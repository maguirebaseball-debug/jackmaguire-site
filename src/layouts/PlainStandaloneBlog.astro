---
import BaseHead from '../components/BaseHead.astro';

type Props = {
	title: string;
	description: string;
	pubDate: string;
	datePublished?: string;
};

const { title, description, pubDate, datePublished } = Astro.props;
const published = datePublished ?? pubDate;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"url": Astro.url.href,
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": Astro.url.href
			},
			"image": new URL('/og-default.png', Astro.site).toString(),
			"author": {
				"@type": "Person",
				"name": "Jack Maguire",
				"url": Astro.site?.toString()
			},
			"publisher": {
				"@type": "Person",
				"name": "Jack Maguire",
				"url": Astro.site?.toString()
			},
			"datePublished": published,
			"dateModified": published
		})} />
		<style>
			body {
				background: #fff;
				color: #000;
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
				font-size: 18px;
				line-height: 1.6;
				margin: 0;
				padding: 0;
			}
			main,
			.plain-footer {
				width: 100%;
				max-width: 720px;
				margin: 0 auto;
				padding: 0 10%;
				box-sizing: border-box;
			}
			main {
				padding-top: 2rem;
				padding-bottom: 4rem;
			}
			.plain-footer {
				padding-bottom: 2rem;
			}
			h1 {
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
				font-size: 2.25rem;
				font-weight: 400;
				line-height: 1.2;
				margin: 0 0 1.5rem;
			}
			h2 {
				font-size: 1.5rem;
				font-weight: 400;
				line-height: 1.3;
				margin: 2rem 0 1rem;
			}
			h3 {
				font-size: 1.25rem;
				font-weight: 400;
				line-height: 1.3;
				margin: 1.5rem 0 1rem;
			}
			p,
			ul,
			ol,
			blockquote,
			table {
				margin: 0 0 1.5rem;
			}
			li {
				margin: 0 0 0.5rem;
			}
			table {
				border-collapse: separate;
				border-spacing: 2px;
			}
			th,
			td {
				padding: 1px;
			}
			.date {
				margin: 0 0 0.75rem;
			}
			.title {
				margin: 0 0 1rem;
			}
			a {
				color: revert;
				text-decoration: revert;
			}
			@media (max-width: 600px) {
				main,
				.plain-footer {
					padding-left: 20px;
					padding-right: 20px;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<div class="title">
				<p class="date">{pubDate}</p>
				<h1>{title}</h1>
			</div>
			<slot />
		</main>
		<footer class="plain-footer">
			<a href="/blog/">More writing</a>
		</footer>
	</body>
</html>
