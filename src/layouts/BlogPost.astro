---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ReadingProgressBar from '../components/ReadingProgressBar.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, ogImage, tags = [], relatedLinks, plain = true } = Astro.props;
const defaultRelatedRecommendationLinks = [
	...(tags.includes('nyc') || tags.includes('food')
		? [
				{ href: '/recommendations/nyc-restaurants/', label: 'NYC restaurant recommendations' },
				{ href: '/recommendations/nyc-pastrami/', label: 'NYC pastrami ranking' },
				{ href: '/recommendations/curry-house-chinatown/', label: 'Curry House Chinatown guide' },
			]
		: []),
	...(tags.includes('books') || tags.includes('philosophy') || tags.includes('essays')
		? [{ href: '/recommendations/books/', label: 'recommended books' }]
		: []),
	...(tags.includes('tech') || tags.includes('ai')
		? [{ href: '/recommendations/apps/', label: 'recommended apps' }]
		: []),
];
const relatedRecommendationLinks = relatedLinks ?? defaultRelatedRecommendationLinks;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} ogImage={ogImage} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"url": Astro.url.href,
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": Astro.url.href
			},
			"image": ogImage ? new URL(ogImage, Astro.site).toString() : new URL('/og-default.png', Astro.site).toString(),
			"author": {
				"@type": "Person",
				"name": "Jack Maguire",
				"url": Astro.site?.toString()
			},
			"publisher": {
				"@type": "Person",
				"name": "Jack Maguire",
				"url": Astro.site?.toString()
			},
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
			"keywords": tags
		})} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 3px;
				box-shadow: var(--box-shadow);
			}
			.article-container {
				display: flex;
				justify-content: center;
				gap: 2.5rem;
				max-width: var(--width-article);
				margin: 0 auto;
				position: relative;
			}
			.prose {
				width: 100%;
				max-width: var(--width-prose);
				margin: 0;
				padding: 1em;
				color: rgb(var(--gray-dark));
				box-sizing: border-box;
			}
			.title {
				max-width: var(--width-prose);
				margin: 0 0 1.5rem;
				padding: 0.75rem 0 0.5rem;
				text-align: left;
				line-height: 1.1;
				word-wrap: break-word;
				hyphens: auto;
			}
			@media (max-width: 1280px) {
				.article-container {
					display: block;
				}
				.prose {
					margin: auto;
				}
			}
			@media (max-width: 480px) {
				.prose {
					padding: 0.5em 0;
					max-width: calc(100vw - 2rem);
					font-size: 17px;
					line-height: 1.68;
				}
				.title {
					padding: 0.5em 0;
					text-align: left;
				}
			}
			.title h1 {
				margin: 0 0 0.5rem 0;
				font-size: clamp(1.4rem, 4.5vw, 3rem);
				font-weight: 700;
				line-height: 1.05;
				letter-spacing: 0;
				text-wrap: pretty;
			}
			.date {
				margin-bottom: 1rem;
				color: var(--accent-dark);
				font-family: var(--font-ui), sans-serif;
				font-size: 0.78rem;
				font-weight: 600;
				letter-spacing: 0;
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 480px) {
				.title h1 {
					font-size: clamp(1.3rem, 6.5vw, 1.65rem);
					line-height: 1.08;
					text-wrap: wrap;
				}
			}
			.prose :global(blockquote) {
				width: min(46rem, 100%);
				margin: 1.75rem 0;
				padding: 0.3rem 0 0.3rem 1.15rem;
				font-size: clamp(1rem, 2vw, 1.1rem);
				line-height: 1.55;
				border-left-color: rgba(85, 107, 47, 0.55);
				color: rgb(var(--black));
			}
			.prose :global(table) {
				font-family: var(--font-ui), sans-serif;
				font-size: 0.82rem;
			}
			.prose :global(h2 + table),
			.prose :global(p + table) {
				margin-top: 0.75rem;
			}
			.rss-cta {
				margin: 0;
				font-size: 0.76rem;
				color: rgba(var(--gray-dark), 0.52);
			}
			.rss-cta a {
				color: rgba(var(--gray-dark), 0.6);
				text-underline-offset: 0.15em;
			}
			.plain-blog {
				background: #fff;
				color: #000;
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
			}
			.plain-blog main {
				width: 80%;
				margin: 0 auto;
				padding: 2rem 0 4rem;
				box-sizing: border-box;
			}
			.plain-blog .article-container {
				display: block;
				max-width: none;
				width: 100%;
				margin: 0;
			}
			.plain-blog .prose {
				width: 100%;
				max-width: none;
				padding: 0;
				color: #000;
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
				font-size: 18px;
				line-height: 1.6;
			}
			.plain-blog .title {
				max-width: none;
				margin: 0 0 1.5rem;
				padding: 0;
			}
			.plain-blog .title h1 {
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
				font-size: 2.25rem;
				font-weight: 400;
				line-height: 1.2;
				margin: 0 0 1.5rem;
			}
			.plain-blog .date {
				color: #000;
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
				font-size: 18px;
				font-weight: 400;
				margin-bottom: 0.75rem;
			}
			.plain-blog .prose :global(h2) {
				font-size: 1.5rem;
				font-weight: 400;
				line-height: 1.3;
				margin: 2rem 0 1rem;
			}
			.plain-blog .prose :global(p),
			.plain-blog .prose :global(ol),
			.plain-blog .prose :global(ul) {
				margin: 0 0 1.5rem;
			}
			.plain-blog .prose :global(li) {
				margin: 0 0 0.5rem;
			}
			.plain-blog .prose :global(a),
			.plain-blog .plain-footer a {
				color: revert;
				text-decoration: revert;
				text-underline-offset: auto;
			}
			.plain-blog .plain-footer {
				width: 80%;
				margin: 0 auto;
				padding: 0 0 2rem;
				font-family: Charter, "Bitstream Charter", "Sitka Text", Cambria, "Times New Roman", Times, serif;
				font-size: 18px;
				line-height: 1.6;
				box-sizing: border-box;
			}
			@media (max-width: 600px) {
				.plain-blog main,
				.plain-blog .plain-footer {
					width: 100%;
					padding-left: 20px;
					padding-right: 20px;
				}
			}
		</style>
	</head>

	<body class:list={[plain && 'plain-blog']}>
		{!plain && <ReadingProgressBar />}
		{!plain && <Header />}
		<main>
			<article>
				<div class="hero-image">
					{!plain && heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="article-container">
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
						</div>
						{!plain && (
							<div style="background: #f5f5f5; border-left: 4px solid #556B2F; padding: 1.25rem; margin: 2rem 0; font-size: 0.95rem; line-height: 1.6;">
								<p style="margin: 0 0 0.5rem 0;"><strong>Jack Maguire</strong> is a writer and analyst based in East Village, NYC. He covers food, travel, AI, and sports with an emphasis on research and firsthand perspective. <a href="/about/" style="color: #556B2F;">Read more</a></p>
							</div>
						)}
						<slot />
						{
							!plain && relatedRecommendationLinks.length > 0 && (
								<>
									<hr />
									<p>Further reading:</p>
									<ul>
										{relatedRecommendationLinks.map((link) => (
											<li>
												<a href={link.href}>{link.label}</a>
											</li>
										))}
									</ul>
									<p class="rss-cta">New posts occasionally. <a href="/rss.xml">Subscribe via RSS</a> to follow along.</p>
								</>
							)
						}
					</div>
					{!plain && <TableOfContents />}
				</div>
			</article>
		</main>
		{plain && (
			<footer class="plain-footer">
				<a href="/blog/">More writing</a>
			</footer>
		)}
		{!plain && <Footer />}
	</body>
</html>
