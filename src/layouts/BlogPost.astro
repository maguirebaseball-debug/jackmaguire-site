---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ReadingProgressBar from '../components/ReadingProgressBar.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, ogImage, tags = [] } = Astro.props;
const relatedRecommendationLinks = [
	...(tags.includes('nyc') || tags.includes('food')
		? [
				{ href: '/recommendations/nyc-restaurants/', label: 'NYC restaurant recommendations' },
				{ href: '/recommendations/nyc-pastrami/', label: 'NYC pastrami ranking' },
				{ href: '/recommendations/curry-house-chinatown/', label: 'Curry House Chinatown guide' },
			]
		: []),
	...(tags.includes('books') || tags.includes('philosophy') || tags.includes('essays')
		? [{ href: '/recommendations/books/', label: 'recommended books' }]
		: []),
	...(tags.includes('tech') || tags.includes('ai')
		? [{ href: '/recommendations/apps/', label: 'recommended apps' }]
		: []),
];
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} ogImage={ogImage} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"image": ogImage ? new URL(ogImage, Astro.site).toString() : new URL('/og-default.png', Astro.site).toString(),
			"author": {
				"@type": "Person",
				"name": "Jack Maguire",
				"url": Astro.site?.toString()
			},
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString()
		})} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.article-container {
				display: flex;
				justify-content: center;
				gap: 3rem;
				max-width: 1200px;
				margin: 0 auto;
				position: relative;
			}
			.prose {
				width: 100%;
				max-width: 800px;
				margin: 0;
				padding: 1em;
				color: rgb(var(--gray-dark));
				box-sizing: border-box;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.25;
				word-wrap: break-word;
				hyphens: auto;
			}
			@media (max-width: 1280px) {
				.article-container {
					display: block;
				}
				.prose {
					margin: auto;
				}
			}
			@media (max-width: 480px) {
				.prose {
					padding: 0.5em 0;
				}
				.title {
					padding: 0.5em 0;
					text-align: left;
				}
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.related-recommendations {
				margin-top: 3rem;
				padding: 1.1rem 1.25rem;
				border: 1px solid rgba(var(--gray-light), 0.8);
				border-left: 4px solid var(--accent);
				border-radius: 10px;
				background: #fdf8ef;
				font-size: 0.92rem;
			}
			.related-recommendations h2 {
				margin: 0 0 0.5rem 0;
				font-size: 1rem;
			}
			.related-recommendations ul {
				margin: 0;
				padding-left: 1.2rem;
			}
			.related-recommendations li {
				margin: 0.25rem 0;
			}
		</style>
	</head>

	<body>
		<ReadingProgressBar />
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="article-container">
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
						{
							relatedRecommendationLinks.length > 0 && (
								<section class="related-recommendations" aria-labelledby="related-recommendations-title">
									<h2 id="related-recommendations-title">Related recommendation hubs</h2>
									<ul>
										{relatedRecommendationLinks.map((link) => (
											<li>
												<a href={link.href}>{link.label}</a>
											</li>
										))}
									</ul>
								</section>
							)
						}
					</div>
					<TableOfContents />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
