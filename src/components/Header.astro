---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/start">Start</HeaderLink>
			<span class="sep">|</span>
			<HeaderLink href="/blog">Writing</HeaderLink>
			<span class="sep">|</span>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<span class="sep">|</span>
			<HeaderLink href="/recommendations">Recs</HeaderLink>
			<span class="sep">|</span>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--paper);
		border-bottom: 1px solid rgba(var(--gray-light), 0.8);
	}
	h2 {
		margin: 0;
		font-size: 0.95em;
		letter-spacing: 0;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--width-site);
		margin: 0 auto;
		gap: 1.25rem;
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.75rem;
	}
	.sep {
		color: rgba(var(--gray), 0.5);
		font-size: 0.8em;
		padding: 0 0.1rem;
	}
	nav a {
		padding: 0.85em 0;
		color: var(--black);
		border-bottom: 3px solid transparent;
		text-decoration: none;
		white-space: nowrap;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding: 0.7rem 0.85rem 0.6rem;
		}
		nav {
			max-width: 100%;
			display: grid;
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 0.35rem;
		}
		.internal-links {
			width: 100%;
			justify-content: center;
			gap: clamp(0.42rem, 3vw, 0.9rem);
			font-size: clamp(0.72rem, 3.35vw, 0.88rem);
		}
		nav a {
			padding: 0.15rem 0 0.25rem;
			border-bottom-width: 2px;
		}
	}
</style>
