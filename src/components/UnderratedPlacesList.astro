---
import placesData from '../data/underrated_places.json';

// We extract unique categories, boroughs, and neighborhoods for the dropdowns
const categories = [...new Set(placesData.map((p: any) => p.category))].sort();
const boroughs = [...new Set(placesData.map((p: any) => p.borough))].sort();
const neighborhoods = [...new Set(placesData.map((p: any) => p.neighborhood))].sort();
---

<div class="places-app">
  <div class="controls-container">
    <div class="filter-group">
      <label for="category-filter">Category</label>
      <select id="category-filter">
        <option value="All">All Categories</option>
        {categories.map((c) => <option value={c}>{c}</option>)}
      </select>
    </div>

    <div class="filter-group">
      <label for="borough-filter">Borough</label>
      <select id="borough-filter">
        <option value="All">All Boroughs</option>
        {boroughs.map((b) => <option value={b}>{b}</option>)}
      </select>
    </div>

    <div class="filter-group">
      <label for="neighborhood-filter">Neighborhood</label>
      <select id="neighborhood-filter">
        <option value="All">All Neighborhoods</option>
        {neighborhoods.map((n) => <option value={n}>{n}</option>)}
      </select>
    </div>

    <div class="filter-group">
      <label for="sort-select">Sort By</label>
      <select id="sort-select">
        <option value="rating-desc">Highest Rated</option>
        <option value="reviews-desc">Most Reviewed</option>
        <option value="reviews-asc">Hidden Gems (Fewest Reviews)</option>
      </select>
    </div>
  </div>

  <div class="results-meta">
    Showing <span id="results-count">0</span> places
  </div>

  <div id="places-grid" class="places-grid">
    <!-- Places will be rendered here by Vanilla JS -->
  </div>

  <div class="load-more-container">
    <button id="load-more-btn" class="load-more-btn" style="display: none;">Load More</button>
  </div>
</div>

<script id="places-data-json" type="application/json" set:html={JSON.stringify(placesData)}></script>

<script>
  const placesDataRaw = document.getElementById('places-data-json')?.textContent;
  const allPlaces = placesDataRaw ? JSON.parse(placesDataRaw) : [];

  let filteredPlaces = [...allPlaces];
  let currentPage = 1;
  const itemsPerPage = 30;

  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
  const boroughFilter = document.getElementById('borough-filter') as HTMLSelectElement;
  const neighborhoodFilter = document.getElementById('neighborhood-filter') as HTMLSelectElement;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  
  const placesGrid = document.getElementById('places-grid');
  const resultsCount = document.getElementById('results-count');
  const loadMoreBtn = document.getElementById('load-more-btn');

  function applyFiltersAndSort() {
    const cat = categoryFilter.value;
    const boro = boroughFilter.value;
    const neigh = neighborhoodFilter.value;
    const sort = sortSelect.value;

    filteredPlaces = allPlaces.filter((p: any) => {
      const matchCat = cat === 'All' || p.category === cat;
      const matchBoro = boro === 'All' || p.borough === boro;
      const matchNeigh = neigh === 'All' || p.neighborhood === neigh;
      return matchCat && matchBoro && matchNeigh;
    });

    if (sort === 'rating-desc') {
      filteredPlaces.sort((a: any, b: any) => b.rating - a.rating || b.reviews - a.reviews);
    } else if (sort === 'reviews-desc') {
      filteredPlaces.sort((a: any, b: any) => b.reviews - a.reviews || b.rating - a.rating);
    } else if (sort === 'reviews-asc') {
      filteredPlaces.sort((a: any, b: any) => a.reviews - b.reviews || b.rating - a.rating);
    }

    currentPage = 1;
    renderGrid(true);
  }

  function renderGrid(reset = false) {
    if (!placesGrid || !resultsCount) return;

    if (reset) {
      placesGrid.innerHTML = '';
      if (resultsCount) {
        resultsCount.textContent = filteredPlaces.length.toString();
      }
    }

    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const placesToRender = filteredPlaces.slice(start, end);

    placesToRender.forEach((place: any) => {
      const card = document.createElement('div');
      card.className = 'place-card';
      
      const header = document.createElement('div');
      header.className = 'place-card-header';
      header.innerHTML = `
        <h2>${place.name}</h2>
        <div class="place-rating">${place.rating} ⭐ (${place.reviews} reviews)</div>
      `;

      const details = document.createElement('div');
      details.className = 'place-details';
      details.innerHTML = `
        <span class="tag">${place.category}</span>
        <span class="tag">${place.neighborhood}, ${place.borough}</span>
        <p class="address">${place.address}</p>
        <a href="${place.maps_link}" target="_blank" rel="noopener noreferrer" class="maps-link">View on Maps →</a>
      `;

      const citation = document.createElement('div');
      citation.className = 'reddit-citation';
      citation.innerHTML = `
        <p class="quote">"${place.reddit_quote}"</p>
        <small class="thread-id">— ${place.reddit_thread}</small>
      `;

      card.appendChild(header);
      card.appendChild(details);
      card.appendChild(citation);
      placesGrid.appendChild(card);
    });

    if (loadMoreBtn) {
      if (end < filteredPlaces.length) {
        loadMoreBtn.style.display = 'block';
      } else {
        loadMoreBtn.style.display = 'none';
      }
    }
  }

  categoryFilter?.addEventListener('change', applyFiltersAndSort);
  boroughFilter?.addEventListener('change', applyFiltersAndSort);
  neighborhoodFilter?.addEventListener('change', applyFiltersAndSort);
  sortSelect?.addEventListener('change', applyFiltersAndSort);

  loadMoreBtn?.addEventListener('click', () => {
    currentPage++;
    renderGrid();
  });

  // Initial render
  applyFiltersAndSort();
</script>

<style>
  .places-app {
    margin-top: 2rem;
  }
  .controls-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
    background: rgba(85, 107, 47, 0.05); /* Olive green tint */
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(85, 107, 47, 0.2);
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .filter-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #4a4a4a;
  }
  .filter-group select {
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: var(--font-ui, system-ui);
    background-color: #fff;
    cursor: pointer;
  }
  .filter-group select:focus {
    outline: 2px solid #556B2F;
    border-color: #556B2F;
  }
  .results-meta {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    color: #666;
    font-weight: 500;
  }
  .places-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .place-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .place-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(85, 107, 47, 0.1);
    border-color: rgba(85, 107, 47, 0.4);
  }
  .place-card-header h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
    color: #222;
  }
  .place-rating {
    font-weight: 600;
    color: #556B2F;
    font-size: 0.9rem;
  }
  .place-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tag {
    display: inline-block;
    background: #f0f0f0;
    color: #333;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    width: max-content;
  }
  .address {
    margin: 0;
    font-size: 0.9rem;
    color: #555;
  }
  .maps-link {
    color: #556B2F;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    width: max-content;
  }
  .maps-link:hover {
    text-decoration: underline;
  }
  .reddit-citation {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px dashed #ddd;
    font-style: italic;
    color: #666;
    font-size: 0.85rem;
  }
  .quote {
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }
  .thread-id {
    color: #888;
  }
  .load-more-container {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }
  .load-more-btn {
    background-color: #556B2F;
    color: #fff;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.2s ease;
  }
  .load-more-btn:hover {
    background-color: #3b4d1f;
  }
</style>
