---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
}

let cleanPathname = Astro.url.pathname;
if (!cleanPathname.endsWith('/') && !cleanPathname.split('/').pop().includes('.')) {
	cleanPathname += '/';
}
const canonicalURL = new URL(cleanPathname, Astro.site);

const { title, description, ogImage = '/og-default.png' } = Astro.props;
const ogImageUrl = new URL(ogImage, Astro.site);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<ClientRouter />

<Font cssVariable="--font-heading" preload />
<Font cssVariable="--font-ui" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&display=swap" rel="stylesheet">
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-1697T7D92W"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-1697T7D92W');
</script>

<script>
	const engagementStorageKey = 'jm_engagement_lead_v1';
	const engagementThresholdMs = 2 * 60 * 1000;
	const metaFbcStorageKey = 'jm_meta_fbc';

	function readCookie(name) {
		return document.cookie
			.split('; ')
			.find((cookie) => cookie.startsWith(`${name}=`))
			?.split('=')
			.slice(1)
			.join('=');
	}

	function getFbc() {
		const cookieFbc = readCookie('_fbc');
		if (cookieFbc) return cookieFbc;

		const storedFbc = sessionStorage.getItem(metaFbcStorageKey);
		if (storedFbc) return storedFbc;

		const fbclid = new URLSearchParams(window.location.search).get('fbclid');
		if (!fbclid) return undefined;

		const fbc = `fb.1.${Date.now()}.${fbclid}`;
		sessionStorage.setItem(metaFbcStorageKey, fbc);
		return fbc;
	}

	function getEngagementState() {
		try {
			return JSON.parse(sessionStorage.getItem(engagementStorageKey) || '{"paths":[],"activeMs":0,"sent":false}');
		} catch {
			return { paths: [], activeMs: 0, sent: false };
		}
	}

	function saveEngagementState(state) {
		sessionStorage.setItem(engagementStorageKey, JSON.stringify(state));
	}

	function recordCurrentPage() {
		const state = getEngagementState();
		const path = `${window.location.pathname}${window.location.search}`;
		state.paths = [...new Set([...state.paths, path])];
		saveEngagementState(state);
	}

	if (!window.__jmEngagementTrackingInitialized) {
		window.__jmEngagementTrackingInitialized = true;
		getFbc();
		recordCurrentPage();

		let activeSince = document.visibilityState === 'visible' ? Date.now() : null;

		const addActiveTime = () => {
			if (activeSince === null) return;
			const latestState = getEngagementState();
			latestState.activeMs += Date.now() - activeSince;
			activeSince = Date.now();
			saveEngagementState(latestState);
		};

		const sendLeadIfQualified = () => {
			addActiveTime();
			const latestState = getEngagementState();
			if (latestState.sent || latestState.paths.length < 3 || latestState.activeMs < engagementThresholdMs) return;

			latestState.sent = true;
			saveEngagementState(latestState);
			fetch('/api/capi-lead/', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					eventId: crypto.randomUUID(),
					eventName: 'engaged_visitor_3_pages_2_minutes',
					eventSourceUrl: window.location.href,
					fbp: readCookie('_fbp'),
					fbc: getFbc(),
				}),
				keepalive: true,
			}).catch(() => {});
		};

		const onVisibilityChange = () => {
			if (document.visibilityState === 'visible') {
				activeSince = Date.now();
			} else {
				addActiveTime();
				activeSince = null;
			}
			sendLeadIfQualified();
		};

		document.addEventListener('visibilitychange', onVisibilityChange);
		document.addEventListener('astro:page-load', () => {
			recordCurrentPage();
			sendLeadIfQualified();
		});
		window.addEventListener('pagehide', () => {
			addActiveTime();
			sendLeadIfQualified();
		});
		window.setInterval(sendLeadIfQualified, 10_000);
	}
</script>
