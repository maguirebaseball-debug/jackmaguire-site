---
<div class="reading-progress-container" aria-hidden="true">
  <div class="reading-progress-bar" id="readingProgressBar"></div>
</div>

<style>
  .reading-progress-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: transparent;
    z-index: 10000;
    pointer-events: none;
  }
  .reading-progress-bar {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, var(--accent) 0%, #8fbc8f 100%);
    transition: width 0.1s ease-out;
  }
</style>

<script>
  let scrollHandler: (() => void) | null = null;

  function initProgressBar() {
    const bar = document.getElementById('readingProgressBar');
    if (!bar) return;

    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }

    scrollHandler = () => {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      
      if (docHeight > 0) {
        const percentage = (scrollTop / docHeight) * 100;
        bar.style.width = `${Math.min(100, Math.max(0, percentage))}%`;
      } else {
        bar.style.width = '0%';
      }
    };

    window.addEventListener('scroll', scrollHandler);
    scrollHandler();
  }

  // Bind to page-load for View Transitions compatibility
  document.addEventListener('astro:page-load', initProgressBar);
</script>
