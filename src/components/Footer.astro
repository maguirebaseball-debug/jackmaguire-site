---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p>
			Jack Maguire · East Village, NYC · notes on paid social, food, travel, reading, tools.
			<a href="/start">Start</a> · <a href="/blog">Writing</a> · <a href="/recommendations">Recs</a> · <a href="/now">Now</a> · <a href="/rss.xml">RSS</a>
			&copy; {today.getFullYear()}
		</p>
		<p class="footer-ig">
			More of this in photo form: <a href="https://instagram.com/jack.maguire__/" id="ig-follow-link" target="_blank" rel="noopener">follow along on Instagram</a>
		</p>
	</div>
</footer>

<script>
	const igLink = document.getElementById('ig-follow-link');
	igLink?.addEventListener('click', () => {
		fetch('/api/capi-lead/', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				eventName: 'instagram_follow_clickout',
				eventSourceUrl: window.location.href,
			}),
			keepalive: true,
		}).catch(() => {});
	});
</script>
<style>
	footer {
		padding: 1.5em 1em;
		background: var(--paper);
		color: rgb(var(--gray-dark));
		font-size: 0.8em;
		border-top: 1px solid rgba(var(--gray-light), 0.7);
		margin-top: 2em;
	}
	.footer-content {
		max-width: var(--width-site);
		margin: 0 auto;
	}
	.footer-content p {
		margin: 0;
		line-height: 1.5;
	}
	.footer-content a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-content a:hover {
		color: var(--accent);
		text-decoration: underline;
	}
	@media (max-width: 600px) {
		footer {
			padding: 1.2em 1em;
			margin-top: 1.5em;
			font-size: 0.75em;
		}
	}
</style>
