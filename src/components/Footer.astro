---
const today = new Date();
---

<footer>
        <div class="footer-content">
                <div class="footer-column brand">
                        <h3>Jack Maguire</h3>
                        <p>Performance marketing, urbanism, and intentional living. Based in the East Village, New York City.</p>
                </div>
                <div class="footer-column links">
                        <h3>Index</h3>
                        <ul>
                                <li><a href="/start">Start Here</a></li>
                                <li><a href="/blog">Writing</a></li>
                                <li><a href="/projects">Projects</a></li>
                                <li><a href="/recommendations">Recommendations</a></li>
                        </ul>
                </div>
                <div class="footer-column links">
                        <h3>Connect</h3>
                        <ul>
                                <li><a href="/about">About & Contact</a></li>
                                <li><a href="/now">Now Page</a></li>
                                <li><a href="/rss.xml" target="_blank">RSS Feed</a></li>
                        </ul>
                </div>
        </div>
        <div class="footer-bottom">
                <p>&copy; {today.getFullYear()} Jack Maguire. All rights reserved.</p>
        </div>
</footer>
<style>
        footer {
                padding: 4em 1em 2em 1em;
                background: linear-gradient(var(--gray-gradient)) no-repeat;
                color: rgb(var(--gray-dark));
                font-size: 0.9em;
                border-top: 1px solid rgb(var(--gray-light));
                margin-top: 4em;
        }
        .footer-content {
                max-width: 720px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 2fr 1fr 1fr;
                gap: 2em;
                padding-bottom: 2em;
                border-bottom: 1px solid rgb(var(--gray-light));
        }
        .footer-column h3 {
                font-family: var(--font-fraunces);
                font-size: 1.2em;
                color: rgb(var(--black));
                margin-top: 0;
                margin-bottom: 0.8em;
        }
        .footer-column.brand p {
                line-height: 1.6;
                color: rgb(var(--gray));
                margin: 0;
        }
        .footer-column.links ul {
                list-style: none;
                padding: 0;
                margin: 0;
        }
        .footer-column.links li {
                margin-bottom: 0.5em;
        }
        .footer-column.links a {
                color: rgb(var(--gray-dark));
                text-decoration: none;
                transition: color 0.2s ease;
        }
        .footer-column.links a:hover {
                color: var(--accent);
        }
        .footer-bottom {
                max-width: 720px;
                margin: 0 auto;
                padding-top: 1.5em;
                text-align: center;
                color: rgb(var(--gray));
                font-size: 0.85em;
        }
        .footer-bottom p {
                margin: 0;
        }
        @media (max-width: 600px) {
                .footer-content {
                        grid-template-columns: 1fr;
                        text-align: center;
                }
        }
</style>
