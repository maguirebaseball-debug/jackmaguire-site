---
const today = new Date();
const mailchimpFormAction = import.meta.env.PUBLIC_MAILCHIMP_SUBSCRIBE_URL;
const mailchimpTagId = import.meta.env.PUBLIC_MAILCHIMP_FOOTER_TAG_ID;
---

<footer>
	<div class="footer-content">
		<p>
			Jack Maguire · East Village, NYC · notes on paid social, food, travel, reading, tools.
			<a href="/blog">Writing</a> · <a href="/recommendations">Recs</a> · <a href="/now">Now</a> · <a href="/rss.xml">RSS</a>
			&copy; {today.getFullYear()}
		</p>
		<p class="footer-ig">
			More of this in photo form: <a href="https://instagram.com/jack.maguire__/" id="ig-follow-link" target="_blank" rel="noopener">follow along on Instagram</a>
		</p>
		{mailchimpFormAction && (
			<form class="newsletter-form" action={mailchimpFormAction} method="post" target="_blank">
				<label for="footer-email">Subscribe for my newsletter</label>
				<div class="newsletter-fields">
					<input id="footer-email" name="EMAIL" type="email" autocomplete="email" placeholder="you@example.com" required />
					{mailchimpTagId && <input type="hidden" name="tags" value={mailchimpTagId} />}
					<button type="submit">Subscribe</button>
				</div>
			</form>
		)}
	</div>
</footer>

<script>
	const igLink = document.getElementById('ig-follow-link');
	igLink?.addEventListener('click', () => {
		fetch('/api/capi-lead/', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				eventName: 'instagram_follow_clickout',
				eventSourceUrl: window.location.href,
			}),
			keepalive: true,
		}).catch(() => {});
	});
</script>
<style>
	footer {
		padding: 1.5em 1em;
		background: var(--paper);
		color: rgb(var(--gray-dark));
		font-size: 0.8em;
		border-top: 1px solid rgba(var(--gray-light), 0.7);
		margin-top: 2em;
	}
	.footer-content {
		max-width: var(--width-site);
		margin: 0 auto;
	}
	.footer-content p {
		margin: 0;
		line-height: 1.5;
	}
	.footer-content a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-content a:hover {
		color: var(--accent);
		text-decoration: underline;
	}
	.newsletter-form {
		margin-top: 0.85em;
	}
	.newsletter-form label {
		display: block;
		margin-bottom: 0.35em;
	}
	.newsletter-fields {
		display: flex;
		gap: 0.4em;
		max-width: 24rem;
	}
	.newsletter-fields input {
		min-width: 0;
		flex: 1;
		padding: 0.35em 0.45em;
		border: 1px solid rgb(var(--gray));
		border-radius: 0;
		font: inherit;
	}
	.newsletter-fields button {
		padding: 0.35em 0.65em;
		border: 1px solid rgb(var(--gray-dark));
		border-radius: 0;
		background: transparent;
		color: rgb(var(--gray-dark));
		font: inherit;
		cursor: pointer;
	}
	.newsletter-fields button:hover {
		background: rgb(var(--gray-dark));
		color: var(--paper);
	}
	@media (max-width: 600px) {
		footer {
			padding: 1.2em 1em;
			margin-top: 1.5em;
			font-size: 0.75em;
		}
		.newsletter-fields {
			max-width: none;
		}
	}
</style>
