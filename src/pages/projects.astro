---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects: ${SITE_TITLE}`} description="A collection of tools, data experiments, and projects from Jack Maguire, including cocktail databases, ingredient pairing analysis, and structured travel itineraries." />
	</head>
	<body>
		<Header />
		<main>
			<section class="project-lede">
				<p class="kicker">Small systems and route plans</p>
				<h1>Projects</h1>
				<p class="intro">Tools, itineraries, and structured notes built around questions I wanted answered cleanly.</p>
			</section>

			<ul class="project-list">
				<li>
					<a href="/itineraries/central-europe">
						<span class="title">A Fortnight in Central Europe</span>
						<span class="desc">Fifteen days by rail, bus, shuttle, and one short flight from Geneva to Dublin.</span>
					</a>
				</li>
				<li>
					<a href="/itineraries/nyc-euro">
						<span class="title">NYC Euro-esque Day</span>
						<span class="desc">A Greenwich Village and Meatpacking day on foot: one good walk and one good table</span>
					</a>
				</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		color: rgb(var(--gray));
		margin: 0;
	}
	.project-lede {
		margin-bottom: 2.4rem;
		padding-bottom: 1.2rem;
		border-bottom: 1px solid rgba(85, 107, 47, 0.22);
	}
	.kicker {
		margin: 0 0 0.45rem;
		font-family: var(--font-ui), sans-serif;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent-dark);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.project-list li {
		border-bottom: 1px solid rgba(var(--gray-light), 0.9);
	}
	.project-list li a {
		display: block;
		display: grid;
		grid-template-columns: 15rem 1fr;
		gap: 1.2rem;
		padding: 1.25em 0;
		text-decoration: none;
		color: inherit;
	}
	.project-list li a:hover .title {
		color: var(--accent);
	}
	.title {
		display: block;
		font-size: 1.1em;
		font-weight: 600;
		color: rgb(var(--black));
		margin-bottom: 0.3em;
	}
	@media (max-width: 620px) {
		.project-list li a {
			grid-template-columns: 1fr;
			gap: 0.2rem;
		}
	}
	.desc {
		display: block;
		font-size: 0.9em;
		color: rgb(var(--gray));
	}
</style>
