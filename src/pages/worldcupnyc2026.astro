      font-size: 2rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .team-info { flex: 1; min-width: 0; }

    .group-badge {
      display: inline-block;
      background: rgba(234, 252, 38, 0.1);
      color: var(--accent);
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.15em;
