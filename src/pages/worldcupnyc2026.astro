      color: var(--text-muted);
    }

    .venue-links {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 0.75rem 0;
    }

    .venue-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      border: 1px solid var(--border);
      padding: 0.25rem 0.6rem;
      border-radius: 3px;
      transition: all 0.12s;
      white-space: nowrap;
    }

    .venue-link:hover {
      background: rgba(234,252,38,0.08);
      border-color: var(--accent);
    }

    .venue-phone {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .card-note {
      font-size: 0.72rem;
      color: #f5a623;
      background: rgba(245, 166, 35, 0.08);
      border: 1px solid rgba(245, 166, 35, 0.2);
      border-radius: 4px;
      padding: 0.4rem 0.6rem;
      margin-bottom: 0.75rem;
    }


    /* ---- EXCLUDED SECTION ---- */
    .excluded-section {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .excluded-title {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.1rem;
      color: #fff;
      margin-bottom: 0.75rem;
    }

    .excluded-intro {
      font-size: 0.9rem;
      color: var(--text-muted);
      max-width: 600px;
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }

    .excluded-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-bottom: 2rem;
    }

    .excluded-card {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.75rem 1rem;
      min-width: 200px;
    }

    .excluded-flag { font-size: 1.5rem; }
    .excluded-info { flex: 1; }

    .excluded-name {
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--text-primary);
    }

    .excluded-tag {
      font-size: 0.68rem;
      color: #cc6666;
      margin-top: 0.1rem;
    }

    /* ---- CTA ---- */
    .cta-box {
      background: linear-gradient(135deg, #0f1929, #162238);
      border: 1px solid var(--accent);
      border-radius: var(--radius);
      padding: 2rem;
      text-align: center;
      margin-top: 1rem;
      margin-bottom: 3rem;
    }

    .cta-box h3 {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
      color: #fff;
    }

    .cta-box p {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }

    .cta-links {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .cta-link {
      display: inline-block;
      background: var(--accent);
      color: #000;
      font-weight: 800;
      font-size: 0.8rem;
      padding: 0.6rem 1.4rem;
      border-radius: 4px;
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: opacity 0.12s;
    }

    .cta-link:hover { opacity: 0.85; }

    .cta-link.secondary {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
    }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 600px) {
      .team-grid { grid-template-columns: 1fr; }
      .wc-hero { padding: 2rem 1rem 1.5rem; }
      .date-label { font-size: 1rem; }
    }
  </style>
</head>
<body>
  <Header />

  <main>
    <div class="wc-hero">
      <div class="wc-container">
        <div class="wc-badge">FIFA World Cup 2026 NYC Guide</div>
        <h1 class="wc-title">Where to Watch the <span>World Cup</span> in NYC, by Country</h1>
        <div class="wc-intro">
          <p>
            I put this together because I am currently unemployed and I want to watch as many
            2026 World Cup matches as possible. New York has so many diverse neighborhoods and bars
            that I thought it would be worth having one place where every supporter can find where
            their country gathers. There is no atmosphere quite like watching a match inside a room
            full of people rooting for the same country.
          </p>
          <p>
            Every venue on this page has been verified through at least two independent sources as
            currently open and active as a supporter destination for that country. Nine teams did not
            have two-source verified supporter pubs in NYC and are listed at the bottom.
          </p>
        </div>
        <div class="wc-meta">All kickoff times Eastern Time (ET). Group stage runs June 11 to June 27, 2026.</div>

        <div class="stats-bar">
          <div class="stat-item">
            <div class="stat-num">39</div>
            <div class="stat-label">Verified Venues</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">48</div>
            <div class="stat-label">Teams</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">5</div>
            <div class="stat-label">Boroughs</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">104</div>
            <div class="stat-label">Total Matches</div>
          </div>
        </div>
      </div>
    </div>

    <div class="wc-container">
      <!-- CHRONOLOGICAL MATCH SCHEDULE -->
      {matchDays.map(day => (
        <div class="date-section">
          <div class="date-header">
            <span class="date-label">{day.label}</span>
          </div>
          {day.slots.map(slot => (
            <div class="time-slot">
              <div class="time-label">{slot.time}</div>
              <div class="team-grid">
                {slot.entries.map(({team, match}) => (
                  <div class="team-card">
                    <div class="team-card-header">
                      <div class="team-flag">{team.flag}</div>
                      <div class="team-info">
                        <div class="group-badge">Group {team.group}</div>
                        <div class="team-name">{team.team}</div>
                        <div class="match-context">vs {match.opponent}</div>
                        <div class="venue-name">{team.venue}</div>
                        <div class="venue-neighborhood">{team.neighborhood}</div>
                      </div>
                    </div>

                    {team.note && <div class="card-note">{team.note}</div>}

                    <div class="venue-phone">{team.address} &bull; {team.phone}</div>

                    <div class="venue-links">
                      <a href={team.mapsLink} target="_blank" rel="noopener" class="venue-link">
                        Google Maps
                      </a>
                      {team.website && (
                        <a href={team.website} target="_blank" rel="noopener" class="venue-link">
                          Website
                        </a>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ))}

      <!-- EXCLUDED TEAMS -->
      <div class="excluded-section">
        <div class="excluded-title">No Verified Supporter Pub Found</div>
        <p class="excluded-intro">
          These nine teams did not have a New York City bar or restaurant that could be confirmed
          through two independent sources as a dedicated supporter destination for that country.
          Know of one? Please get in touch.
        </p>
        <div class="excluded-grid">
          {excludedTeams.map(t => (
            <div class="excluded-card">
              <div class="excluded-flag">{t.flag}</div>
              <div class="excluded-info">
                <div class="excluded-name">{t.team}</div>
                <div class="excluded-tag">Group {t.group} &bull; No verified pub found</div>
              </div>
            </div>
          ))}
        </div>

        <div class="cta-box">
          <h3>Know a Venue for One of These Countries?</h3>
          <p>
            If you know of a bar or restaurant in NYC where supporters of one of these countries
            gather to watch their national team, with the match on TV and audio, please reach out.
            I will verify it and add it to this guide.
          </p>
          <div class="cta-links">
            <a href="mailto:maguirebaseball@gmail.com?subject=World+Cup+NYC+Venue+Tip" class="cta-link">
