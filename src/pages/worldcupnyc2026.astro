  { team: "Curazao", flag: "🇨🇼", region: "North & Central America", group: "E" }
];

function timeToMinutes(t) {
  const m = t.match(/(\d+)(?::(\d+))?\s*(AM|PM)/i);
  if (!m) return 0;
  let h = parseInt(m[1]);
  const min = parseInt(m[2] ?? '0');
  const ampm = m[3].toUpperCase();
  if (ampm === 'PM' && h !== 12) h += 12;
  if (ampm === 'AM' && h === 12) h = 0;
  return h * 60 + min;
}

const DOW = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

function fmtDate(d) {
  const day = parseInt(d.split(' ')[1]);
  return `${DOW[new Date(2026, 5, day).getDay()]}, June ${day}`;
}

const allEntries = teams.flatMap(team => team.matches.map(match => ({ team, match })));
allEntries.sort((a, b) => {
  const da = parseInt(a.match.date.split(' ')[1]);
  const db = parseInt(b.match.date.split(' ')[1]);
  if (da !== db) return da - db;
  return timeToMinutes(a.match.time) - timeToMinutes(b.match.time);
});

const matchDays = [];
for (const entry of allEntries) {
  let day = matchDays.find(d => d.date === entry.match.date);
  if (!day) {
    day = { date: entry.match.date, label: fmtDate(entry.match.date), slots: [] };
    matchDays.push(day);
  }
  let slot = day.slots.find(s => s.time === entry.match.time);
  if (!slot) {
    slot = { time: entry.match.time, entries: [] };
    day.slots.push(slot);
  }
  slot.entries.push(entry);
}
