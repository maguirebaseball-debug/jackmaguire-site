<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <style>
    :root {
      --bg-primary: #060a14;
      --bg-card: #0f1929;
      --bg-card-hover: #162238;
      --accent: #eafc26;
      --text-primary: #f0f4ff;
      --text-muted: #8899bb;
      --border: rgba(234, 252, 38, 0.12);
      --border-active: rgba(234, 252, 38, 0.5);
      --radius: 8px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
      line-height: 1.6;
    }

    .wc-container {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ---- HERO ---- */
    .wc-hero {
      background: linear-gradient(180deg, #000d1f 0%, #060a14 100%);
      border-bottom: 1px solid var(--border);
      padding: 3rem 1.25rem 2.5rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .wc-hero > * {
      width: 100%;
      max-width: 1080px;
    }

    .wc-badge {
      display: inline-block;
      background: var(--accent);
      color: #000;
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 2px;
      margin-bottom: 1.25rem;
    }

    .wc-title {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: clamp(1.9rem, 5vw, 3.2rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: #fff;
      max-width: 720px;
      margin: 0 auto 1rem;
    }

    .wc-title span { color: var(--accent); }

    .wc-intro {
      max-width: 600px;
      margin: 0 auto 1rem;
      color: var(--text-muted);
      font-size: 1rem;
      line-height: 1.7;
    }

    .wc-intro p + p { margin-top: 0.85rem; }

    .wc-meta {
      font-size: 0.78rem;
      color: var(--text-muted);
      letter-spacing: 0.05em;
    }

    /* ---- STATS BAR ---- */
    .stats-bar {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
      padding: 1.25rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    .stat-item { text-align: center; flex: 1; min-width: 80px; }

    .stat-num {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.8rem;
      color: var(--accent);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 0.2rem;
    }

    /* ---- DATE SECTIONS ---- */
    .date-section {
      margin-top: 2.5rem;
    }

    .date-header {
      display: flex;
      align-items: center;
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--accent);
    }

    .date-label {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.2rem;
      letter-spacing: 0.02em;
      color: #fff;
    }

    /* ---- TIME SLOTS ---- */
    .time-slot {
      margin-bottom: 1.75rem;
    }

    .time-label {
      font-family: var(--font-ui, 'Plus Jakarta Sans', sans-serif);
      font-weight: 700;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
      padding-left: 0.1rem;
    }

    /* ---- MATCH CONTEXT ---- */
    .match-context {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-muted);
      margin-top: 0.1rem;
    }

    /* ---- TEAM GRID ---- */
    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1rem;
    }

    /* ---- TEAM CARD ---- */
    .team-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      transition: all 0.15s;
    }

    .team-card:hover {
      border-color: var(--border-active);
      background: var(--bg-card-hover);
    }

    .team-card-header {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 0.85rem;
    }

