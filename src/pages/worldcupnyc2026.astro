<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <style>
    :root {
      --bg-primary: #060a14;
      --bg-card: #0f1929;
      --bg-card-hover: #162238;
      --accent: #eafc26;
      --accent-dark: #c8d900;
      --text-primary: #f0f4ff;
      --text-muted: #8899bb;
      --border: rgba(234, 252, 38, 0.12);
      --border-active: rgba(234, 252, 38, 0.5);
      --red: #e62027;
      --radius: 8px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
      line-height: 1.6;
    }

    .wc-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }

    /* ---- HERO ---- */
    .wc-hero {
      background: linear-gradient(180deg, #000d1f 0%, #060a14 100%);
      border-bottom: 1px solid var(--border);
      padding: 3rem 1.25rem 2.5rem;
      text-align: center;
    }

    .wc-badge {
      display: inline-block;
      background: var(--accent);
      color: #000;
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 2px;
      margin-bottom: 1.25rem;
    }

    .wc-title {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: clamp(1.9rem, 5vw, 3.2rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: #fff;
      max-width: 800px;
      margin: 0 auto 1rem;
    }

    .wc-title span { color: var(--accent); }

    .wc-intro {
      max-width: 660px;
      margin: 0 auto 1rem;
      color: var(--text-muted);
      font-size: 1rem;
      line-height: 1.7;
    }

    .wc-intro p + p { margin-top: 0.85rem; }

    .wc-meta {
      font-size: 0.78rem;
      color: var(--text-muted);
      letter-spacing: 0.05em;
    }

    /* ---- MAP ---- */
    .map-section {
      padding: 2rem 0 0;
    }

    .section-label {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    #wc-map {
      width: 100%;
      height: 480px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      overflow: hidden;
      margin-top: 0.75rem;
    }

    /* ---- CONFEDERATION TABS ---- */
    .conf-nav {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      padding: 2rem 0 0;
    }

    .conf-btn {
      background: var(--bg-card);
      border: 1px solid var(--border);
      color: var(--text-muted);
      font-family: var(--font-ui, 'Plus Jakarta Sans', sans-serif);
      font-weight: 700;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .conf-btn:hover, .conf-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #000;
    }

    /* ---- CONFEDERATION SECTION ---- */
    .confederation-section {
      margin-top: 2.5rem;
    }

    .conf-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .conf-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .conf-name {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      color: #fff;
    }

    .conf-count {
      margin-left: auto;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ---- TEAM GRID ---- */
    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1rem;
    }

    /* ---- TEAM CARD ---- */
    .team-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      cursor: pointer;
      transition: all 0.15s;
      position: relative;
    }

    .team-card:hover {
      border-color: var(--border-active);
      background: var(--bg-card-hover);
    }

    .team-card.highlighted {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent), 0 4px 24px rgba(234,252,38,0.1);
    }

    .team-card-header {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 0.85rem;
    }

    .team-flag {
      font-size: 2rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .team-info { flex: 1; min-width: 0; }

    .group-badge {
      display: inline-block;
      background: rgba(234, 252, 38, 0.1);
      color: var(--accent);
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.15rem 0.5rem;
      border-radius: 2px;
      margin-bottom: 0.2rem;
    }

    .team-name {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.05rem;
      color: #fff;
      line-height: 1.2;
    }

    .venue-name {
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--text-primary);
      margin-top: 0.15rem;
    }

    .venue-neighborhood {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .venue-links {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 0.75rem 0;
    }

    .venue-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      border: 1px solid var(--border);
      padding: 0.25rem 0.6rem;
      border-radius: 3px;
      transition: all 0.12s;
      white-space: nowrap;
    }

    .venue-link:hover {
      background: rgba(234,252,38,0.08);
      border-color: var(--accent);
    }

    .venue-phone {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .card-note {
      font-size: 0.72rem;
      color: #f5a623;
      background: rgba(245, 166, 35, 0.08);
      border: 1px solid rgba(245, 166, 35, 0.2);
      border-radius: 4px;
      padding: 0.4rem 0.6rem;
      margin-bottom: 0.75rem;
    }

    /* ---- SCHEDULE ---- */
    .schedule-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.4rem;
    }

    .match-list {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .match-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      padding: 0.3rem 0.5rem;
      border-radius: 3px;
      background: rgba(255,255,255,0.03);
    }

    .match-date {
      font-weight: 700;
      color: var(--accent);
      min-width: 44px;
      font-size: 0.72rem;
    }

    .match-time {
      color: var(--text-muted);
      font-size: 0.7rem;
      min-width: 70px;
    }

    .match-vs {
      color: var(--text-muted);
      font-size: 0.65rem;
    }

    .match-opponent {
      color: var(--text-primary);
      font-weight: 600;
    }

    .map-btn {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(234,252,38,0.08);
      border: 1px solid var(--border);
      color: var(--accent);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.25rem 0.5rem;
      border-radius: 3px;
      cursor: pointer;
      transition: all 0.12s;
    }

    .map-btn:hover {
      background: rgba(234,252,38,0.15);
      border-color: var(--accent);
    }

    /* ---- EXCLUDED SECTION ---- */
    .excluded-section {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .excluded-title {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.1rem;
      color: #fff;
      margin-bottom: 0.75rem;
    }

    .excluded-intro {
      font-size: 0.9rem;
      color: var(--text-muted);
      max-width: 600px;
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }

    .excluded-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-bottom: 2rem;
    }

    .excluded-card {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.75rem 1rem;
      min-width: 200px;
    }

    .excluded-flag { font-size: 1.5rem; }

    .excluded-info { flex: 1; }

    .excluded-name {
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--text-primary);
    }

    .excluded-tag {
      font-size: 0.68rem;
      color: #cc6666;
      margin-top: 0.1rem;
    }

    /* ---- CTA ---- */
    .cta-box {
      background: linear-gradient(135deg, #0f1929, #162238);
      border: 1px solid var(--accent);
      border-radius: var(--radius);
      padding: 2rem;
      text-align: center;
      margin-top: 1rem;
    }

    .cta-box h3 {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
      color: #fff;
    }

    .cta-box p {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }

    .cta-links {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .cta-link {
      display: inline-block;
      background: var(--accent);
      color: #000;
      font-weight: 800;
      font-size: 0.8rem;
      padding: 0.6rem 1.4rem;
      border-radius: 4px;
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: opacity 0.12s;
    }

    .cta-link:hover { opacity: 0.85; }

    .cta-link.secondary {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
    }

    /* ---- STATS BAR ---- */
    .stats-bar {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
      padding: 1.25rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    .stat-item { text-align: center; flex: 1; min-width: 80px; }

    .stat-num {
      font-family: var(--font-heading, 'Plus Jakarta Sans', sans-serif);
      font-weight: 800;
      font-size: 1.8rem;
      color: var(--accent);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 0.2rem;
    }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 600px) {
      .team-grid { grid-template-columns: 1fr; }
      .wc-hero { padding: 2rem 1rem 1.5rem; }
      #wc-map { height: 320px; }
      .conf-nav { gap: 0.35rem; }
      .conf-btn { font-size: 0.65rem; padding: 0.4rem 0.7rem; }
    }
  </style>
</head>
<body>
  <Header />

  <main>
    <div class="wc-hero">
      <div class="wc-container">
        <div class="wc-badge">FIFA World Cup 2026 NYC Guide</div>
        <h1 class="wc-title">Where to Watch the <span>World Cup</span> in NYC, by Country</h1>
        <div class="wc-intro">
          <p>
            I put this together because I am currently unemployed and I want to watch as many
            2026 World Cup matches as possible. New York has so many diverse neighborhoods and bars
            that I thought it would be worth having one place where every supporter can find where
            their country gathers. There is no atmosphere quite like watching a match inside a room
            full of people rooting for the same country.
          </p>
          <p>
            Every venue on this page has been verified through at least two independent sources as
            currently open and active as a supporter destination for that country. Nine teams did not
            have two-source verified supporter pubs in NYC and are listed at the bottom.
          </p>
        </div>
        <div class="wc-meta">All kickoff times Eastern Time (ET). Group stage runs June 11 to June 27, 2026.</div>

        <div class="stats-bar">
          <div class="stat-item">
            <div class="stat-num">39</div>
            <div class="stat-label">Verified Venues</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">48</div>
            <div class="stat-label">Teams</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">5</div>
            <div class="stat-label">Boroughs</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">104</div>
            <div class="stat-label">Total Matches</div>
          </div>
        </div>
      </div>
    </div>

    <div class="wc-container">
      <!-- MAP SECTION -->
      <div class="map-section">
        <div class="section-label">Interactive Map</div>
        <div>Click any marker to jump to that team. Click a team card to pin it on the map.</div>
        <div id="wc-map"></div>
      </div>

      <!-- CONFEDERATION NAV -->
      <div class="conf-nav" id="conf-nav">
        <button class="conf-btn active" data-conf="all">All Teams</button>
        {confederationOrder.map(conf => (
          <button class="conf-btn" data-conf={conf}>{conf}</button>
        ))}
      </div>

      <!-- TEAM SECTIONS BY CONFEDERATION -->
      {confederationOrder.map(conf => {
        const confTeams = teams.filter(t => t.confederation === conf);
        if (confTeams.length === 0) return null;
        const color = confederationColors[conf];
        return (
          <div class="confederation-section" data-conf-section={conf} id={`conf-${conf}`}>
            <div class="conf-header">
              <div class="conf-dot" style={`background: ${color}`}></div>
              <div class="conf-name">{conf}</div>
              <div class="conf-count">{confTeams.length} teams verified</div>
            </div>
            <div class="team-grid">
              {confTeams.map(team => (
                <div
                  class="team-card"
                  id={`card-${team.id}`}
                  data-id={team.id}
                  data-lat={team.lat}
                  data-lng={team.lng}
                >
                  <button class="map-btn" data-id={team.id}>Pin on map</button>
                  <div class="team-card-header">
                    <div class="team-flag">{team.flag}</div>
                    <div class="team-info">
                      <div class="group-badge">Group {team.group}</div>
                      <div class="team-name">{team.team}</div>
                      <div class="venue-name">{team.venue}</div>
                      <div class="venue-neighborhood">{team.neighborhood}</div>
                    </div>
                  </div>

                  {team.note && <div class="card-note">{team.note}</div>}

                  <div class="venue-phone">{team.address} &bull; {team.phone}</div>

                  <div class="venue-links">
                    <a href={team.mapsLink} target="_blank" rel="noopener" class="venue-link">
                      View on Google Maps
                    </a>
                    {team.website && (
                      <a href={team.website} target="_blank" rel="noopener" class="venue-link">
                        Website
                      </a>
                    )}
                  </div>

                  <div class="schedule-label">Group Stage Matches</div>
                  <div class="match-list">
                    {team.matches.map(m => (
                      <div class="match-row">
                        <span class="match-date">{m.date}</span>
                        <span class="match-time">{m.time}</span>
                        <span class="match-vs">vs</span>
                        <span class="match-opponent">{m.opponent}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}

      <!-- EXCLUDED TEAMS -->
      <div class="excluded-section">
        <div class="excluded-title">No Verified Supporter Pub Found</div>
        <p class="excluded-intro">
          These nine teams did not have a New York City bar or restaurant that could be confirmed
          through two independent sources as a dedicated supporter destination for that country.
          Know of one? Please get in touch.
        </p>
        <div class="excluded-grid">
          {excludedTeams.map(t => (
            <div class="excluded-card">
              <div class="excluded-flag">{t.flag}</div>
              <div class="excluded-info">
                <div class="excluded-name">{t.team}</div>
                <div class="excluded-tag">Group {t.group} &bull; No verified pub found</div>
              </div>
            </div>
          ))}
        </div>

        <div class="cta-box">
          <h3>Know a Venue for One of These Countries?</h3>
          <p>
            If you know of a bar or restaurant in NYC where supporters of one of these countries
            gather to watch their national team, with the match on TV and audio, please reach out.
            I will verify it and add it to this guide.
          </p>
          <div class="cta-links">
            <a href="mailto:maguirebaseball@gmail.com?subject=World+Cup+NYC+Venue+Tip" class="cta-link">
              Email me a tip
            </a>
            <a href="/about" class="cta-link secondary">Contact page</a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WPeE=" crossorigin=""></script>
  <script define:vars={{ teams }}>
    // Initialize Leaflet map
    const map = L.map('wc-map', {
      center: [40.73, -73.94],
      zoom: 11,
      scrollWheelZoom: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19
    }).addTo(map);

    const confColors = {
      UEFA: '#4477ff',
      CONMEBOL: '#ffcc00',
      CONCACAF: '#ff4444',
      CAF: '#ff8800',
      AFC: '#22cc88',
      OFC: '#00aacc'
    };

    const markers = {};

    function makeIcon(conf) {
      const color = confColors[conf] || '#eafc26';
      return L.divIcon({
        className: '',
        html: `<div style="
          width: 28px; height: 28px;
          background: ${color};
          border: 2px solid #fff;
          border-radius: 50% 50% 50% 0;
          transform: rotate(-45deg);
          box-shadow: 0 2px 8px rgba(0,0,0,0.5);
        "></div>`,
        iconSize: [28, 28],
        iconAnchor: [14, 28],
        popupAnchor: [0, -30]
      });
    }

    teams.forEach(team => {
      const marker = L.marker([team.lat, team.lng], { icon: makeIcon(team.confederation) })
        .addTo(map)
        .bindPopup(`
          <div style="font-family: sans-serif; min-width: 160px;">
            <div style="font-size: 1.4rem; margin-bottom: 4px;">${team.flag}</div>
            <strong style="font-size: 0.9rem;">${team.team}</strong><br>
            <span style="font-size: 0.78rem; color: #666;">${team.venue}</span><br>
            <span style="font-size: 0.73rem; color: #999;">${team.neighborhood}</span>
          </div>
        `);

      marker.on('click', () => {
        const card = document.getElementById('card-' + team.id);
        if (card) {
          card.scrollIntoView({ behavior: 'smooth', block: 'center' });
          document.querySelectorAll('.team-card').forEach(c => c.classList.remove('highlighted'));
          card.classList.add('highlighted');
          setTimeout(() => card.classList.remove('highlighted'), 3000);
        }
      });

      markers[team.id] = marker;
    });

    // Pin on map buttons
    document.querySelectorAll('.map-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const marker = markers[id];
        if (marker) {
          map.setView(marker.getLatLng(), 14, { animate: true });
          marker.openPopup();
          document.getElementById('wc-map').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Confederation filter buttons
    const confNav = document.getElementById('conf-nav');
    confNav.addEventListener('click', e => {
      const btn = e.target.closest('.conf-btn');
      if (!btn) return;
      document.querySelectorAll('.conf-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const conf = btn.dataset.conf;
      document.querySelectorAll('[data-conf-section]').forEach(section => {
        section.style.display = (conf === 'all' || section.dataset.confSection === conf) ? '' : 'none';
      });
    });
  </script>
</body>
</html>
