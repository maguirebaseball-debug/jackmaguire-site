---
import BaseHead from '../../components/BaseHead.astro';

const title = 'Thanks — Jack Maguire';
const description = 'Message received. Jack Maguire will follow up directly.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<meta name="robots" content="noindex, nofollow" />

		<!--
			PLACEHOLDER: LinkedIn Insight Tag + Conversion tracking.
			Replace YOUR_PARTNER_ID below with the Partner ID from
			LinkedIn Campaign Manager > Account Assets > Insight Tag.
			Find the Conversion ID for this specific goal (e.g. "CMO landing page lead")
			under Campaign Manager > Account Assets > Conversion Tracking, then
			uncomment the conversion snippet beneath the base tag.
		-->
		<script type="text/javascript">
		/*
		_linkedin_partner_id = "YOUR_PARTNER_ID";
		window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
		window._linkedin_data_partner_ids.push(_linkedin_partner_id);
		(function(l) {
		if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
		window.lintrk.q=[]}
		var s = document.getElementsByTagName("script")[0];
		var b = document.createElement("script");
		b.type = "text/javascript";b.async = true;
		b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
		s.parentNode.insertBefore(b, s);})(window.lintrk);
		*/
		</script>
		<!--
		<noscript>
		<img height="1" width="1" style="display:none;" alt="" src="https://px.ads.linkedin.com/collect/?pid=YOUR_PARTNER_ID&conversionId=YOUR_CONVERSION_ID&fmt=gif" />
		</noscript>
		-->
	</head>
	<body>
		<main>
			<div class="wrap">
				<p class="eyebrow">Message received</p>
				<h1>Thanks, that's in my inbox.</h1>
				<p class="body-text">
					I read every message myself. If it's a fit, expect a reply within a day, usually
					sooner.
				</p>
				<p class="body-text">
					In the meantime, you can see the background behind the numbers on the
					<a href="/about/">about page</a>, or head back to <a href="/cmo/">the overview</a>.
				</p>
			</div>
		</main>
	</body>
</html>

<style>
	:global(body) {
		background: var(--paper);
	}
	main {
		max-width: none;
		padding: 0;
		display: flex;
		min-height: 70vh;
		align-items: center;
	}
	.wrap {
		max-width: 620px;
		margin: 0 auto;
		padding: 3em 1.25em;
		text-align: left;
	}
	.eyebrow {
		font-family: var(--font-ui), sans-serif;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent-dark);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin: 0 0 0.75em;
	}
	h1 {
		font-family: var(--font-heading), sans-serif;
		font-size: clamp(1.5em, 5vw, 2.2em);
		margin: 0 0 0.75em;
		color: rgb(var(--black));
	}
	.body-text {
		font-size: 1.05em;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
		margin: 0 0 1em;
	}
</style>
