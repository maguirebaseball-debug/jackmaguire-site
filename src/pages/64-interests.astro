---
import Header from '../components/Header.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>The Fulfillment 64 | jackmaguire.org</title>
  <meta name="description" content="Sixty-four interests, one bracket: a simulated tournament of what is most fulfilling, scored from my own documented preferences." />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body style="margin:0;padding:0;">
  <Header />
  <div class="f64-page">
<style is:global>
:root{
  --paper:#F1F2F0; --card:#FFFFFF; --ink:#23252D; --muted:#6D717E; --line:#DBDED9;
  --accent:#C42A60; --accent-soft:#C42A6014; --gold:#A8811C; --gold-soft:#A8811C1A;
  --r0:#5567D8; --r1:#3F8F5E; --r2:#BE6A2C; --r3:#C42A60;
  --shadow:0 1px 3px rgba(20,22,30,.08);
}
@media (prefers-color-scheme: dark){
  :root{
    --paper:#15171D; --card:#1E212A; --ink:#EBECEF; --muted:#979DAB; --line:#2C303B;
    --accent:#F0568B; --accent-soft:#F0568B1F; --gold:#D8B14A; --gold-soft:#D8B14A21;
    --r0:#7C8CEC; --r1:#5FB584; --r2:#DE8F4E; --r3:#F0568B;
    --shadow:0 1px 3px rgba(0,0,0,.4);
  }
}
:root[data-theme="dark"]{
  --paper:#15171D; --card:#1E212A; --ink:#EBECEF; --muted:#979DAB; --line:#2C303B;
  --accent:#F0568B; --accent-soft:#F0568B1F; --gold:#D8B14A; --gold-soft:#D8B14A21;
  --r0:#7C8CEC; --r1:#5FB584; --r2:#DE8F4E; --r3:#F0568B;
  --shadow:0 1px 3px rgba(0,0,0,.4);
}
:root[data-theme="light"]{
  --paper:#F1F2F0; --card:#FFFFFF; --ink:#23252D; --muted:#6D717E; --line:#DBDED9;
  --accent:#C42A60; --accent-soft:#C42A6014; --gold:#A8811C; --gold-soft:#A8811C1A;
  --r0:#5567D8; --r1:#3F8F5E; --r2:#BE6A2C; --r3:#C42A60;
  --shadow:0 1px 3px rgba(20,22,30,.08);
}
*{box-sizing:border-box}
.f64-page{background:var(--paper);color:var(--ink);margin:0;min-height:100vh;
  font-family:'Avenir Next',Seravek,'Segoe UI',system-ui,sans-serif;
  font-size:15px;line-height:1.5;}
.disp{font-family:'Avenir Next Condensed','Arial Narrow','Helvetica Neue',sans-serif;
  text-transform:uppercase;letter-spacing:.02em;}
.mono{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-variant-numeric:tabular-nums;}

.f64-hero{max-width:1060px;margin:0 auto;padding:44px 24px 8px;}
.eyebrow{font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin:0 0 10px;}
.f64-page h1{font-family:'Avenir Next Condensed','Arial Narrow',sans-serif;text-transform:uppercase;
  font-weight:700;font-size:clamp(44px,8vw,84px);line-height:.95;margin:0 0 14px;letter-spacing:.01em;text-wrap:balance;}
.f64-page h1 .n64{color:var(--accent);}
.sub{max-width:62ch;color:var(--muted);margin:0 0 22px;}
.sub strong{color:var(--ink);font-weight:600;}

.champ-banner{display:flex;align-items:center;gap:16px;flex-wrap:wrap;
  border:1px solid var(--gold);background:var(--gold-soft);border-radius:6px;
  padding:14px 18px;margin-bottom:26px;}
.champ-banner .lab{font-size:11px;letter-spacing:.16em;color:var(--gold);font-weight:600;}
.champ-banner .who{font-weight:700;font-size:26px;line-height:1.1;}
.champ-banner .score{color:var(--muted);font-size:13px;}

details.rules{max-width:1060px;margin:0 auto 30px;padding:0 24px;}
details.rules>summary{cursor:pointer;font-weight:600;font-size:14px;letter-spacing:.08em;
  text-transform:uppercase;color:var(--accent);list-style:none;display:inline-flex;gap:8px;align-items:center;}
details.rules>summary::before{content:"+";font-weight:700;}
details.rules[open]>summary::before{content:"-";}
details.rules>summary:focus-visible{outline:2px solid var(--accent);outline-offset:3px;}
.rules-body{border:1px solid var(--line);background:var(--card);border-radius:8px;
  padding:22px 24px;margin-top:14px;box-shadow:var(--shadow);}
.rules-body h3{margin:18px 0 6px;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.rules-body h3:first-child{margin-top:0;}
.rules-body p{max-width:70ch;margin:6px 0;}
.rules-body ul{max-width:70ch;margin:6px 0;padding-left:20px;}
.dimtable-wrap{overflow-x:auto;}
table.dimtable{border-collapse:collapse;width:100%;font-size:13.5px;min-width:640px;}
table.dimtable th{text-align:left;font-size:11px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--muted);padding:6px 12px 6px 0;border-bottom:1px solid var(--line);font-weight:600;}
table.dimtable td{padding:8px 12px 8px 0;border-bottom:1px solid var(--line);vertical-align:top;}
.wchip{display:inline-block;min-width:26px;text-align:center;border-radius:4px;padding:1px 6px;
  font-weight:700;font-size:12px;}
.wchip.lb{background:var(--accent-soft);color:var(--accent);}
.wchip.en{background:var(--gold-soft);color:var(--gold);}
.kind{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);white-space:nowrap;}

.scrollhint{max-width:1060px;margin:0 auto;padding:0 24px 8px;color:var(--muted);
  font-size:12px;letter-spacing:.1em;text-transform:uppercase;}
.bracket-wrap{overflow-x:auto;padding:6px 24px 30px;}
.bracket{display:flex;gap:14px;min-width:2150px;margin:0 auto;width:max-content;}
.col{display:flex;flex-direction:column;width:176px;flex:none;}
.col .rlabel{text-align:center;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--muted);padding:4px 0 10px;font-weight:600;}
.stack{flex:1;display:flex;flex-direction:column;justify-content:space-around;gap:6px;}
.halfcol{flex:1;display:flex;flex-direction:column;}
.regcap{font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;font-weight:700;
  padding:2px 0 6px;text-align:center;}
.match{background:var(--card);border:1px solid var(--line);border-radius:6px;overflow:hidden;
  cursor:pointer;box-shadow:var(--shadow);padding:0;width:100%;text-align:left;
  font:inherit;color:inherit;display:block;border-top:3px solid var(--line);}
.match:hover{border-color:var(--accent);}
.match:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}
.match .row{display:flex;align-items:baseline;gap:6px;padding:5px 9px;}
.match .row+.row{border-top:1px dashed var(--line);}
.match .seed{font-size:10px;color:var(--muted);min-width:14px;}
.match .nm{flex:1;font-family:'Avenir Next Condensed','Arial Narrow',sans-serif;
  font-size:14px;line-height:1.15;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500;}
.match .pt{font-size:11.5px;color:var(--muted);}
.match .row.w .nm{font-weight:700;}
.match .row.w .pt{color:var(--accent);font-weight:700;}
.match .row.l{opacity:.52;}
.centercol{display:flex;flex-direction:column;justify-content:center;gap:16px;width:216px;flex:none;}
.finalcard{border-top-color:var(--gold);}
.finalcard .row.w .pt{color:var(--gold);}
.trophy{border:1.5px solid var(--gold);background:var(--gold-soft);border-radius:8px;
  padding:16px 14px;text-align:center;}
.trophy .lab{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:700;}
.trophy .who{font-family:'Avenir Next Condensed','Arial Narrow',sans-serif;text-transform:uppercase;
  font-weight:700;font-size:24px;line-height:1.05;margin:6px 0 4px;text-wrap:balance;}
.trophy .q{font-size:12px;color:var(--muted);font-style:italic;}
.centerlab{text-align:center;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--muted);font-weight:600;}

dialog.f64-dlg{border:none;border-radius:10px;padding:0;max-width:640px;width:calc(100vw - 32px);
  background:var(--card);color:var(--ink);box-shadow:0 18px 60px rgba(0,0,0,.35);}
dialog.f64-dlg::backdrop{background:rgba(10,12,18,.55);}
.dlg-head{padding:18px 22px 14px;border-bottom:1px solid var(--line);}
.dlg-round{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600;}
.dlg-vs{display:flex;align-items:center;gap:12px;margin-top:8px;flex-wrap:wrap;}
.dlg-side{flex:1;min-width:180px;}
.dlg-side .nm{font-family:'Avenir Next Condensed','Arial Narrow',sans-serif;text-transform:uppercase;
  font-weight:700;font-size:21px;line-height:1.05;}
.dlg-side .meta{font-size:12px;color:var(--muted);margin-top:2px;}
.dlg-side.win .nm{color:var(--accent);}
.dlg-score{font-size:26px;font-weight:700;white-space:nowrap;}
.dlg-body{padding:16px 22px 22px;max-height:62vh;overflow-y:auto;}
.dlg-body h4{margin:14px 0 6px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.dlg-body h4:first-child{margin-top:0;}
.rtable-wrap{overflow-x:auto;}
table.rtable{border-collapse:collapse;width:100%;font-size:13px;min-width:420px;}
table.rtable td,table.rtable th{padding:5px 8px 5px 0;border-bottom:1px solid var(--line);text-align:left;}
table.rtable th{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:600;}
.dots{letter-spacing:2px;font-size:11px;}
.takes{font-weight:700;}
.takes.a{color:var(--accent);}
.takes.b{color:var(--gold);}
.verdict{background:var(--accent-soft);border-radius:6px;padding:12px 14px;font-size:13.5px;margin-top:6px;}
.notes{display:grid;grid-template-columns:1fr;gap:10px;margin-top:6px;}
.note{border:1px solid var(--line);border-radius:6px;padding:10px 12px;font-size:12.5px;color:var(--muted);}
.note b{color:var(--ink);display:block;margin-bottom:2px;}
.note .fsline{font-size:11.5px;margin-top:6px;}
.dlg-close{position:absolute;top:10px;right:12px;background:none;border:none;color:var(--muted);
  font-size:22px;cursor:pointer;line-height:1;padding:6px;}
.dlg-close:hover{color:var(--ink);}
.dlg-close:focus-visible{outline:2px solid var(--accent);}
.f64-foot{max-width:1060px;margin:0 auto;padding:10px 24px 60px;color:var(--muted);font-size:12.5px;}
.f64-foot p{max-width:78ch;margin:4px 0;}
@media (prefers-reduced-motion: no-preference){
  .match{transition:border-color .15s ease, transform .15s ease;}
  .match:hover{transform:translateY(-1px);}
}
</style>

<div class="f64-hero">
  <p class="eyebrow">Simulated from the Notion preference corpus &middot; 64 interests &middot; July 2026</p>
  <h1>The Fulfillment <span class="n64">64</span></h1>
  <p class="sub">Sixty-four of Jack Maguire's interests, seeded into four regions and played head-to-head on one question: <strong>which is more fulfilling to me?</strong> Every match is decided by the need stack documented in his own Notion: five load-bearing needs, four major enrichers, and penalties for the "false versions" his pages explicitly warn about. Click any match for the round-by-round result.</p>
  <div class="champ-banner">
    <span class="lab">National Champion</span>
    <span class="who disp" id="champ-name"></span>
    <span class="score" id="champ-score"></span>
  </div>
</div>

<details class="rules">
  <summary>Scoring &amp; rules: built from the Notion deep dive</summary>
  <div class="rules-body">
    <h3>Where the rules come from</h3>
    <p>The scoring model is lifted directly from the <em>My Lifestyle Preferences</em> first-principles research page, which distilled the whole preference corpus (Psych profile, Values, activity / travel / music / food pages, Gratitude List) into a <strong>need stack</strong>: five load-bearing needs whose absence breaks the life, and four major enrichers that make it rich.</p>
    <h3>The nine dimensions</h3>
    <div class="dimtable-wrap"><table class="dimtable" id="dimtable">
      <tr><th>Dimension</th><th>Weight</th><th>Tier</th><th>What it means (paraphrased from Notion)</th></tr>
    </table></div>
    <h3>How an interest is scored</h3>
    <ul>
      <li>Each interest gets <strong>0-3</strong> on every dimension, graded against the evidence in the preference pages.</li>
      <li><strong>Revealed-preference bonus (+0-8):</strong> behavioral proof beats self-report. Finishing the Appalachian Trail, all-time Spotify data, the 300-film ranking list, PPL 3&times;/week, and the Gratitude List all count as receipts.</li>
      <li><strong>False-version penalty (&minus;0-8):</strong> the lifestyle research names distorted versions of each pattern : optimization as avoidance, restaurant loops as time-filler, AI-query loops, digital substitutes for contact. Interests whose everyday enactment matches a named false version pay for it. The Values page's first principle, <em>"the best parts of life are not optimized into existence,"</em> is why the productivity cluster gets hammered.</li>
      <li><strong>Fulfillment Score</strong> =  (dimension &times; weight) + bonus &minus; penalty. Seeding is by Fulfillment Score within each region.</li>
    </ul>
    <h3>How a match is decided</h3>
    <ul>
      <li>The nine dimensions are played as nine rounds. Winning a round earns its weight in points (35 total on the table); a tied round splits its weight.</li>
      <li>Most points wins. Ties break on revealed-preference bonus, then lower penalty, then seed. Bonuses and penalties otherwise affect seeding only : on the court, the need stack decides.</li>
      <li>This is why the bracket rewards interests that touch <em>many</em> needs over interests that max out one: it is a direct implementation of Values #5, <em>"meaning is not something I orbit; it accumulates quietly from many sources."</em></li>
    </ul>
    <h3>Sources</h3>
    <p> My Interests &middot;  My Preferences DB &middot; My Lifestyle Preferences (need stack, cross-domain patterns, false positives) &middot;  Personal Values &middot;  Activity,  Travel,  Music,  Food preferences &middot;  Gratitude List.</p>
  </div>
</details>

<p class="scrollhint">Bracket scrolls sideways &rarr;</p>
<div class="bracket-wrap"><div class="bracket" id="bracket"></div></div>

<dialog id="dlg" class="f64-dlg">
  <button class="dlg-close" id="dlg-close" aria-label="Close">&times;</button>
  <div class="dlg-head">
    <div class="dlg-round" id="dlg-round"></div>
    <div class="dlg-vs">
      <div class="dlg-side" id="dlg-a"></div>
      <div class="dlg-score mono" id="dlg-score"></div>
      <div class="dlg-side" id="dlg-b" style="text-align:right"></div>
    </div>
  </div>
  <div class="dlg-body">
    <h4>The nine rounds</h4>
    <div class="rtable-wrap"><table class="rtable" id="dlg-rounds"></table></div>
    <h4>Verdict</h4>
    <div class="verdict" id="dlg-verdict"></div>
    <h4>The case files</h4>
    <div class="notes" id="dlg-notes"></div>
  </div>
</dialog>

<div class="f64-foot">
  <p>A tournament, not a to-do list. The final says it plainly: the trail proved he can do hard things alone; the table is where a life that is already full gets shared. Both survive. One wins.</p>
  <p>Method note: dimension grades are editorial reads of the Notion evidence, so treat one-point margins as coin flips and the Final Four as signal.</p>
</div>

<script is:inline>
const DATA = {"dims": [{"key": "AGY", "label": "Agency & self-authorship", "w": 5, "kind": "load-bearing", "desc": "Real say over time, place, routes, projects. Failure mode: feeling trapped in someone else's plan."}, {"key": "KNW", "label": "Being known", "w": 5, "kind": "load-bearing", "desc": "Recognition in detail: interests, humor, fear, softness, contradictions. Not just being liked."}, {"key": "SOC", "label": "Social aliveness", "w": 5, "kind": "load-bearing", "desc": "Frequent live contact, banter, hosting, group energy. Failure mode: digital substitutes."}, {"key": "EMB", "label": "Embodied competence", "w": 5, "kind": "load-bearing", "desc": "Strength, endurance, movement, physical challenge as contact with life."}, {"key": "MNG", "label": "Meaning accumulation", "w": 4, "kind": "load-bearing", "desc": "Plural meaning from relationships, beauty, ritual, learning. Never one totalizing center."}, {"key": "SEN", "label": "High-fidelity sensory life", "w": 3, "kind": "enricher", "desc": "Texture, aroma, beat, atmosphere, designed spaces. High-resolution contact with the real world."}, {"key": "CON", "label": "Conceptual compression", "w": 3, "kind": "enricher", "desc": "Ideas that compress complexity into usable models. Explanatory power, not information volume."}, {"key": "NOV", "label": "Structured novelty", "w": 3, "kind": "enricher", "desc": "New inputs held inside a coherent rhythm: routes, categories, social containers."}, {"key": "FRI", "label": "Friction with warmth", "w": 2, "kind": "enricher", "desc": "Debate, teasing, truth, charged contact that stays connected."}], "regions": ["The Mind", "The Body & The World", "The Table & The Senses", "The People & The Work"], "interests": {"Psychology": {"name": "Psychology", "region": 0, "dims": [2, 2, 2, 0, 3, 0, 3, 2, 2], "bonus": 5, "penalty": 0, "note": "The engine behind his unusual self-knowledge. Psych profile and values page are both products of this interest; it feeds being-known directly.", "fs": 66,