t"}, {"dim": "CON", "w": 3, "a": 2, "b": 1, "win": "a"}, {"dim": "NOV", "w": 3, "a": 2, "b": 2, "win": "t"}, {"dim": "FRI", "w": 2, "a": 0, "b": 2, "win": "b"}], "tiebreak": null, "round": "Final Four", "region": null}], [{"a": "Long-distance trekking", "b": "Hosting dinner parties", "aPts": 16.0, "bPts": 19.0, "winner": "Hosting dinner parties", "rounds": [{"dim": "AGY", "w": 5, "a": 3, "b": 3, "win": "t"}, {"dim": "KNW", "w": 5, "a": 1, "b": 3, "win": "b"}, {"dim": "SOC", "w": 5, "a": 2, "b": 3, "win": "b"}, {"dim": "EMB", "w": 5, "a": 3, "b": 1, "win": "a"}, {"dim": "MNG", "w": 4, "a": 3, "b": 2, "win": "a"}, {"dim": "SEN", "w": 3, "a": 2, "b": 3, "win": "b"}, {"dim": "CON", "w": 3, "a": 1, "b": 1, "win": "t"}, {"dim": "NOV", "w": 3, "a": 3, "b": 2, "win": "a"}, {"dim": "FRI", "w": 2, "a": 0, "b": 2, "win": "b"}], "tiebreak": null, "round": "Championship", "region": null}]], "champion": "Hosting dinner parties"};
const INT = DATA.interests, DIMS = DATA.dims, REG = DATA.regions;
const RCOL = ['var(--r0)','var(--r1)','var(--r2)','var(--r3)'];
const fmt = n => (n % 1 === 0 ? String(n) : n.toFixed(1));

// header
const finalM = DATA.rounds[5][0];
document.getElementById('champ-name').textContent = DATA.champion;
const runnerUp = finalM.winner === finalM.a ? finalM.b : finalM.a;
const wPts = finalM.winner === finalM.a ? finalM.aPts : finalM.bPts;
const lPts = finalM.winner === finalM.a ? finalM.bPts : finalM.aPts;
document.getElementById('champ-score').textContent =
  `def. ${runnerUp} ${fmt(wPts)}-${fmt(lPts)} in the final`;

// rules dim table
const dt = document.getElementById('dimtable');
DIMS.forEach(d => {
  const tr = document.createElement('tr');
  tr.innerHTML = `<td><strong>${d.label}</strong></td>
    <td><span class="wchip ${d.kind === 'load-bearing' ? 'lb' : 'en'}">&times;${d.w}</span></td>
    <td class="kind">${d.kind}</td><td>${d.desc}</td>`;
  dt.appendChild(tr);
});

// ---- bracket ----
function matchCard(m, big) {
  const btn = document.createElement('button');
  btn.className = 'match' + (big ? ' finalcard' : '');
  if (m.region !== null && m.region !== undefined) btn.style.borderTopColor = RCOL[m.region];
  const row = (name, pts) => {
    const it = INT[name], won = m.winner === name;
    return `<div class="row ${won ? 'w' : 'l'}">
      <span class="seed mono">${it.seed}</span>
      <span class="nm" title="${name}">${name}</span>
      <span class="pt mono">${fmt(pts)}</span></div>`;
  };
  btn.innerHTML = row(m.a, m.aPts) + row(m.b, m.bPts);
  btn.addEventListener('click', () => openMatch(m));
  return btn;
}
function column(label, groups, big) {
  // groups: array of {region|null, matches[]} stacked vertically
  const col = document.createElement('div');
  col.className = 'col';
  col.innerHTML = `<div class="rlabel">${label}</div>`;
  groups.forEach(g => {
    const half = document.createElement('div');
    half.className = 'halfcol';
    if (g.caption !== undefined) {
      const cap = document.createElement('div');
      cap.className = 'regcap';
      cap.textContent = g.caption;
      cap.style.color = RCOL[g.region];
      half.appendChild(cap);
    }
    const st = document.createElement('div');
    st.className = 'stack';
    g.matches.forEach(m => st.appendChild(matchCard(m, big)));
    half.appendChild(st);
    col.appendChild(half);
  });
  return col;
}
const R = DATA.rounds; // 0:R64(32) 1:R32(16) 2:S16(8) 3:E8(4) 4:F4(2) 5:final(1)
const slice = (rd, a, b) => R[rd].slice(a, b);
const names = ['Round of 64', 'Round of 32', 'Sweet 16', 'Regional Final'];
const br = document.getElementById('bracket');
// left: regions 0,1 : right: regions 2,3
const leftRegs = [0, 1], rightRegs = [2, 3];
const counts = [8, 4, 2, 1]; // matches per region per round
function sideCols(regs, mirror) {
  const cols = [];
  for (let rd = 0; rd < 4; rd++) {
    const groups = regs.map(rg => ({
      region: rg,
      caption: rd === 0 ? REG[rg] : undefined,
      matches: slice(rd, rg * counts[rd], (rg + 1) * counts[rd])
    }));
    cols.push(column(names[rd], groups));
  }
  const semiIdx = regs === leftRegs ? 0 : 1;
  cols.push(column('Final Four', [{region: null, matches: [R[4][semiIdx]]}]));
  if (mirror) cols.reverse();
  return cols;
}
sideCols(leftRegs, false).forEach(c => br.appendChild(c));
// center
const center = document.createElement('div');
center.className = 'centercol';
center.innerHTML = '<div class="centerlab">National Championship</div>';
center.appendChild(matchCard(R[5][0], true));
const champIt = INT[DATA.champion];
const tr = document.createElement('div');
tr.className = 'trophy';
tr.innerHTML = `<div class="lab">Champion</div>
  <div class="who">${DATA.champion}</div>
  <div class="q">"Connection is nourishing now, today, in this season."</div>`;
center.appendChild(tr);
br.appendChild(center);
sideCols(rightRegs, true).forEach(c => br.appendChild(c));

// ---- match dialog ----
const dlg = document.getElementById('dlg');
function sideHTML(name) {
  const it = INT[name];
  return `<div class="nm">${name}</div>
    <div class="meta">#${it.seed} seed &middot; ${REG[it.region]} &middot; Fulfillment Score ${it.fs}</div>`;
}
function dots(n) { return '\u25CF'.repeat(n) + '\u25CB'.repeat(3 - n); }
function verdict(m) {
  const winA = m.winner === m.a;
  const w = m.winner, l = winA ? m.b : m.a;
  const won = m.rounds.filter(r => r.win === (winA ? 'a' : 'b'))
    .sort((x, y) => y.w - x.w);
  const lost = m.rounds.filter(r => r.win === (winA ? 'b' : 'a'))
    .sort((x, y) => y.w - x.w);
  const lbl = k => DIMS.find(d => d.key === k).label;
  let s = `<strong>${w}</strong> takes ${won.length} of the nine rounds`;
  if (won.length) s += `, led by ${won.slice(0, 2).map(r => `<em>${lbl(r.dim)}</em>`).join(' and ')}`;
  s += '. ';
  if (lost.length) {
    s += `${l} answers on ${lost.slice(0, 2).map(r => `<em>${lbl(r.dim)}</em>`).join(' and ')}, but it isn't enough. `;
  } else {
    s += `${l} never wins a round outright. `;
  }
  s += `Final: <span class="mono">${fmt(winA ? m.aPts : m.bPts)}-${fmt(winA ? m.bPts : m.aPts)}</span>`;
  if (m.tiebreak) s += `, decided on the ${m.tiebreak}`;
  s += '.';
  return s;
}
function openMatch(m) {
  document.getElementById('dlg-round').textContent =
    m.round + (m.region !== null && m.region !== undefined ? ' \u00B7 ' + REG[m.region] : '');
  const A = document.getElementById('dlg-a'), B = document.getElementById('dlg-b');
  A.innerHTML = sideHTML(m.a); B.innerHTML = sideHTML(m.b);
  A.className = 'dlg-side' + (m.winner === m.a ? ' win' : '');
  B.className = 'dlg-side' + (m.winner === m.b ? ' win' : '');
  document.getElementById('dlg-score').textContent = `${fmt(m.aPts)} - ${fmt(m.bPts)}`;
  const t = document.getElementById('dlg-rounds');
  t.innerHTML = `<tr><th>Round (weight)</th><th>${m.a}</th><th>${m.b}</th><th>Takes it</th></tr>` +
    m.rounds.map(r => {
      const d = DIMS.find(x => x.key === r.dim);
      const takes = r.win === 't' ? '<span style="color:var(--muted)">split</span>'
        : `<span class="takes ${r.win}">${r.win === 'a' ? m.a : m.b}</span>`;
      return `<tr><td>${d.label} <span class="wchip ${d.kind === 'load-bearing' ? 'lb' : 'en'}">&times;${d.w}</span></td>
        <td class="dots mono">${dots(r.a)}</td><td class="dots mono">${dots(r.b)}</td><td>${takes}</td></tr>`;
    }).join('');
  document.getElementById('dlg-verdict').innerHTML = verdict(m);
  const notes = document.getElementById('dlg-notes');
  notes.innerHTML = [m.a, m.b].map(n => {
    const it = INT[n];
    const base = it.fs - it.bonus + it.penalty;
    return `<div class="note"><b>${n}</b>${it.note}
      <div class="fsline mono">base ${base} &middot; revealed-preference +${it.bonus} &middot; false-version &minus;${it.penalty} = FS ${it.fs}</div></div>`;
  }).join('');
  dlg.showModal();
}
document.getElementById('dlg-close').addEventListener('click', () => dlg.close());
dlg.addEventListener('click', e => { if (e.target === dlg) dlg.close(); });
</script>

  </div>
