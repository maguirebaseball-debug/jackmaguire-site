---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const lastUpdated = 'May 28, 2026';
const recommendationHubs = [
	{ name: 'NYC Restaurants', url: '/recommendations/nyc-restaurants/' },
	{ name: 'NYC Underrated Places', url: '/recommendations/nyc-underrated/' },
	{ name: 'Chinatown Non-Spicy Intel', url: '/recommendations/curry-house-chinatown/' },
	{ name: 'NYC Pastrami Ranking', url: '/recommendations/nyc-pastrami/' },
	{ name: 'Books', url: '/recommendations/books/' },
	{ name: 'Apps', url: '/recommendations/apps/' },
	{ name: 'Films', url: '/recommendations/films/' },
	{ name: 'Tex-Mex and Suburban Mexican in NYC', url: '/recommendations/tex-mex-nyc/' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Best Recommendations from Jack Maguire: NYC, Books, Apps, and Films`} description="A hub for Jack Maguire's restaurant, book, app, and film recommendations." />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'ItemList',
			name: 'Recommendation hubs by Jack Maguire',
			itemListElement: recommendationHubs.map((item, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name: item.name,
				url: new URL(item.url, Astro.site).toString(),
			})),
		})} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Recommendations</h1>
			<p class="intro">Things I return to after actual use: places, books, tools, and films with enough signal to recommend directly.</p>
			<p class="updated">Last updated: {lastUpdated}</p>

				<section class="feature">
					<h2>NYC Restaurants</h2>
					<p>Practical dining picks across New York City, with firsthand notes and clear tradeoffs.</p>
					<a href="/recommendations/nyc-restaurants" class="section-link">View list →</a>
				</section>

				<section class="feature">
					<h2>NYC Underrated Places</h2>
					<p>A filtered directory of 2,100+ hidden gems — including restaurants, retail, parks, and museums — sourced from local discussions.</p>
					<a href="/recommendations/nyc-underrated" class="section-link">View directory →</a>
				</section>

				<section>
					<h2>Chinatown Non-Spicy Intel</h2>
					<p>A restrained field guide to mild Malaysian orders at Curry House on Pell Street.</p>
				<a href="/recommendations/curry-house-chinatown" class="section-link">View guide →</a>
			</section>

			<section>
				<h2>NYC Pastrami Ranking</h2>
				<p>Aggregate ranking of 30 food blog lists to find the consensus best pastrami in the city.</p>
				<a href="/recommendations/nyc-pastrami" class="section-link">View ranking →</a>
			</section>

			<section>
				<h2>Books</h2>
				<p>Books worth your time and attention.</p>
				<a href="/recommendations/books" class="section-link">View list →</a>
			</section>

			<section>
				<h2>Apps</h2>
				<p>Tools I consistently use and recommend.</p>
				<a href="/recommendations/apps" class="section-link">View list →</a>
			</section>

			<section>
				<h2>Films</h2>
				<p>Films I strongly recommend watching.</p>
				<a href="/recommendations/films" class="section-link">View list →</a>
			</section>

			<section>
				<h2>Tex-Mex and Suburban Mexican in NYC</h2>
				<p>Where to find the chips-salsa-margaritas-rice-and-beans vibe in New York.</p>
				<a href="/recommendations/tex-mex-nyc" class="section-link">View guide →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		color: rgb(var(--gray));
		margin-bottom: 2.5em;
	}
	.updated {
		color: rgb(var(--gray));
		font-size: 0.85em;
		margin-top: -1.25em;
		margin-bottom: 2.5em;
	}
	section {
		display: grid;
		grid-template-columns: 14rem 1fr auto;
		gap: 1rem;
		align-items: baseline;
		padding: 1.35em 0;
	}
	section h2 {
		font-size: 1.2em;
		margin: 0;
	}
	section p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95em;
	}
	.section-link {
		font-size: 0.9em;
		white-space: nowrap;
	}
	.feature {
		padding: 1.6em 1em;
		margin-left: -1em;
		margin-right: -1em;
		border-left: 3px solid rgba(85, 107, 47, 0.45);
		background: linear-gradient(90deg, rgba(245, 239, 227, 0.55), transparent 72%);
	}
	@media (max-width: 720px) {
		section {
			grid-template-columns: 1fr;
			gap: 0.35rem;
		}
		.feature {
			margin-left: 0;
			margin-right: 0;
		}
	}
</style>
