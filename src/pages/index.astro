---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getStandaloneBlogPosts } from '../lib/standaloneBlogPosts';

const markdownPosts = (await getCollection('blog')).map((post) => ({
	title: post.data.title,
	href: `/blog/${post.id}/`,
	pubDate: post.data.pubDate,
}));

const posts = [...getStandaloneBlogPosts(), ...markdownPosts]
	.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Jack Maguire</h1>
				<p>
					Paid social director in the East Village. I write field notes on performance marketing,
					NYC restaurants, long walks, books, travel logistics, and the useful edges of AI.
				</p>
				<div class="ledger" aria-label="Site coordinates">
					<span>East Village</span>
					<span>Paid social</span>
					<span>Food notes</span>
					<span>Travel routes</span>
				</div>
			</section>

			<section class="recent">
				<h2>Recent writing</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={post.href}>
									<span class="title">{post.title}</span>
									<span class="date">
										<FormattedDate date={post.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<p class="all-link"><a href="/blog">All writing →</a></p>
			</section>

			<section class="site-index" aria-label="Site index">
				<a href="/projects" class="index-row">
					<h3>Projects</h3>
					<p>Route plans, research tools, and small systems built to answer specific questions.</p>
				</a>
				<a href="/recommendations" class="index-row featured">
					<h3>Recommendations</h3>
					<p>Restaurants, books, apps, and films I can defend from actual use.</p>
				</a>
				<a href="/now" class="index-row">
					<h3>Now</h3>
					<p>Current work, reading, travel, and the questions taking up mental space.</p>
				</a>
				<a href="/about" class="index-row">
					<h3>About</h3>
					<p>Paid social background, McGill, long-distance hiking, books, and contact.</p>
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: 3.2em;
		position: relative;
	}
	.intro h1 {
		font-size: clamp(2.15em, 8vw, 3.4em);
		margin-bottom: 0.4em;
	}
	.intro p {
		color: rgb(var(--gray-dark));
		font-size: 1.1em;
		max-width: var(--width-prose);
	}
	.ledger {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 1.4rem;
		font-family: var(--font-ui), sans-serif;
		font-size: 0.72rem;
		color: var(--accent-dark);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.ledger span {
		border-top: 1px solid rgba(85, 107, 47, 0.3);
		padding: 0.35rem 0.9rem 0 0;
	}
	.recent h2 {
		font-size: 1.1em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		margin-bottom: 1em;
	}
	.recent ul {
		list-style: none;
		padding: 0;
		margin: 0 0 1em 0;
	}
	.recent ul li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.recent ul li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.75em 0;
		text-decoration: none;
		color: rgb(var(--black));
	}
	@media (max-width: 600px) {
		.recent ul li a {
			flex-direction: column;
			gap: 0.25em;
		}
	}
	.recent ul li a:hover .title {
		color: var(--accent);
	}
	.recent ul li a .date {
		color: rgb(var(--gray));
		font-size: 0.85em;
		white-space: nowrap;
	}
	.all-link {
		text-align: right;
		margin-top: 0.5em;
	}
	.site-index {
		margin-top: 3em;
	}
	.index-row {
		display: grid;
		grid-template-columns: 11rem 1fr;
		gap: 1.25rem;
		border-top: 1px solid rgba(var(--gray-light), 0.9);
		padding: 1.15em 0;
		text-decoration: none;
		color: inherit;
		transition: color 0.2s ease, padding-left 0.2s ease;
	}
	.index-row:last-child {
		border-bottom: 1px solid rgba(var(--gray-light), 0.9);
	}
	.index-row:hover {
		padding-left: 0.3rem;
	}
	.index-row h3 {
		margin: 0;
		font-size: 1em;
		color: rgb(var(--black));
	}
	.index-row p {
		margin: 0;
		font-size: 0.9em;
		color: rgb(var(--gray));
	}
	.index-row.featured {
		border-left: 3px solid rgba(85, 107, 47, 0.45);
		padding-left: 0.85rem;
		background: linear-gradient(90deg, rgba(245, 239, 227, 0.52), transparent 72%);
	}
	@media (max-width: 600px) {
		.index-row {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
<!-- cache-bust for recent writing list: subagents article links $(date) -->
