		<script is:inline>
			function initPastramiFilter() {
				const searchInput = document.getElementById('pastrami-search');
				const boroughButtons = document.querySelectorAll('.borough-filter-wrap .filter-btn');
				const sortSelect = document.getElementById('pastrami-sort');
				const listContainer = document.getElementById('pastrami-list');
				const entries = Array.from(listContainer.querySelectorAll('.entry'));
				const pickleDivider = document.getElementById('pickle-divider-el');
				const noResultsMsg = document.getElementById('pastrami-no-results');

				let activeBorough = 'all';
				let searchQuery = '';

				function filterAndSort() {
					// 1. Filter
					let visibleCount = 0;
					entries.forEach(entry => {
						const name = entry.getAttribute('data-name').toLowerCase();
						const location = entry.querySelector('.entry-location').textContent.toLowerCase();
						const note = entry.querySelector('.entry-note').textContent.toLowerCase();
						const borough = entry.getAttribute('data-borough');

						const matchesSearch = name.includes(searchQuery) || location.includes(searchQuery) || note.includes(searchQuery);
						const matchesBorough = activeBorough === 'all' || borough === activeBorough;

						if (matchesSearch && matchesBorough) {
							entry.style.display = 'grid';
							visibleCount++;
						} else {
							entry.style.display = 'none';
						}
					});

					// Toggle empty state
					if (visibleCount === 0) {
						noResultsMsg.style.display = 'block';
						if (pickleDivider) pickleDivider.style.display = 'none';
					} else {
						noResultsMsg.style.display = 'none';
						if (pickleDivider) {
							// Only display the pickle divider if the list is in default rank order and Katz is visible
							const isDefaultSort = sortSelect.value === 'rank-asc';
							const katzEntry = entries.find(e => e.getAttribute('data-name') === "Katz's Delicatessen");
							const isKatzVisible = katzEntry && katzEntry.style.display !== 'none';
							pickleDivider.style.display = (isDefaultSort && isKatzVisible) ? 'flex' : 'none';
						}
					}

					// 2. Sort
					const sortBy = sortSelect.value;
					entries.sort((a, b) => {
						if (sortBy === 'rank-asc') {
							const aRank = parseFloat(a.getAttribute('data-rank'));
							const bRank = parseFloat(b.getAttribute('data-rank'));
							if (aRank !== bRank) return aRank - bRank;
							// Secondary tie breaker on lists count
							return parseInt(b.getAttribute('data-lists')) - parseInt(a.getAttribute('data-lists'));
						} else if (sortBy === 'lists-desc') {
							const aLists = parseInt(a.getAttribute('data-lists'));
							const bLists = parseInt(b.getAttribute('data-lists'));
							if (aLists !== bLists) return bLists - aLists;
							// Secondary tie breaker on rank
							return parseFloat(a.getAttribute('data-rank')) - parseFloat(b.getAttribute('data-rank'));
						} else if (sortBy === 'name-asc') {
							const aName = a.getAttribute('data-name');
							const bName = b.getAttribute('data-name');
							return aName.localeCompare(bName);
						}
						return 0;
					});

					// Append sorted items in order
					entries.forEach(entry => {
						if (entry.style.display !== 'none') {
							listContainer.appendChild(entry);
						}
					});
				}

				// Search input listener
				if (searchInput) {
					searchInput.addEventListener('input', (e) => {
						searchQuery = e.target.value.toLowerCase();
						filterAndSort();
					});
				}

				// Borough filter buttons listeners
				boroughButtons.forEach(btn => {
					btn.addEventListener('click', () => {
						boroughButtons.forEach(b => b.classList.remove('active'));
						btn.classList.add('active');
						activeBorough = btn.getAttribute('data-borough');
						filterAndSort();
					});
				});

				// Sort selector listener
				if (sortSelect) {
					sortSelect.addEventListener('change', () => {
						filterAndSort();
					});
				}

				// Run initial filter and sort
				filterAndSort();
			}

			// Initialize
			initPastramiFilter();
			document.addEventListener('astro:page-load', initPastramiFilter);
		</script>
