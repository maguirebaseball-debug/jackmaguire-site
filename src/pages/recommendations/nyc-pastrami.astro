---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const lastUpdated = 'May 28, 2026';
const pastramiRanking = [
	'Parkview Diner',
	"Moe's Pastrami & Burger",
	"Katz's Delicatessen",
	'House of Glatt',
	'Hometown Bar-B-Que',
	'2nd Avenue Deli',
	'Pastrami Queen',
	"Junior's Restaurant & Bakery",
	'Butcher Block',
	"Liebman's Deli",
	"Sarge's Delicatessen",
	'USA Brooklyn Delicatessen',
	"Mendy's NYC",
	"Murray's Sturgeon Shop",
	'Mile End Delicatessen',
	"S&P Lunch (fmr. Eisenberg's)",
	'Majestic Delicatessen',
	"Frankel's Delicatessen",
	"David's Brisket House",
	"Morgan's Brooklyn Barbecue",
	'Essen New York Deli',
	"Lenny's Grill and Deli",
	'Defonte Sandwich Shop',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Best Pastrami in NYC: Consensus Ranking: ${SITE_TITLE}`}
			description="We pulled 30 ranked lists of NYC pastrami sandwiches from food blogs, newsletters, and local guides, then re-ranked every spot by its average position across the lists it appeared in."
		/>
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'ItemList',
			name: 'Best pastrami in NYC consensus ranking',
			itemListElement: pastramiRanking.map((name, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name,
			})),
		})} />
		<style>
			.intro {
				margin-bottom: 2em;
				color: rgb(var(--gray-dark));
				line-height: 1.7;
			}
			.updated {
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin-top: -1em;
				margin-bottom: 2em;
			}
			.methodology {
				background: rgba(var(--gray-light), 0.5);
				border-radius: 10px;
				padding: 1.25em 1.5em;
				margin-bottom: 2.5em;
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.65;
			}
			.methodology strong {
				color: rgb(var(--gray-dark));
			}

			/* Interactive Filter System Styles */
			.pastrami-filter-wrapper {
				background-color: #fdf8ef;
				border: 2px solid var(--accent);
				border-radius: 10px;
				padding: 1.5rem;
				margin-bottom: 2.5rem;
				box-shadow: 0 4px 12px rgba(var(--gray), 0.08);
			}
			.filter-row {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				align-items: center;
				justify-content: space-between;
			}
			.search-box-wrap {
				flex: 1;
				min-width: 260px;
				position: relative;
			}
			.search-box-wrap input {
				width: 100%;
				padding: 10px 12px 10px 38px;
				font-size: 0.95rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				background-color: #fff;
				color: rgb(var(--gray-dark));
				box-sizing: border-box;
				transition: border-color 0.2s;
			}
			.search-box-wrap input:focus {
				border-color: var(--accent);
				outline: none;
			}
			.search-icon-inline {
				position: absolute;
				left: 12px;
				top: 50%;
				transform: translateY(-50%);
				width: 16px;
				height: 16px;
				color: rgb(var(--gray));
				pointer-events: none;
			}
			.borough-filter-wrap {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-items: center;
			}
			.filter-btn {
				background-color: #fff;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 4px;
				padding: 0.4rem 0.8rem;
				font-size: 0.82rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				cursor: pointer;
				transition: all 0.2s;
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}
			.filter-btn.active {
				background-color: var(--accent);
				color: #fff;
				border-color: var(--accent);
			}
			.filter-btn:hover:not(.active) {
				border-color: var(--accent);
				background-color: rgba(var(--gray-light), 0.2);
			}
			.sort-select-wrap {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.sort-select-wrap label {
				font-size: 0.82rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}
			.sort-select-wrap select {
				padding: 8px 12px;
				font-size: 0.9rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				background-color: #fff;
				color: rgb(var(--gray-dark));
				cursor: pointer;
				outline: none;
			}

			.ranking-list {
				display: flex;
				flex-direction: column;
				gap: 1.25em;
			}
			.entry {
				background: #fff;
				border-radius: 10px;
				padding: 1.25em 1.5em;
				box-shadow: 0 1px 4px rgba(var(--gray), 18%), 0 4px 16px rgba(var(--gray), 12%);
				display: grid;
				grid-template-columns: 3em 1fr auto;
				gap: 0 1.25em;
				align-items: start;
				transition: opacity 0.3s, transform 0.3s;
			}
			@media (max-width: 520px) {
				.entry {
					grid-template-columns: 2.5em 1fr;
				}
				.score-block {
					grid-column: 2;
					margin-top: 0.5em;
				}
			}
			.rank-num {
				font-size: 1.5em;
				font-weight: 800;
				color: rgb(var(--gray));
				line-height: 1.2;
				padding-top: 0.1em;
			}
			.rank-num.top3 {
				color: #b8860b;
			}
			.entry-body {
				min-width: 0;
			}
			.entry-name {
				font-size: 1.1em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 0.15em 0;
				line-height: 1.3;
			}
			.entry-name a {
				color: inherit;
				text-decoration: none;
				border-bottom: 1px dashed var(--accent);
			}
			.entry-name a:hover {
				color: var(--accent);
				border-bottom-style: solid;
			}
			.entry-location {
				font-size: 0.82em;
				color: rgb(var(--gray));
				margin-bottom: 0.5em;
			}
			.entry-note {
				font-size: 0.88em;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
			}
			.entry-note .tag {
				display: inline-block;
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.07em;
				text-transform: uppercase;
				background: rgba(var(--gray-light), 0.8);
				color: rgb(var(--gray));
				border-radius: 4px;
				padding: 0.1em 0.5em;
				margin-right: 0.4em;
				vertical-align: middle;
			}
			.score-block {
				text-align: right;
				white-space: nowrap;
			}
			.avg-rank {
				font-size: 1.4em;
				font-weight: 800;
				color: rgb(var(--black));
				line-height: 1.1;
			}
			.avg-rank.top3 {
				color: #b8860b;
			}
			.avg-label {
				font-size: 0.68em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				display: block;
				margin-top: 0.2em;
			}
			.lists-count {
				font-size: 0.75em;
				color: rgb(var(--gray));
				margin-top: 0.5em;
			}
			.divider {
				border: none;
				border-top: 1px solid rgba(var(--gray), 15%);
				margin: 2em 0;
			}
			.pickle-divider {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1.25em;
				margin: 2em 0;
			}
			.pickle-divider::before,
			.pickle-divider::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgba(var(--gray), 20%);
			}
			.pickle-divider svg {
				width: 96px;
				height: auto;
				opacity: 0.82;
			}
			.sources-note {
				font-size: 0.82em;
				color: rgb(var(--gray));
				line-height: 1.6;
				margin-top: 2.5em;
			}
			.sources-note a {
				color: rgb(var(--gray));
				border-bottom: 1px dashed rgb(var(--gray));
				text-decoration: none;
			}
			.sources-note a:hover {
				color: var(--accent);
				border-bottom-color: var(--accent);
			}
			/* Top 3: larger rank numeral, warm background, left border: structurally distinct from #22 */
			.entry.top3-entry {
				background: #fdf8ef;
				border-left: 4px solid #c4942e;
				padding-left: calc(1.5em - 4px);
				box-shadow: 0 2px 10px rgba(196,148,46,0.14), 0 6px 24px rgba(var(--gray), 10%);
				grid-template-columns: 3.5em 1fr auto;
			}
			.top3-entry .rank-num {
				font-size: 2.25em;
				line-height: 1.05;
				padding-top: 0.05em;
			}
			.top3-entry .entry-name {
				font-size: 1.2em;
			}
			.top3-entry .avg-rank {
				font-size: 1.75em;
			}
			.ticket-wrap {
				margin: 2.5em auto 0;
				max-width: 200px;
			}
			.ticket-wrap svg {
				width: 100%;
				height: auto;
				filter: drop-shadow(2px 3px 6px rgba(0,0,0,0.15));
			}
			.no-results-msg {
				padding: 2.5rem;
				text-align: center;
				background-color: #faf9f6;
				border: 1px dashed rgb(var(--gray-light));
				border-radius: 8px;
				color: rgb(var(--gray));
				font-weight: 600;
				display: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>NYC Pastrami, Ranked</h1>

			<p class="intro">
				There is no shortage of lists ranking pastrami sandwiches in New York City. The problem is that every list has its own agenda: a top pick on one is buried at the bottom of another. So instead of adding one more opinion, we pulled 30 ranked lists from food blogs, newsletters, and local guides published between 2024 and 2026, and let the aggregate do the talking.
			</p>
			<p class="updated">Last updated: {lastUpdated}</p>
			
			<div class="methodology">
				<strong>How this works:</strong> For each list, we recorded where every restaurant placed: 1st, 2nd, 3rd, and so on. We then calculated each restaurant's average rank across all the lists it appeared in. Lower average rank is better. A place that tops two lists beats a place that consistently sits at #5 on seven lists. No points for just showing up. Only mainstream publications were excluded (NYT, Eater, Grubstreet, Infatuation, Thrillist, and similar). 30 sources total; 23 restaurants ranked.
			</div>

			<!-- Interactive Filter Controls -->
			<div class="pastrami-filter-wrapper">
				<div class="filter-row">
					<div class="search-box-wrap">
						<svg class="search-icon-inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
						<input type="text" id="pastrami-search" placeholder="Search by deli name or location..." aria-label="Search delis" />
					</div>
					<div class="borough-filter-wrap">
						<button class="filter-btn active" data-borough="all">All Boroughs</button>
						<button class="filter-btn" data-borough="Manhattan">Manhattan</button>
						<button class="filter-btn" data-borough="Brooklyn">Brooklyn</button>
						<button class="filter-btn" data-borough="Queens">Queens</button>
						<button class="filter-btn" data-borough="Bronx">Bronx</button>
					</div>
					<div class="sort-select-wrap">
						<label for="pastrami-sort">Sort By:</label>
						<select id="pastrami-sort">
							<option value="rank-asc">Consensus Rank (Ascending)</option>
							<option value="lists-desc">List Representation (Descending)</option>
							<option value="name-asc">Alphabetical (A to Z)</option>
						</select>
					</div>
				</div>
			</div>

			<div class="ranking-list" id="pastrami-list">

				<div class="entry top3-entry" data-name="Parkview Diner" data-borough="Brooklyn" data-rank="1.0" data-lists="2">
					<div class="rank-num top3">1</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://maps.google.com/?q=Parkview+Diner+Bath+Beach+Brooklyn" target="_blank" rel="noopener">Parkview Diner</a>
						</div>
						<div class="entry-location">Bath Beach, Brooklyn</div>
						<div class="entry-note">
							<span class="tag">Tied #1</span>
							Won Best of Brooklyn pastrami in both 2024 and 2025. Almost entirely unknown outside the borough's local food circles, which is part of why the average rank looks so clean: the lists that mention it put it first.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank top3">1.0</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">2 lists</div>
					</div>
				</div>

				<div class="entry top3-entry" data-name="Moe's Pastrami & Burger" data-borough="Brooklyn" data-rank="1.0" data-lists="2">
					<div class="rank-num top3">1</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://maps.google.com/?q=Moe's+Pastrami+and+Burger+Prospect-Lefferts+Gardens+Brooklyn" target="_blank" rel="noopener">Moe's Pastrami &amp; Burger</a>
						</div>
						<div class="entry-location">Prospect-Lefferts Gardens, Brooklyn</div>
						<div class="entry-note">
							<span class="tag">Tied #1</span>
							Opened 2023. Halal-certified. Won the <a href="https://brooklynmetropolis.com/" target="_blank" rel="noopener">Brooklyn Metropolis</a> moving blog ranking outright and drew a 4/4 from the <a href="https://peterkto.com/" target="_blank" rel="noopener">PeterKto food blog</a>, edging Katz's 3/4 in a head-to-head. A commenter on <a href="https://robertsietsema.substack.com/" target="_blank" rel="noopener">Robert Sietsema's Substack</a> called it the best in the boroughs after five decades of eating.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank top3">1.0</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">2 lists</div>
					</div>
				</div>

				<div class="entry top3-entry" data-name="Katz's Delicatessen" data-borough="Manhattan" data-rank="1.3" data-lists="14">
					<div class="rank-num top3">3</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://katzsdelicatessen.com/" target="_blank" rel="noopener">Katz's Delicatessen</a>
						</div>
						<div class="entry-location">Lower East Side, Manhattan</div>
						<div class="entry-note">
							Appeared on 14 lists, more than any other restaurant, and held the top position on most of them. The average rank of 1.3 confirms it is not just the most famous; it is genuinely the consensus best. The main complaints are the price ($28.95), the lines, and the tourist density. None of that changes what is in the sandwich.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank top3">1.3</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">14 lists</div>
					</div>
				</div>

				<div class="entry" data-name="House of Glatt" data-borough="Brooklyn" data-rank="2.0" data-lists="1">
					<div class="rank-num">4</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://maps.google.com/?q=House+of+Glatt+Crown+Heights+Brooklyn" target="_blank" rel="noopener">House of Glatt</a>
						</div>
						<div class="entry-location">Crown Heights, Brooklyn</div>
						<div class="entry-note">
							A highly regarded Glatt kosher butcher and deli serving Crown Heights. Highly regarded for its traditional, hand-carved, heavily spiced pastrami and deeply authentic neighborhood atmosphere.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">2.0</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">1 list</div>
					</div>
				</div>

				<div class="entry" data-name="Hometown Bar-B-Que" data-borough="Brooklyn" data-rank="2.8" data-lists="4">
					<div class="rank-num">5</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://hometownbarbque.com/" target="_blank" rel="noopener">Hometown Bar-B-Que</a>
						</div>
						<div class="entry-location">Red Hook, Brooklyn</div>
						<div class="entry-note">
							<span class="tag">Fri-Sun only</span>
							Texas BBQ-style hot-smoked pastrami, available Friday through Sunday. <a href="https://johntannerbbqblog.wordpress.com/" target="_blank" rel="noopener">John Tanner's BBQ blog</a> argued it surpasses Katz's on raw flavor. For anyone who prefers the smoked brisket end of the spectrum over the steamed deli style, this is the pick.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">2.8</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">4 lists</div>
					</div>
				</div>

				<div class="entry" data-name="2nd Avenue Deli" data-borough="Manhattan" data-rank="3.1" data-lists="7">
					<div class="rank-num">6</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://2ndavenuedeli.com/" target="_blank" rel="noopener">2nd Avenue Deli</a>
						</div>
						<div class="entry-location">Murray Hill / Upper East Side</div>
						<div class="entry-note">
							Consistently in the top three across seven separate lists. Hand-carved, thickly sliced, and made with brisket-cut pastrami. Critics frequently note the broth as a hidden strength. The UES location is more manageable than the Murray Hill branch on weekends.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">3.1</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">7 lists</div>
					</div>
				</div>

				<div class="entry" data-name="Pastrami Queen" data-borough="Manhattan" data-rank="3.4" data-lists="11">
					<div class="rank-num">7</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://www.pastramiqueen.com/" target="_blank" rel="noopener">Pastrami Queen</a>
						</div>
						<div class="entry-location">UES / UWS / Moynihan Train Hall</div>
						<div class="entry-note">
							Anthony Bourdain's publicly stated favorite. Machine-sliced rather than hand-carved, which increases surface area and concentrates flavor. Appeared on 11 lists, second only to Katz's, and consistently landed in the top three. The Moynihan Hall location has made it more accessible than it used to be.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">3.4</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">11 lists</div>
					</div>
				</div>

				<div class="entry" data-name="Junior's Restaurant & Bakery" data-borough="Brooklyn" data-rank="3.5" data-lists="4">
					<div class="rank-num">8</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://www.juniorscheesecake.com/" target="_blank" rel="noopener">Junior's Restaurant &amp; Bakery</a>
						</div>
						<div class="entry-location">Downtown Brooklyn</div>
						<div class="entry-note">
							<span class="tag">Tied #8</span>
							Better known for cheesecake, which may be why the pastrami tends to get overlooked. Appeared on four lists at an average position of 3.5.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">3.5</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">4 lists</div>
					</div>
				</div>

				<div class="entry" data-name="Butcher Block" data-borough="Queens" data-rank="3.5" data-lists="2">
					<div class="rank-num">8</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://maps.google.com/?q=Butcher+Block+Sunnyside+Queens" target="_blank" rel="noopener">Butcher Block</a>
						</div>
						<div class="entry-location">Sunnyside, Queens</div>
						<div class="entry-note">
							<span class="tag">Tied #8</span>
							The only Queens entry in the top ten. Appeared on two lists at an average rank of 3.5. Largely unknown outside the neighborhood.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">3.5</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">2 lists</div>
					</div>
				</div>

				<div class="entry" data-name="Liebman's Deli" data-borough="Bronx" data-rank="3.7" data-lists="6">
					<div class="rank-num">10</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://liebmansdeli.com/" target="_blank" rel="noopener">Liebman's Deli</a>
						</div>
						<div class="entry-location">Riverdale, Bronx</div>
						<div class="entry-note">
							The only Bronx entry. Kosher, lean-cut pastrami with a 70-year history. Appeared on six lists and consistently described as the best-value option in the dataset. The trip to Riverdale keeps the tourist count low.
						</div>
					</div>
					<div class="score-block">
						<div class="avg-rank">3.7</div>
						<span class="avg-label">avg rank</span>
						<div class="lists-count">6 lists</div>
					</div>
				</div>

				<div class="entry" data-name="Sarge's Delicatessen" data-borough="Manhattan" data-rank="3.8" data-lists="5">
					<div class="rank-num">11</div>
					<div class="entry-body">
						<div class="entry-name">
							<a href="https://sargesdeli.com/" target="_blank" rel="noopener">Sarge's Delicatessen</a>
