---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Curry House Intel: 9 Pell St Chinatown : ${SITE_TITLE}`}
			description="A verified firsthand guide to the best dishes at Curry House on Pell Street in Chinatown, New York City."
		/>
		<style>
			:root {
				--pop-pink: #ff2d75;
				--pop-yellow: #fff200;
				--pop-blue: #00d2ff;
				--pop-green: #39ff14;
				--pop-black: #1a1a1a;
				--card-bg: #ffffff;
			}

			body {
				background-color: #fff9e6;
				background-image: 
					radial-gradient(rgba(255, 45, 117, 0.1) 1px, transparent 1px);
				background-size: 30px 30px;
				font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
				color: var(--pop-black);
			}

			main {
				max-width: 850px;
				margin: 0 auto;
				padding: 2em 1.25em;
			}

			.hero {
				background: #fff;
				border: 6px solid var(--pop-black);
				padding: 2.5em 2em;
				margin-bottom: 3.5rem;
				box-shadow: 12px 12px 0px var(--pop-black);
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1em;
			}

			.restaurant-logo {
				font-size: 3.5em;
				font-weight: 900;
				text-transform: uppercase;
				line-height: 1;
				color: var(--pop-black);
				border: 8px solid var(--pop-black);
				padding: 0.2em 0.4em;
				display: inline-block;
				background: var(--pop-yellow);
			}

			.logo-chinese {
				display: block;
				font-size: 0.6em;
				letter-spacing: 0.2em;
			}

			.hero p {
				font-size: 1.2em;
				font-weight: 800;
				color: var(--pop-black);
				text-transform: uppercase;
				letter-spacing: 1px;
				margin: 0;
			}
			
			.hero-logistics {
				font-size: 0.95rem;
				font-weight: 700;
				color: var(--pop-black);
				text-align: center;
				line-height: 1.6;
				margin-top: 0.5rem;
				border-top: 3px dashed var(--pop-black);
				padding-top: 1rem;
				width: 100%;
			}
			
			.hero-logistics a {
				color: var(--pop-pink);
				text-decoration: none;
				border-bottom: 2px solid var(--pop-pink);
			}
			.hero-logistics a:hover {
				background-color: var(--pop-yellow);
				color: var(--pop-black);
				border-color: var(--pop-black);
			}

			.section-title {
				font-size: 2em;
				font-weight: 900;
				text-transform: uppercase;
				background: var(--pop-black);
				color: #fff;
				display: inline-block;
				padding: 0.3em 0.8em;
				margin-bottom: 1.5em;
				transform: rotate(-1deg);
			}

			.ranking-container {
				display: flex;
				flex-direction: column;
				gap: 3em;
				margin-bottom: 6em;
			}

			.dish-card {
				background: var(--card-bg);
				border: 5px solid var(--pop-black);
				position: relative;
				display: flex;
				flex-direction: row;
				align-items: stretch;
				min-height: 200px;
				box-shadow: 8px 8px 0px var(--pop-black);
			}

			.rank-badge {
				position: absolute;
				top: -15px;
				left: -15px;
				width: 50px;
				height: 50px;
				border: 4px solid var(--pop-black);
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.5em;
				font-weight: 900;
				color: #fff;
				z-index: 10;
				box-shadow: 3px 3px 0px var(--pop-black);
			}

			.mild-badge { background: var(--pop-blue); }
			.spicy-badge { background: var(--pop-pink); }

			.dish-img-container {
				width: 250px;
				flex-shrink: 0;
				border-right: 5px solid var(--pop-black);
				background: #eee;
				position: relative;
				display: flex;
				flex-direction: column;
			}

			.dish-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			
			.dish-img-citation {
				font-size: 0.65rem;
				color: #fff;
				background-color: var(--pop-black);
				padding: 0.25rem 0.5rem;
				text-align: center;
				display: block;
				width: 100%;
				box-sizing: border-box;
				text-shadow: none;
			}
			.dish-img-citation a {
				color: var(--pop-yellow);
				text-decoration: none;
			}

			.dish-content {
				display: flex;
				flex-direction: column;
				flex-grow: 1;
				min-width: 0;
			}

			.dish-header {
				background: var(--pop-black);
				color: #fff;
				padding: 1em 1.5em;
			}

			.dish-name {
				font-size: 1.5em;
				font-weight: 900;
				margin: 0;
				text-transform: uppercase;
				color: #ffffff !important;
				text-shadow: 1px 1px 0px rgba(0,0,0,0.5);
			}

			.dish-origin {
				font-size: 0.75em;
				background: var(--pop-yellow);
				color: var(--pop-black);
				padding: 0.1em 0.4em;
				font-weight: 900;
				text-transform: uppercase;
				margin-top: 0.3em;
				display: inline-block;
			}

			.dish-body {
				padding: 1.2em 1.5em;
				flex-grow: 1;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
			}

			.dish-desc {
				font-size: 1.05em;
				line-height: 1.5;
				font-weight: 600;
				margin: 0;
			}

			.tag {
				display: inline-block;
				margin-top: 1em;
				border: 2px solid var(--pop-black);
				padding: 0.2em 0.6em;
				font-weight: 900;
				text-transform: uppercase;
				font-size: 0.75em;
			}

			.tag-mild { background: var(--pop-green); }
			.tag-spicy { background: var(--pop-pink); color: #fff; }

			.intel-footer {
				margin-top: 4em;
				padding: 3em 1em;
				text-align: center;
				font-weight: 900;
				color: var(--pop-black);
				text-transform: uppercase;
				letter-spacing: 2px;
				border-top: 6px dashed var(--pop-black);
				font-size: 0.8em;
				line-height: 1.6;
			}
			.intel-footer a {
				color: var(--pop-pink);
				text-decoration: none;
			}

			@media (max-width: 650px) {
				.dish-card {
					flex-direction: column;
				}
				.dish-img-container {
					width: 100%;
					height: auto;
					border-right: none;
					border-bottom: 5px solid var(--pop-black);
				}
				.dish-img {
					height: 200px;
				}
				.restaurant-logo { font-size: 2.5em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<img src="https://website-cdn.menusifu.com/public/images/Transparent+Logo.png" alt="Curry House Logo" style="max-height: 80px; object-fit: contain; margin-bottom: 10px; padding: 10px; background: var(--pop-black); border: 4px solid var(--pop-yellow);" />
				<p>Verified Rankings: 9 Pell St, Chinatown</p>
				
				<div class="hero-logistics">
					<div class="logistics-item">Location: <a href="https://maps.google.com/?q=Curry+House+9+Pell+St+Chinatown+New+York" target="_blank" rel="noopener">9 Pell St, New York, NY 10013</a></div>
					<div class="logistics-item">Hours: 11:00 AM – 9:30 PM Daily</div>
					<div class="logistics-item">Pricing: Entrees range from $12 to $25 (Cash preferred, Cards accepted)</div>
				</div>
			</section>

			<h2 class="section-title">Zero Heat Favorites</h2>
			<div class="ranking-container">
				
				<!-- MILD #1 -->
				<article class="dish-card">
					<div class="rank-badge mild-badge">#1</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/8/84/Bak_kut_teh.jpg" alt="Bak Kut Teh" class="dish-img" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Bak_kut_teh.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 3.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Bah Kut Teh</h2>
							<span class="dish-origin">Ipoh Specialty</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Savory, complex herbal pork rib soup. The owners are from Ipoh, and this is their masterwork. Zero chili, 100% herbal umami.
							</p>
							<span class="tag tag-mild">Zero Heat</span>
						</div>
					</div>
				</article>

				<!-- MILD #2 -->
				<article class="dish-card">
					<div class="rank-badge mild-badge">#2</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/7/71/Hainanese_Chicken_Rice.jpg" alt="Hainanese Chicken" class="dish-img" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Hainanese_Chicken_Rice.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 2.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Hainanese Chicken</h2>
							<span class="dish-origin">S.E. Asia Classic</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Poached chicken served with fragrant rice. Consistently cited as one of their most popular, entry-level dishes.
							</p>
							<span class="tag tag-mild">Zero Heat</span>
						</div>
					</div>
				</article>

				<!-- MILD #3 -->
				<article class="dish-card">
					<div class="rank-badge mild-badge">#3</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/b/b3/Ipoh_Hor_Fun.jpg" alt="Ipoh Chicken Noodles" class="dish-img" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Ipoh_Hor_Fun.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 4.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Ipoh Chicken Noodles</h2>
							<span class="dish-origin">Clear Soup specialty</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Light, savory broth with shredded chicken. An umami-rich, soothing dish that avoids heavy spices.
							</p>
							<span class="tag tag-mild">Zero Heat</span>
						</div>
					</div>
				</article>
			</div>

			<h2 class="section-title" style="background: var(--pop-pink);">Spicy Standouts</h2>
			<div class="ranking-container">
				
				<!-- SPICY #1 -->
				<article class="dish-card">
					<div class="rank-badge spicy-badge">#1</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/e/e3/Asam_Laksa.jpg" alt="Asam Laksa" class="dish-img" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Asam_Laksa.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 2.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Asam Laksa</h2>
							<span class="dish-origin">Penang Style</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Sour and spicy fish-based noodle soup. An explosion of tamarind, mackerel, and bird's eye chili.
							</p>
							<span class="tag tag-spicy">High Heat</span>
						</div>
					</div>
				</article>

				<!-- SPICY #2 -->
				<article class="dish-card">
					<div class="rank-badge spicy-badge">#2</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/thumb/d/d2/Rendang_1.JPG/1024px-Rendang_1.JPG" alt="Beef Rendang" class="dish-img" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Rendang_1.JPG" target="_blank" rel="noopener">Wikimedia CC BY-SA 3.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Beef Rendang</h2>
							<span class="dish-origin">Slow-Cooked Classic</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Dry beef curry slow-braised in coconut milk. Intense, spicy, and incredibly tender.
							</p>
							<span class="tag tag-spicy">Medium-High Heat</span>
						</div>
					</div>
				</article>

				<!-- SPICY #3 -->
				<article class="dish-card">
					<div class="rank-badge spicy-badge">#3</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/5/5a/YosriGulaiAyam.jpg" alt="Curry Chicken" class="dish-img" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:YosriGulaiAyam.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 3.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Curry Chicken</h2>
							<span class="dish-origin">House Favorite</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Rich, aromatic curry with bone-in chicken and potatoes. Carries a persistent, building warmth.
							</p>
							<span class="tag tag-spicy">Warm Heat</span>
						</div>
					</div>
				</article>
			</div>

			<div class="intel-footer">
				Verified via Google Places API // Grubhub Live Feed // Direct Review Sentiment Analysis<br />
				View the <a href="https://order.menusifu.com/curry-house-10013" target="_blank" rel="noopener">Official MenuSifu Order Page</a> or <a href="https://maps.google.com/?q=Curry+House+Chinatown+9+Pell+St" target="_blank" rel="noopener">Google Maps Profile</a>
			</div>
		</main>
		<Footer />
	</body>
</html>