---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const lastUpdated = 'May 28, 2026';
const curryHouseDishes = [
	'Bah Kut Teh',
	'Hainanese Chicken',
	'Ipoh Chicken Noodles',
	'Asam Laksa',
	'Beef Rendang',
	'Curry Chicken',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Best Dishes at Curry House Chinatown: ${SITE_TITLE}`}
			description="A verified firsthand guide to the best dishes at Curry House on Pell Street in Chinatown, New York City."
		/>
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'ItemList',
			name: 'Best dishes at Curry House Chinatown',
			itemListElement: curryHouseDishes.map((name, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name,
			})),
		})} />
		<style>
			body {
				background-color: var(--paper);
			}

			main {
				max-width: 820px;
				margin: 0 auto;
				padding: 2.5em 1.25em;
			}

			.hero {
				border-top: 2px solid rgba(85, 107, 47, 0.35);
				border-bottom: 1px solid rgba(85, 107, 47, 0.18);
				padding: 1.5em 0 1.7em;
				margin-bottom: 3rem;
			}

			.hero h1 {
				font-size: clamp(1.8rem, 8vw, 3.2rem);
				font-family: var(--font-heading);
				font-weight: 620;
				line-height: 1.05;
				color: rgb(var(--black));
				margin: 0 0 1rem;
			}

			.hero-kicker {
				margin: 0 0 0.6rem;
				font-family: var(--font-ui), sans-serif;
				font-size: 0.72rem;
				font-weight: 700;
				color: var(--accent-dark);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.hero-logistics {
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}

			.hero-logistics a {
				color: var(--accent-dark);
				text-decoration: none;
				border-bottom: 1px solid rgba(85, 107, 47, 0.45);
			}
			.hero-logistics a:hover {
				color: var(--accent);
			}
			.hero .updated {
				font-size: 0.82rem;
				font-family: var(--font-ui), sans-serif;
				color: rgb(var(--gray));
				margin: 1rem 0 0;
			}

			.section-title {
				font-size: 1.2em;
				font-weight: 620;
				color: rgb(var(--black));
				margin: 2.8em 0 1em;
				padding-bottom: 0.35rem;
				border-bottom: 1px solid rgba(85, 107, 47, 0.28);
			}

			.ranking-container {
				display: flex;
				flex-direction: column;
				gap: 1.1em;
				margin-bottom: 3.5em;
			}

			.dish-card {
				position: relative;
				display: grid;
				grid-template-columns: 12rem 1fr;
				background: rgba(255, 255, 255, 0.62);
				border-top: 1px solid rgba(var(--gray-light), 0.9);
				min-height: 180px;
			}
			.dish-card.image-missing {
				grid-template-columns: 1fr;
			}
			.dish-card.image-missing .dish-img-container {
				display: none;
			}
			.dish-card.image-missing .rank-badge {
				position: static;
				justify-self: start;
				margin: 1rem 1.25rem 0;
			}

			.rank-badge {
				position: absolute;
				top: 0.75rem;
				left: 0.75rem;
				font-family: var(--font-ui), sans-serif;
				font-size: 0.78rem;
				font-weight: 700;
				color: var(--accent-dark);
				z-index: 10;
				background: rgba(245, 239, 227, 0.9);
				padding: 0.2rem 0.45rem;
			}

			.dish-img-container {
				width: 100%;
				border-right: 1px solid rgba(var(--gray-light), 0.85);
				background: rgba(var(--gray-light), 0.28);
				position: relative;
				display: flex;
				flex-direction: column;
			}
			.dish-img-container::before {
				content: "reference image";
				position: absolute;
				inset: 0;
				display: grid;
				place-items: center;
				font-family: var(--font-ui), sans-serif;
				font-size: 0.72rem;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				color: rgba(var(--gray), 0.72);
			}

			.dish-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				border-radius: 0;
				position: relative;
				z-index: 1;
			}

			.dish-img-citation {
				font-size: 0.65rem;
				color: rgb(var(--gray));
				background-color: rgba(255, 255, 255, 0.86);
				padding: 0.25rem 0.5rem;
				text-align: center;
				display: block;
				width: 100%;
				box-sizing: border-box;
				text-shadow: none;
				position: relative;
				z-index: 2;
			}
			.dish-img-citation a {
				color: rgb(var(--gray));
				text-decoration: none;
			}

			.dish-content {
				display: flex;
				flex-direction: column;
				flex-grow: 1;
				min-width: 0;
			}

			.dish-header {
				color: rgb(var(--black));
				padding: 1.1em 1.25em 0.4em;
			}

			.dish-name {
				font-size: 1.32em;
				font-weight: 620;
				margin: 0;
				color: rgb(var(--black));
			}

			.dish-origin {
				font-size: 0.75em;
				color: var(--accent-dark);
				font-family: var(--font-ui), sans-serif;
				font-weight: 700;
				text-transform: uppercase;
				margin-top: 0.3em;
				display: inline-block;
			}

			.dish-body {
				padding: 0.4em 1.25em 1.15em;
				flex-grow: 1;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
			}

			.dish-desc {
				font-size: 0.98em;
				line-height: 1.58;
				margin: 0;
			}

			.tag {
				display: inline-block;
				margin-top: 0.85em;
				border-top: 1px solid rgba(85, 107, 47, 0.28);
				padding-top: 0.35em;
				font-family: var(--font-ui), sans-serif;
				font-weight: 700;
				text-transform: uppercase;
				font-size: 0.75em;
				color: var(--accent-dark);
			}

			.intel-footer {
				margin-top: 3em;
				padding-top: 1.25em;
				color: rgb(var(--gray));
				border-top: 1px solid rgba(85, 107, 47, 0.22);
				font-size: 0.82em;
				line-height: 1.6;
			}
			.intel-footer a {
				color: var(--accent-dark);
				text-decoration: none;
			}

			@media (max-width: 650px) {
				.hero-logistics {
					grid-template-columns: 1fr;
					gap: 0.35rem;
				}
				.dish-card {
					grid-template-columns: 1fr;
				}
				.dish-img-container {
					width: 100%;
					height: auto;
					border-right: none;
					border-bottom: 1px solid rgba(var(--gray-light), 0.85);
				}
				.dish-img {
					height: 200px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="hero-kicker">9 Pell Street, Chinatown</p>
				<h1>Mild Orders at Curry House</h1>
				
				<div class="hero-logistics">
					<div class="logistics-item">Location: <a href="https://maps.google.com/?q=Curry+House+9+Pell+St+Chinatown+New+York" target="_blank" rel="noopener">9 Pell St, New York, NY 10013</a></div>
					<div class="logistics-item">Hours: 11:00 AM to 9:30 PM Daily</div>
					<div class="logistics-item">Pricing: Entrees range from $12 to $25 (Cash preferred, Cards accepted)</div>
				</div>
				<p class="updated">Last updated: {lastUpdated}</p>
			</section>

			<h2 class="section-title">Low-heat orders</h2>
			<div class="ranking-container">
				
				<!-- MILD #1 -->
				<article class="dish-card">
					<div class="rank-badge mild-badge">#1</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/8/84/Bak_kut_teh.jpg" alt="Bak Kut Teh" class="dish-img" onerror="this.closest('.dish-card').classList.add('image-missing'); this.style.display='none'" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Bak_kut_teh.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 3.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Bah Kut Teh</h2>
							<span class="dish-origin">Ipoh Specialty</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Savory, complex herbal pork rib soup. The owners are from Ipoh, and this is their masterwork. Zero chili, 100% herbal umami.
							</p>
							<span class="tag tag-mild">Mild order</span>
						</div>
					</div>
				</article>

				<!-- MILD #2 -->
				<article class="dish-card">
					<div class="rank-badge mild-badge">#2</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/7/71/Hainanese_Chicken_Rice.jpg" alt="Hainanese Chicken" class="dish-img" onerror="this.closest('.dish-card').classList.add('image-missing'); this.style.display='none'" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Hainanese_Chicken_Rice.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 2.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Hainanese Chicken</h2>
							<span class="dish-origin">S.E. Asia Classic</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Poached chicken served with fragrant rice. Consistently cited as one of their most popular, entry-level dishes.
							</p>
							<span class="tag tag-mild">Mild order</span>
						</div>
					</div>
				</article>

				<!-- MILD #3 -->
				<article class="dish-card">
					<div class="rank-badge mild-badge">#3</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/b/b3/Ipoh_Hor_Fun.jpg" alt="Ipoh Chicken Noodles" class="dish-img" onerror="this.closest('.dish-card').classList.add('image-missing'); this.style.display='none'" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Ipoh_Hor_Fun.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 4.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Ipoh Chicken Noodles</h2>
							<span class="dish-origin">Clear Soup specialty</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Light, savory broth with shredded chicken. An umami-rich, soothing dish that avoids heavy spices.
							</p>
							<span class="tag tag-mild">Mild order</span>
						</div>
					</div>
				</article>
			</div>

			<h2 class="section-title">Spicier orders</h2>
			<div class="ranking-container">
				
				<!-- SPICY #1 -->
				<article class="dish-card">
					<div class="rank-badge spicy-badge">#1</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/e/e3/Asam_Laksa.jpg" alt="Asam Laksa" class="dish-img" onerror="this.closest('.dish-card').classList.add('image-missing'); this.style.display='none'" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Asam_Laksa.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 2.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Asam Laksa</h2>
							<span class="dish-origin">Penang Style</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Sour and spicy fish-based noodle soup. An explosion of tamarind, mackerel, and bird's eye chili.
							</p>
							<span class="tag tag-spicy">High heat</span>
						</div>
					</div>
				</article>

				<!-- SPICY #2 -->
				<article class="dish-card">
					<div class="rank-badge spicy-badge">#2</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/thumb/d/d2/Rendang_1.JPG/1024px-Rendang_1.JPG" alt="Beef Rendang" class="dish-img" onerror="this.closest('.dish-card').classList.add('image-missing'); this.style.display='none'" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:Rendang_1.JPG" target="_blank" rel="noopener">Wikimedia CC BY-SA 3.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Beef Rendang</h2>
							<span class="dish-origin">Slow-Cooked Classic</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Dry beef curry slow-braised in coconut milk. Intense, spicy, and incredibly tender.
							</p>
							<span class="tag tag-spicy">Medium-high heat</span>
						</div>
					</div>
				</article>

				<!-- SPICY #3 -->
				<article class="dish-card">
					<div class="rank-badge spicy-badge">#3</div>
					<div class="dish-img-container">
						<img src="https://upload.wikimedia.org/wikipedia/commons/5/5a/YosriGulaiAyam.jpg" alt="Curry Chicken" class="dish-img" onerror="this.closest('.dish-card').classList.add('image-missing'); this.style.display='none'" />
						<span class="dish-img-citation">Image: <a href="https://commons.wikimedia.org/wiki/File:YosriGulaiAyam.jpg" target="_blank" rel="noopener">Wikimedia CC BY-SA 3.0</a></span>
					</div>
					<div class="dish-content">
						<header class="dish-header">
							<h2 class="dish-name">Curry Chicken</h2>
							<span class="dish-origin">House Favorite</span>
						</header>
						<div class="dish-body">
							<p class="dish-desc">
								Rich, aromatic curry with bone-in chicken and potatoes. Carries a persistent, building warmth.
							</p>
							<span class="tag tag-spicy">Warm heat</span>
						</div>
					</div>
				</article>
			</div>

			<div class="intel-footer">
				Notes checked against the official menu, public listing details, and review patterns.<br />
				View the <a href="https://order.menusifu.com/curry-house-10013" target="_blank" rel="noopener">official MenuSifu order page</a> or <a href="https://maps.google.com/?q=Curry+House+Chinatown+9+Pell+St" target="_blank" rel="noopener">Google Maps profile</a>.
			</div>
		</main>
		<Footer />
	</body>
</html>
