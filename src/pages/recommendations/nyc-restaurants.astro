		<script is:inline>
			function initRestaurantFilter() {
				const searchInput = document.getElementById('restaurant-search');
				const filterPills = document.querySelectorAll('.category-filter-wrap .filter-pill');
				const container = document.getElementById('restaurant-container');
				const items = Array.from(container.querySelectorAll('.restaurant'));
				const noResultsMsg = document.getElementById('restaurant-no-results');

				let activeFilter = 'all';
				let searchQuery = '';

				function performFiltering() {
					let visibleCount = 0;
					items.forEach(item => {
						const name = item.getAttribute('data-name').toLowerCase();
						const type = item.getAttribute('data-type');
						const tags = item.getAttribute('data-tags').toLowerCase();
						const borough = item.getAttribute('data-borough');
						const address = item.querySelector('.restaurant-logistics').textContent.toLowerCase();

						const matchesSearch = name.includes(searchQuery) || tags.includes(searchQuery) || address.includes(searchQuery);
						
						let matchesCategory = false;
						if (activeFilter === 'all') {
							matchesCategory = true;
						} else if (activeFilter === 'Manhattan' || activeFilter === 'Brooklyn' || activeFilter === 'Queens') {
							matchesCategory = (borough === activeFilter);
						} else {
							matchesCategory = (type === activeFilter);
						}

						if (matchesSearch && matchesCategory) {
							item.style.display = 'block';
							visibleCount++;
						} else {
							item.style.display = 'none';
						}
					});

					noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
				}

				if (searchInput) {
					searchInput.addEventListener('input', (e) => {
						searchQuery = e.target.value.toLowerCase();
						performFiltering();
					});
				}

				filterPills.forEach(pill => {
					pill.addEventListener('click', () => {
						filterPills.forEach(p => p.classList.remove('active'));
						pill.classList.add('active');
						activeFilter = pill.getAttribute('data-cat');
						performFiltering();
					});
				});

				performFiltering();
			}

			initRestaurantFilter();
			document.addEventListener('astro:page-load', initRestaurantFilter);
		</script>
	</body>
