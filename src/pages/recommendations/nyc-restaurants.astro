---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`NYC Restaurant Recommendations — ${SITE_TITLE}`}
			description="Jack Maguire's picks for restaurants, bars, and cafes worth seeking out in New York City."
		/>
		<style>
			.intro {
				margin-bottom: 2.5em;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.restaurant-list {
				display: flex;
				flex-direction: column;
				gap: 2.5em;
			}
			.restaurant {
				background: #fff;
				border-radius: 10px;
				padding: 1.5em 1.75em;
				box-shadow: 0 1px 4px rgba(var(--gray), 18%), 0 4px 16px rgba(var(--gray), 12%);
			}
			.restaurant-header {
				margin-bottom: 0.75em;
			}
			.restaurant-number {
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				display: block;
				margin-bottom: 0.2em;
			}
			.restaurant-name {
				font-size: 1.2em;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0;
				line-height: 1.3;
			}
			.restaurant-type {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-top: 0.15em;
			}
			.verdict-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1em;
				margin-top: 1em;
			}
			@media (max-width: 560px) {
				.verdict-grid {
					grid-template-columns: 1fr;
				}
			}
			.verdict-block {
				background: rgba(var(--gray-light), 0.45);
				border-radius: 7px;
				padding: 0.85em 1em;
			}
			.verdict-block.pros {
				background: rgba(220, 240, 220, 0.5);
			}
			.verdict-block.cons {
				background: rgba(240, 220, 220, 0.4);
			}
			.verdict-label {
				font-size: 0.7em;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 0.5em;
				display: block;
			}
			.verdict-block.pros .verdict-label {
				color: #2a7a2a;
			}
			.verdict-block.cons .verdict-label {
				color: #9a2a2a;
			}
			.verdict-block ul {
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.verdict-block ul li {
				font-size: 0.88em;
				line-height: 1.5;
				padding: 0.25em 0;
				padding-left: 1.1em;
				position: relative;
				color: rgb(var(--gray-dark));
			}
			.verdict-block.pros ul li::before {
				content: '+';
				position: absolute;
				left: 0;
				color: #2a7a2a;
				font-weight: 700;
			}
			.verdict-block.cons ul li::before {
				content: '−';
				position: absolute;
				left: 0;
				color: #9a2a2a;
				font-weight: 700;
			}
			.item-name {
				font-weight: 600;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>NYC Restaurants</h1>
			<p class="intro">Places worth seeking out. Honest pros and cons from real visits and reviews.</p>

			<div class="restaurant-list">

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">01</span>
						<div class="restaurant-name">Jakarta Munch at Hungry Pearl</div>
						<div class="restaurant-type">Indonesian &mdash; Food Hall</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li><span class="item-name">Beef Rendang</span> (slow-cooked coconut beef) is a consistent must-order</li>
								<li>Clear labeling for vegan and gluten-free diners</li>
								<li><span class="item-name">Jus Alpukat</span> (avocado smoothie with chocolate) is a fan favorite</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Around $17&ndash;20 per bowl, which feels high for a food hall</li>
								<li>Chicken Gulai can be less marinated than the beef options</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">02</span>
						<div class="restaurant-name">Europa Bar and Grill</div>
						<div class="restaurant-type">Bar &amp; Grill &mdash; Gravesend, Brooklyn</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>True neighborhood spot with outdoor seating and a pool table</li>
								<li>Locals claim it has some of the best cheeseburgers in Gravesend</li>
								<li>High-energy karaoke and DJ nights on Saturdays</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Ratings on secondary sites diverge significantly from Google Maps</li>
								<li>Neighborhood dive, not a fine dining experience</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">03</span>
						<div class="restaurant-name">Greyz Bistro</div>
						<div class="restaurant-type">Caribbean-Asian Fusion &mdash; Crown Heights</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Chef Garth praised for Michelin-level food quality</li>
								<li>Standouts: Oxtail Ravioli, Jerk Chicken Tacos, Snapper with Lavender Beurre Blanc</li>
								<li>Chef interacts personally with guests</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Prices (e.g., a $75 omelet) can feel jarring for Crown Heights</li>
								<li>Ambiance described as lacking the polish that matches the price point</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">04</span>
						<div class="restaurant-name">390 Social</div>
						<div class="restaurant-type">Cocktail Bar &amp; Event Space &mdash; Park Slope</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>$1.50 oyster happy hour (Sun&ndash;Fri) is one of the best steals in Brooklyn</li>
								<li>Highly recommended for private events; manager Dana frequently praised</li>
								<li>Greenery-filled decor and a cozy speakeasy lower level</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Menu focuses on specialized tapas, not standard bar fare</li>
								<li>Downstairs room gets cramped for groups over 35</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">05</span>
						<div class="restaurant-name">Oxford Cafe</div>
						<div class="restaurant-type">Breakfast &amp; Fast-Casual &mdash; FiDi / Midtown</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li><span class="item-name">The "Billy" Wrap</span> rated 9.5/10 by some Beli users</li>
								<li>Lightning-fast service, great for the work crowd</li>
								<li>Hearty portions at prices that undercut nearby tourist traps</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Classic hole-in-the-wall; not a leisurely brunch spot</li>
								<li>Some locations have limited Sunday hours</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">06</span>
						<div class="restaurant-name">Koju</div>
						<div class="restaurant-type">Japanese Omakase</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>High-end sushi paired with a world-class Japanese vinyl sound system</li>
								<li>Chef Kevin Garrison's dry-aged fish delivers intense, concentrated flavor</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Mandatory 20% administrative fee that is not a gratuity</li>
								<li>Reservations are extremely competitive on Resy</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">07</span>
						<div class="restaurant-name">Grand Eleven</div>
						<div class="restaurant-type">Bar &mdash; Tribeca</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Stunning three-story layout mixing Art Deco and modern wood styles</li>
								<li>Highly imaginative cocktail program and a consistently great playlist</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Food menu is minimal: mostly sliders and snacks</li>
								<li>Can be slightly hard to find on an awkward split lot</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">08</span>
						<div class="restaurant-name">Freak Bar</div>
						<div class="restaurant-type">Bar &mdash; Coney Island</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>The ultimate Coney Island experience; attached to the Circus Sideshow</li>
								<li>Excellent selection of local craft beers including Coney Island Brewery</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Clown and skeleton decor is not for the faint of heart</li>
								<li>Gets extremely crowded and loud when the sideshow lets out</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">09</span>
						<div class="restaurant-name">Tatanka's Tincture Bar</div>
						<div class="restaurant-type">Apothecary Cafe &mdash; Bed-Stuy</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Unique drinks infused with tinctures (ashwagandha, rose, etc.) you won't find elsewhere</li>
								<li>Hot Honey Wings and Mac N Cheese are legendary among regulars</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Very small footprint that fills up fast</li>
								<li>Earthy botanical flavors are polarizing if that's not your thing</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">10</span>
						<div class="restaurant-name">Wok In Duane</div>
						<div class="restaurant-type">Asian Fusion</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Reddit raves about the wok hei in the Drunken Noodles</li>
								<li>$1 appetizer and drink special during happy hour</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Narrow entrance and dining area feel cramped during peak dinner</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">11</span>
						<div class="restaurant-name">Alytori</div>
						<div class="restaurant-type">Fried Chicken</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Hormone-free chicken and triple-cooked fries that stay crispy</li>
								<li>Owners frequently mentioned by name for warmth and remembering regulars</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Very limited indoor seating; primarily grab-and-go or delivery</li>
								<li>Made-to-order means longer waits than standard fast food</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">12</span>
						<div class="restaurant-name">Sunday C&amp;C Bakery</div>
						<div class="restaurant-type">Vegan &mdash; Latin-Asian Fusion</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Frequently called "S-tier" on Reddit; Lion's Mane Mushrooms and Guava Bread are standouts</li>
								<li>Creative Latin-Asian flavors you won't find at a standard vegan cafe</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
								<li>Popular items and weekend specials often sell out by early afternoon</li>
								<li>Counter-service only with very few seats</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="restaurant">
					<div class="restaurant-header">
						<span class="restaurant-number">13</span>
						<div class="restaurant-name">Willows Tavern</div>
						<div class="restaurant-type">Bar &mdash; Ridgewood</div>
					</div>
					<div class="verdict-grid">
						<div class="verdict-block pros">
							<span class="verdict-label">Pros</span>
							<ul>
								<li>Massive willow tree in the backyard; one of the best outdoor drinking spots in Ridgewood</li>
							</ul>
						</div>
						<div class="verdict-block cons">
							<span class="verdict-label">Cons</span>
							<ul>
							</ul>
						</div>
					</div>
				</div>

			</div>
		</main>
		<Footer />
	</body>
</html>
