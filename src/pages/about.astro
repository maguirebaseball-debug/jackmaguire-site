---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="Jack Maguire is a performance marketing and paid social media director based in East Village, NYC. 12+ years managing paid social campaigns across Meta, TikTok, and Instagram." />
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Jack Maguire",
			"url": "https://jackmaguire.org",
			"jobTitle": "Paid Social Media Director",
			"alumniOf": { "@type": "Organization", "name": "McGill University" },
			"address": { "@type": "PostalAddress", "addressLocality": "New York", "addressRegion": "NY" },
			"sameAs": ["https://www.linkedin.com/in/paidsocialdirector/"]
		}
		</script>
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<div class="prose">
				<p>
					I'm Jack Maguire, a performance marketing and paid social media director based in
					New York City. Over the past 12 years I've built and led advertising programs for
					large organizations across Meta, TikTok, Instagram, Facebook, and Snapchat, working
					at the intersection of creative strategy, data analysis, and media buying. This site
					is where I write about what I'm paying attention to: NYC food, travel, philosophy,
					AI, and occasionally work.
				</p>

				<h2>Work</h2>
				<p>
					Most recently, I served as Senior Paid Social Media Director at National Debt Relief
					(March 2022 to January 2026), where I managed over $1M in monthly ad spend across
					Meta and TikTok, led a team of paid social managers, and navigated the regulatory
					complexity of advertising in the debt settlement industry alongside legal and
					compliance teams.
				</p>
				<p>
					Prior roles include Good Apple (agency-side paid social strategy), Visiting Angels
					(paid social management across 800+ franchise locations), Ascension Press (grew
					Facebook and YouTube audiences to 100K+ followers), and Renegade Communications
					(media buying and campaign management). Platforms have included Meta, TikTok,
					Instagram, Facebook, Snapchat, Pinterest, LinkedIn, Reddit, Quora, and YouTube.
				</p>
				<p>
					I have been an early and consistent practitioner of AI-assisted marketing, using
					large language models daily for campaign optimization, creative briefing, and
					analytics since well before widespread adoption. My focus is on how AI changes the
					practical work of performance marketing, not the theoretical version.
				</p>

				<h2>This site</h2>
				<p>
					This site is a place for writing on topics I follow closely: NYC food and
					restaurants, travel, philosophy, AI tools, and performance marketing. The
					perspective is analytical and firsthand. I write about what I have actually done,
					read, or worked through.
				</p>

				<h2>Outside work</h2>
				<p>
					Before my junior year at McGill University, I thru-hiked the Appalachian Trail:
					2,178 miles in 99 days. I have completed three marathons. I have read more than
					300 books, with particular focus on economics, behavioral economics, philosophy,
					theology, and systems thinking. I live in the East Village in New York City.
				</p>

				<h2>Background</h2>
				<ul>
					<li>Most recently: Senior Paid Social Media Director, National Debt Relief</li>
					<li>Previously: Good Apple &middot; Visiting Angels &middot; Ascension Press &middot; Renegade Communications</li>
					<li>McGill University — Business Management &amp; Philosophy</li>
					<li>East Village, New York City</li>
				</ul>

				<h2>Contact</h2>
				<p>
					Email: maguirebaseball [at] gmail [dot] com
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.prose {
		max-width: 600px;
	}
	.prose h2 {
		font-size: 1.2em;
		margin-top: 2em;
		margin-bottom: 0.5em;
	}
	.prose ul {
		padding-left: 1.5em;
	}
	.prose li {
		margin-bottom: 0.3em;
	}
</style>
