<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      /* ── Layout ──────────────────────────────────────────────── */
      .article-container {
        display: flex;
        justify-content: center;
        gap: 3rem;
        max-width: 1300px;
        margin: 0 auto;
        position: relative;
      }
      @media (max-width: 1280px) {
        .article-container { display: block; }
      }
      .article-wrap {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1.25rem 5rem;
        width: 100%;
        box-sizing: border-box;
      }

      /* ── Article header ──────────────────────────────────────── */
      .article-header {
        padding: 2.5rem 0 2rem;
        border-bottom: 1px solid rgb(var(--gray-light));
        margin-bottom: 2.5rem;
      }
      .article-header h1 {
        font-size: clamp(1.6rem, 4vw, 2.6rem);
        line-height: 1.2;
        margin: 0 0 0.75rem;
      }
      .meta {
        font-family: var(--font-lora);
        font-size: 0.85rem;
        color: rgb(var(--gray));
        margin: 0 0 1rem;
      }
      .intro {
        font-size: 1.05rem;
        line-height: 1.75;
        max-width: 780px;
        margin: 0 0 0.75rem;
      }
      .intro-cats {
        margin: 0.75rem 0 0.75rem 1.1rem;
        padding: 0;
        font-size: 1rem;
        line-height: 1.8;
        max-width: 780px;
      }
      .intro-cats li {
        margin-bottom: 0.15rem;
      }
      .intro-note {
        font-size: 0.88rem;
        color: rgb(var(--gray));
        margin: 0.5rem 0 0;
        max-width: 780px;
        line-height: 1.65;
      }

      /* ── Category sections ───────────────────────────────────── */
      .cat-section {
        margin-bottom: 3.5rem;
      }
      .cat-label {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-outfit, var(--font-lora));
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        padding: 0.28rem 0.7rem;
        border-radius: 3px;
        margin-bottom: 0.5rem;
      }
      .cat-energy   .cat-label { background: #fde8e8; color: #7a1a1a; }
      .cat-seated   .cat-label { background: #fef3dc; color: #7a4f00; }
      .cat-calm     .cat-label { background: #ede8f5; color: #4a2d7a; }
      .cat-nj       .cat-label { background: #e0edf5; color: #1a3d5a; }
      .cat-brooklyn .cat-label { background: #e8f0dc; color: #2a4a10; }
      .cat-queens   .cat-label { background: #f5ede8; color: #6a3010; }
      .cat-upper    .cat-label { background: #f0e8f5; color: #5a1a6a; }
      .cat-midtown  .cat-label { background: #e8ecf5; color: #1a2a6a; }

      .cat-section h2 {
        font-size: clamp(1.3rem, 3.5vw, 1.9rem);
        margin: 0 0 0.3rem;
        line-height: 1.2;
      }
      .cat-intro {
        color: rgb(var(--gray));
        font-size: 0.9rem;
        margin: 0 0 1.5rem;
        line-height: 1.6;
      }

      /* ── Venue grid ──────────────────────────────────────────── */
      .venue-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 1.2rem;
      }
      .venue-grid.single-col {
        grid-template-columns: 1fr;
      }

      /* ── Venue card ──────────────────────────────────────────── */
      .venue-card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 1px 4px rgba(var(--gray), 0.12), 0 4px 14px rgba(var(--gray), 0.07);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .card-body {
        padding: 1rem 1.1rem 1.15rem;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        flex: 1;
      }
      .card-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .card-name {
        font-family: var(--font-fraunces);
        font-size: 1.1rem;
        font-weight: 700;
        color: rgb(var(--black));
        margin: 0;
        line-height: 1.2;
      }
      .card-hood {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        padding: 0.15rem 0.45rem;
        border-radius: 3px;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .cat-energy   .card-hood { background: #fde8e8; color: #7a1a1a; }
      .cat-seated   .card-hood { background: #fef3dc; color: #7a4f00; }
      .cat-calm     .card-hood { background: #ede8f5; color: #4a2d7a; }
      .cat-nj       .card-hood { background: #e0edf5; color: #1a3d5a; }
      .cat-brooklyn .card-hood { background: #e8f0dc; color: #2a4a10; }
      .cat-queens   .card-hood { background: #f5ede8; color: #6a3010; }
      .cat-upper    .card-hood { background: #f0e8f5; color: #5a1a6a; }
      .cat-midtown  .card-hood { background: #e8ecf5; color: #1a2a6a; }

      .card-address {
        font-size: 0.78rem;
        color: rgb(var(--gray));
        font-style: italic;
        margin: 0;
      }
      .card-why {
        font-size: 0.88rem;
        line-height: 1.6;
        color: rgb(var(--gray-dark));
        margin: 0;
        flex: 1;
      }
      .card-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.1rem;
      }
      .pill {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.18rem 0.55rem;
        border-radius: 99px;
        border: 1px solid;
        white-space: nowrap;
      }
      .pill-green  { background: #e8f0dc; color: #2a4a10; border-color: #b8d490; }
      .pill-amber  { background: #fef3dc; color: #7a4f00; border-color: #e8c87a; }
      .pill-gray   { background: #f3f4f6; color: rgb(var(--gray)); border-color: rgb(var(--gray-light)); }

      .card-caveat {
        font-size: 0.75rem;
        color: #8a3a3a;
        background: #fdf0f0;
        border-left: 2px solid #d49090;
        padding: 0.3rem 0.6rem;
        border-radius: 0 4px 4px 0;
        margin-top: 0.15rem;
      }
      .card-quote {
        font-size: 0.78rem;
        font-style: italic;
        color: rgb(var(--gray));
        border-left: 2px solid var(--accent);
        padding: 0.3rem 0.6rem;
        margin-top: 0.1rem;
        background: rgba(85, 107, 47, 0.04);
        border-radius: 0 4px 4px 0;
      }
      .card-quote a {
        font-style: normal;
        font-size: 0.72rem;
        display: inline-block;
        margin-left: 0.4rem;
        opacity: 0.75;
      }
      .card-links {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.6rem;
        flex-wrap: wrap;
      }
      .card-link {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--accent);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        opacity: 0.9;
      }
      .card-link:hover { opacity: 1; text-decoration: underline; }

      /* ── Reservation badge ───────────────────────────────────── */
      .res-badge {
        font-size: 0.72rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
      }
      .res-yes  { color: #2a4a10; }
      .res-walk { color: rgb(var(--gray)); }

      /* ── Neighborhood index table ────────────────────────────── */
      .ni-section {
        margin-top: 3.5rem;
        padding-top: 2.5rem;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .ni-section h2 {
        font-size: clamp(1.3rem, 3.5vw, 1.9rem);
        margin: 0 0 0.4rem;
      }
      .ni-intro {
        color: rgb(var(--gray));
        font-size: 0.9rem;
        margin: 0 0 1.5rem;
      }
      .ni-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
      }
      .ni-table th {
        text-align: left;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: rgb(var(--gray));
        padding: 0.5rem 0.75rem;
        border-bottom: 2px solid rgba(85, 107, 47, 0.25);
        background: transparent;
      }
      .ni-table td {
        padding: 0.6rem 0.75rem;
        border-bottom: 1px solid rgb(var(--gray-light));
        vertical-align: top;
        line-height: 1.5;
      }
      .ni-table tr:last-child td {
        border-bottom: none;
      }
      .ni-top-pick {
        font-weight: 600;
        color: rgb(var(--black));
      }
      .ni-runners {
        color: rgb(var(--gray));
        font-size: 0.82rem;
      }

      /* ── Mobile ──────────────────────────────────────────────── */
      @media (max-width: 720px) {
        .venue-grid { grid-template-columns: 1fr; }
        .article-wrap { padding: 0 1rem 3.5rem; }
        .ni-table { font-size: 0.82rem; }
      }
      @media (max-width: 480px) {
        .article-header h1 { font-size: 1.55rem; }
        .cat-section h2 { font-size: 1.3rem; }
      }
    </style>
  </head>
  <body>
    <ReadingProgressBar />
    <Header />
    <main>
      <div class="article-container">
        <TableOfContents />
        <div class="article-wrap">

          <header class="article-header">
            <p class="meta">{pubDate}</p>
            <h1>{title}</h1>
            <p class="intro">
              I live in the East Village and I don't follow the Knicks through a regular season. But they're in the Finals, and I'm going somewhere to watch.
            </p>
            <p class="intro">
              The problem I run into every time: show up to a bar on a big game night and it's so packed you're standing the whole time, can barely see a screen, and can't hear what's happening over the music. I put this list together for myself. Figured other people are in the same spot.
            </p>
            <ul class="intro-cats">
              <li><strong>High Energy</strong> — you want the chaos, the crowd screaming, standing room is fine</li>
              <li><strong>Settled and Seated</strong> — you want real atmosphere but also an actual chair</li>
              <li><strong>Calm Viewing</strong> — you want to follow the game and hear the commentary</li>
            </ul>
            <p class="intro-note">Every listing is flagged walk-in or reservable and has a Google Maps link. Covers Manhattan, Brooklyn, Queens, and Hoboken. No paid placements, no sponsorships.</p>
          </header>

          {/* ── HIGH ENERGY ────────────────────────────────────── */}
          <section class="cat-section cat-energy" id="high-energy">
            <div class="cat-label">&#128293; High Energy</div>
            <h2>Loud, Packed, All-In</h2>
            <div class="venue-grid">
              {high_energy.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; {v.screens.slice(0, 40)}</span>}
                      {(v.reservation && !v.reservation.startsWith('Unknown') && !v.reservation.startsWith('Walk'))
                        ? <span class="pill pill-amber">&#128204; Reservable</span>
                        : <span class="pill pill-gray">Walk-in</span>
                      }
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── SETTLED & SEATED ───────────────────────────────── */}
          <section class="cat-section cat-seated" id="settled-seated">
            <div class="cat-label">&#127941; Settled &amp; Seated</div>
            <h2>Great Atmosphere, Actually Get a Seat</h2>
            <div class="venue-grid">
              {settled_seated.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; Screens confirmed</span>}
                      {(v.reservation && !v.reservation.startsWith('Unknown') && !v.reservation.startsWith('Walk'))
                        ? <span class="pill pill-amber">&#128204; {v.reservation.slice(0, 50)}</span>
                        : <span class="pill pill-gray">Walk-in</span>
                      }
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── CALM VIEWING ───────────────────────────────────── */}
          <section class="cat-section cat-calm" id="calm-viewing">
            <div class="cat-label">&#127936; Calm Viewing</div>
            <h2>Great Screens, Relaxed Crowd</h2>
            <div class="venue-grid">
              {calm_viewing.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.crowd && <span class="pill pill-green">&#128107; Relaxed crowd</span>}
                      {(v.reservation && !v.reservation.startsWith('Unknown') && !v.reservation.startsWith('Walk'))
                        ? <span class="pill pill-amber">&#128204; Reservable</span>
                        : <span class="pill pill-gray">Walk-in</span>
                      }
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── GOLD COAST NJ ──────────────────────────────────── */}
          <section class="cat-section cat-nj" id="gold-coast">
            <div class="cat-label">&#127307; Gold Coast NJ</div>
            <h2>Hoboken &amp; Jersey City</h2>
            <div class="venue-grid">
              {gold_coast.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; Screens</span>}
                      <span class="pill pill-gray">Walk-in</span>
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── BROOKLYN ───────────────────────────────────────── */}
          <section class="cat-section cat-brooklyn" id="brooklyn">
            <div class="cat-label">&#127961;&#65039; Brooklyn</div>
            <h2>Brooklyn</h2>
            <div class="venue-grid">
              {brooklyn.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; Screens</span>}
                      {(v.reservation && !v.reservation.startsWith('Unknown') && !v.reservation.startsWith('Walk'))
                        ? <span class="pill pill-amber">&#128204; Some seating</span>
                        : <span class="pill pill-gray">Walk-in</span>
                      }
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── QUEENS ─────────────────────────────────────────── */}
          <section class="cat-section cat-queens" id="queens">
            <div class="cat-label">&#127953; Queens</div>
            <h2>Queens</h2>
            <div class="venue-grid">
              {queens.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; Screens</span>}
                      <span class="pill pill-gray">Walk-in</span>
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── UPPER MANHATTAN ────────────────────────────────── */}
          <section class="cat-section cat-upper" id="upper-manhattan">
            <div class="cat-label">&#127960;&#65039; Upper Manhattan</div>
            <h2>Upper East Side &amp; Harlem</h2>
            <div class="venue-grid">
              {upper_manhattan.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; Screens</span>}
                      {(v.reservation && v.reservation.toLowerCase().includes('book') || v.reservation && v.reservation.toLowerCase().includes('reserv') && !v.reservation.startsWith('Walk'))
                        ? <span class="pill pill-amber">&#128204; Reservable</span>
                        : <span class="pill pill-gray">Walk-in</span>
                      }
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── MIDTOWN ────────────────────────────────────────── */}
          <section class="cat-section cat-midtown" id="midtown">
            <div class="cat-label">&#127970; Midtown</div>
            <h2>Midtown</h2>
            <div class="venue-grid">
              {midtown.map(v => (
                <div class="venue-card">
                  <div class="card-body">
                    <div class="card-top">
                      <h3 class="card-name">{v.name}</h3>
                      <span class="card-hood">{v.neighborhood}</span>
                    </div>
                    <p class="card-address">{v.address}</p>
                    <p class="card-why">{v.why}</p>
                    <div class="card-pills">
                      {v.screens && v.screens !== 'Unknown' && <span class="pill pill-green">&#128250; Screens</span>}
                      <span class="pill pill-gray">Walk-in</span>
                    </div>
                    {v.caveats && <p class="card-caveat">&#9888;&#65039; {v.caveats}</p>}
                    {v.quotes[0] && (
                      <p class="card-quote">
                        &ldquo;{v.quotes[0].q}&rdquo;
                        {v.quotes[0].url && <a href={v.quotes[0].url} target="_blank" rel="noopener noreferrer"> Review</a>}
                      </p>
                    )}
                    <div class="card-links">
                      {v.website && <a class="card-link" href={v.website} target="_blank" rel="noopener noreferrer">Website ↗</a>}
                      {v.maps_url && <a class="card-link" href={v.maps_url} target="_blank" rel="noopener noreferrer">Map ↗</a>}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* ── NEIGHBORHOOD INDEX ─────────────────────────────── */}
          <section class="ni-section" id="by-neighborhood">
            <h2>Quick Reference by Neighborhood</h2>
            <p class="ni-intro">Top pick per neighborhood, with runners-up.</p>
            <table class="ni-table">
              <thead>
                <tr>
                  <th>Neighborhood</th>
                  <th>Area</th>
                  <th>Top Pick</th>
                  <th>Also Consider</th>
                </tr>
              </thead>
              <tbody>
                {neighborhood_index.map(n => (
                  <tr>
                    <td><strong>{n.neighborhood}</strong></td>
                    <td>{n.area}</td>
                    <td class="ni-top-pick">{n.top}</td>
                    <td class="ni-runners">{n.runners.join(', ')}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>


        </div>
      </div>
    </main>
