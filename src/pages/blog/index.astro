---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getStandaloneBlogPosts } from '../../lib/standaloneBlogPosts';

const markdownPosts = (await getCollection('blog')).map((post) => ({
	title: post.data.title,
	href: `/blog/${post.id}/`,
	pubDate: post.data.pubDate,
	tags: post.data.tags ?? [],
	isStandalone: false,
}));

const standalonePosts = getStandaloneBlogPosts().map((post) => ({
	title: post.title,
	href: post.href,
	pubDate: post.pubDate,
	tags: ['Interactive'],
	isStandalone: true,
}));

const posts = [...standalonePosts, ...markdownPosts].sort(
	(a, b) => b.pubDate.valueOf() - a.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.tags))].filter(t => t !== 'Interactive').sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Jack Maguire Essays: NYC Food, Philosophy, AI, and Travel`} description="Read Jack Maguire's essays, reviews, and notes on NYC restaurants, philosophy, performance marketing, AI, and travel." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing</h1>
			{allTags.length > 0 && (
				<div class="tags">
					{allTags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
			<section class="archive-section">
				<ul class="archive-list">
					{
						posts.map((post) => (
							<li>
								<a href={post.href}>
									<span class="title">
										{post.title}
										{post.isStandalone && <span class="badge">Interactive</span>}
									</span>
									<span class="meta">
										<FormattedDate date={post.pubDate} />
										{post.tags && post.tags.length > 0 && post.tags.filter(t => t !== 'Interactive').length > 0 && (
											<span class="tag-list"> · {post.tags.filter(t => t !== 'Interactive').join(', ')}</span>
										)}
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 1.5em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 2em;
	}
	.tag {
		font-size: 0.8em;
		padding: 0.2em 0.7em;
		background: rgb(var(--gray-light));
		border-radius: 20px;
		color: rgb(var(--gray-dark));
	}
	.archive-section {
		margin: 0 0 2.5em;
	}
	.badge {
		font-size: 0.72rem;
		font-weight: 600;
		background: #e8f0dc;
		color: #3a5c1a;
		padding: 0.15rem 0.45rem;
		border-radius: 4px;
		margin-left: 0.5rem;
		font-family: var(--font-outfit), sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		display: inline-block;
		vertical-align: middle;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	ul li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	ul li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.9em 0;
		text-decoration: none;
		color: rgb(var(--black));
	}
	ul li a:hover .title {
		color: var(--accent);
	}
	.meta {
		font-size: 0.82em;
		color: rgb(var(--gray));
		white-space: nowrap;
		flex-shrink: 0;
	}
	.tag-list {
		font-style: italic;
	}
	@media (max-width: 600px) {
		ul li a {
			flex-direction: column;
			gap: 0.2em;
		}
		.meta {
			white-space: normal;
		}
	}
</style>
