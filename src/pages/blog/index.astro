---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))].sort();

const astroPageSources = import.meta.glob('./*.astro', {
	query: '?raw',
	import: 'default',
	eager: true,
});

function extractConst(source: string, name: string) {
	const match = source.match(new RegExp(`const ${name} = (["'])(.*?)\\1;`, 's'));
	return match?.[2];
}

const featurePosts = Object.entries(astroPageSources)
	.filter(([path]) => !path.includes('/index.astro') && !path.includes('/[...slug].astro'))
	.map(([path, source]) => {
		const slug = path.replace('./', '').replace('.astro', '');
		const title = extractConst(source as string, 'title');
		const pubDate = extractConst(source as string, 'pubDate');

		if (!title || !pubDate) {
			throw new Error(`${path} must define const title and const pubDate to appear on /blog.`);
		}

		return {
			title,
			href: `/blog/${slug}/`,
			pubDate: new Date(`${pubDate} 12:00:00`),
			category: "Feature essay",
		};
	})
	.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Essays, Reviews, & Notes | ${SITE_TITLE}`} description="Read essays, reviews, and notes on performance marketing, NYC restaurants, philosophy, and AI by Jack Maguire." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing</h1>
			{allTags.length > 0 && (
				<div class="tags">
					<span class="tag feature-tag">feature essays</span>
					{allTags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
			<section class="feature-section" aria-labelledby="feature-heading">
				<h2 id="feature-heading">Feature Essays</h2>
				<p class="section-note">Custom Astro articles with fuller layouts, data views, and visual systems.</p>
				<ul class="feature-list">
					{
						featurePosts.map((post) => (
							<li>
								<a href={post.href}>
									<span class="title">{post.title}</span>
									<span class="meta">
										<FormattedDate date={post.pubDate} />
										<span class="tag-list"> · {post.category}</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<h2 class="archive-heading">All Writing</h2>
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="title">{post.data.title}</span>
								<span class="meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.tags && post.data.tags.length > 0 && (
										<span class="tag-list"> · {post.data.tags.join(', ')}</span>
									)}
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 1.5em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 2em;
	}
	.tag {
		font-size: 0.8em;
		padding: 0.2em 0.7em;
		background: rgb(var(--gray-light));
		border-radius: 20px;
		color: rgb(var(--gray-dark));
	}
	.feature-tag {
		background: color-mix(in srgb, var(--accent) 14%, white);
		color: var(--accent-dark);
	}
	.feature-section {
		margin: 0 0 2.5em;
		padding: 1.2em 1.4em;
		border-left: 3px solid var(--accent);
		background: #f7f4ee;
	}
	h2 {
		font-size: 1.15em;
		margin: 0 0 0.35em;
	}
	.section-note {
		margin: 0 0 1em;
		color: rgb(var(--gray));
		font-size: 0.9em;
		line-height: 1.6;
	}
	.feature-list {
		margin: 0;
	}
	.archive-heading {
		margin: 0 0 0.4em;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	ul li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	ul li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.9em 0;
		text-decoration: none;
		color: rgb(var(--black));
	}
	ul li a:hover .title {
		color: var(--accent);
	}
	.meta {
		font-size: 0.82em;
		color: rgb(var(--gray));
		white-space: nowrap;
		flex-shrink: 0;
	}
	.tag-list {
		font-style: italic;
	}
	@media (max-width: 600px) {
		ul li a {
			flex-direction: column;
			gap: 0.2em;
		}
		.meta {
			white-space: normal;
		}
	}
</style>
