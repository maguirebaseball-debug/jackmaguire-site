---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getStandaloneBlogPosts } from '../../lib/standaloneBlogPosts';

const markdownPosts = (await getCollection('blog')).map((post) => ({
	title: post.data.title,
	href: `/blog/${post.id}/`,
	pubDate: post.data.pubDate,
	tags: post.data.tags ?? [],
	isStandalone: false,
}));

const standalonePosts = getStandaloneBlogPosts().map((post) => ({
	title: post.title,
	href: post.href,
	pubDate: post.pubDate,
	tags: ['Interactive'],
	isStandalone: true,
}));

const posts = [...standalonePosts, ...markdownPosts].sort(
	(a, b) => b.pubDate.valueOf() - a.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.tags))].filter(t => t !== 'Interactive').sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Jack Maguire Essays: NYC Food, Philosophy, AI, and Travel`} description="Read Jack Maguire's essays, reviews, and notes on NYC restaurants, philosophy, performance marketing, AI, and travel." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing</h1>
			{allTags.length > 0 && (
				<div class="tags">
					{allTags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
			<section class="archive-section">
				<ul class="archive-list">
					{
						(() => {
							let prevYear = null;
							return posts.map((post) => {
								const y = post.pubDate.getFullYear();
								const isNew = y !== prevYear;
								prevYear = y;
								return (
									<>
										{isNew && <li class="year-header"><h2>{y}</h2></li>}
										<li>
											<a href={post.href}>
												<span class="meta">
													<FormattedDate date={post.pubDate} />
													{post.tags && post.tags.length > 0 && post.tags.filter(t => t !== 'Interactive').length > 0 && (
														<span class="tag-list"> · {post.tags.filter(t => t !== 'Interactive').join(', ')}</span>
													)}
													{post.isStandalone && <span class="interactive"> (interactive)</span>}
												</span>
												<span class="title">{post.title}</span>
											</a>
										</li>
									</>
								);
							});
						})()
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 1.5em;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 2em;
	}
	.tag {
		font-size: 0.8em;
		color: rgb(var(--gray-dark));
	}
	.archive-section {
		margin: 0 0 2.5em;
	}
	.year-header {
		list-style: none;
		margin-top: 1.2em;
	}
	.year-header h2 {
		font-size: 1em;
		margin: 0 0 0.3em;
		color: rgb(var(--gray));
		font-weight: 600;
		letter-spacing: 0;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	ul li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	ul li.year-header {
		border-bottom: none;
	}
	ul li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.9em 0;
		text-decoration: none;
		color: rgb(var(--black));
	}
	ul li a:hover .title {
		color: var(--accent);
	}
	.meta {
		font-size: 0.82em;
		color: rgb(var(--gray));
		white-space: nowrap;
		flex-shrink: 0;
	}
	.interactive {
		font-size: 0.7em;
		opacity: 0.7;
	}
	.tag-list {
		font-style: italic;
	}
	@media (max-width: 600px) {
		ul li a {
			flex-direction: column;
			gap: 0.2em;
		}
		.meta {
			white-space: normal;
		}
	}
</style>
