---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReadingProgressBar from '../../components/ReadingProgressBar.astro';
import { marked } from 'marked';
import bodyMd from './subagents-account-for-most-token-costs-in-long-agent-runs.content.md?raw';

const title = "Subagents Account for Most Token Costs in Long Agent Runs: Fixes That Cut Usage 70 to 90 Percent in Practice";
const description = "Practitioners who run extended agent sessions report the same degradation: context windows fill with thousands of tokens of crap from repeated history and handoffs. Data and fixes that flatten the cost curve."; 
const pubDate = "Jun 02, 2026";

const bodyHtml = marked.parse(bodyMd);

---

<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "author": {
      "@type": "Person",
      "name": "Jack Maguire",
      "url": "https://jackmaguire.org"
    },
    "datePublished": "2026-06-02",
    "publisher": {
      "@type": "Person",
      "name": "Jack Maguire"
    }
  })} />
  <style>
    .wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 1.25rem 5rem;
      width: 100%;
      box-sizing: border-box;
    }

    .article-header {
      padding: 2.5rem 0 2rem;
      border-bottom: 3px solid var(--accent);
      margin-bottom: 3rem;
    }
    .article-header .meta {
      font-family: var(--font-ui), sans-serif;
      font-size: 0.8rem;
      color: rgb(var(--gray));
      margin: 0 0 1rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .article-header .read-time {
      color: var(--accent);
      font-weight: 600;
    }
    .article-header h1 {
      font-size: clamp(1.7rem, 4.5vw, 2.9rem);
      margin: 0 0 1.2rem;
      font-family: var(--font-heading);
      line-height: 1.15;
      font-weight: 800;
      color: rgb(var(--black));
    }
    .article-header .intro {
      font-size: 1.15rem;
      line-height: 1.6;
      color: rgb(var(--gray-dark));
      margin: 0;
    }

    .prose {
      max-width: var(--width-prose);
      font-size: 1.05rem;
      line-height: 1.75;
      color: rgb(var(--gray-dark));
    }
    .prose p {
      margin: 0 0 1.5rem;
    }
    .prose h2 {
      font-family: var(--font-heading);
      font-size: 1.8rem;
      color: rgb(var(--black));
      margin: 2.75rem 0 1.25rem;
      line-height: 1.2;
    }
    .prose h3 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      color: rgb(var(--black));
      margin: 2rem 0 0.9rem;
      line-height: 1.25;
    }
    .prose hr {
      border: 0;
      border-top: 1px solid rgb(var(--gray-light));
      margin: 3rem 0;
    }
    .prose ul, .prose ol {
      margin: 0 0 1.5rem;
      padding-left: 1.5rem;
    }
    .prose li {
      margin-bottom: 0.6rem;
      line-height: 1.65;
    }
    .prose a {
      color: var(--accent-dark);
      text-decoration-thickness: 1px;
      text-underline-offset: 0.18em;
    }
    .prose a:hover {
      color: var(--accent);
    }

    .callout-box {
      background: rgba(85, 107, 47, 0.06);
      border-left: 3px solid var(--accent);
      border-radius: 0 6px 6px 0;
      padding: 1.4rem 1.6rem;
      margin: 2.25rem 0 2.75rem;
    }
    .callout-box .callout-label {
      font-family: var(--font-ui), sans-serif;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--accent-dark);
      font-weight: 700;
      margin: 0 0 0.85rem;
    }
    .callout-box ol {
      margin: 0;
      padding-left: 1.3rem;
    }
    .callout-box li {
      margin-bottom: 0.75rem;
      line-height: 1.6;
      font-size: 1rem;
    }
    .callout-box li:last-child {
      margin-bottom: 0;
    }
    .callout-box strong {
      color: rgb(var(--black));
    }

    .related-reading {
      margin-top: 4rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(85, 107, 47, 0.22);
    }
    .related-reading h2 {
      font-family: var(--font-ui), sans-serif;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--accent-dark);
      margin: 0 0 0.85rem;
      font-weight: 700;
    }
    .related-reading ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    .related-reading a {
      color: rgb(var(--gray-dark));
      text-decoration-thickness: 1px;
      text-underline-offset: 0.18em;
      font-size: 0.95rem;
    }
    .related-reading a:hover {
      color: var(--accent-dark);
    }
  </style>
</head>
<body>
  <ReadingProgressBar />
  <Header />
  <main>
    <div class="wrap">

      <header class="article-header">
        <p class="meta">{pubDate} &nbsp;|&nbsp; Tech &amp; AI &nbsp;|&nbsp; <span class="read-time">8 min read</span></p>
        <h1>{title}</h1>
        <p class="intro">{description}</p>
      </header>
      <section class="prose" set:html={bodyHtml} />

    </div>
  </main>
  <Footer />
</body>
</html>
