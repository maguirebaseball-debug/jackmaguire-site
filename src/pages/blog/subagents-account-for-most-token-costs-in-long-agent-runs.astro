---
import PlainStandaloneBlog from '../../layouts/PlainStandaloneBlog.astro';
import { marked } from 'marked';
import bodyMd from './subagents-account-for-most-token-costs-in-long-agent-runs.content.md?raw';

const title = "Subagents Account for Most Token Costs in Long Agent Runs: Fixes That Cut Usage 70 to 90 Percent in Practice";
const description = "Practitioners who run extended agent sessions report the same degradation: context windows fill with thousands of tokens of crap from repeated history and handoffs. Data and fixes that flatten the cost curve."; 
const pubDate = "Jun 02, 2026";

const bodyHtml = marked.parse(bodyMd);

---

<PlainStandaloneBlog title={title} description={description} pubDate={pubDate} datePublished="2026-06-02">
  <section set:html={bodyHtml} />
</PlainStandaloneBlog>
