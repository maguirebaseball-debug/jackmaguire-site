const title = "World Cup Third-Place Games Are Not Always Higher Scoring. Modern Ones Are.";
const description = "All-time bronze matches match finals for goals. Since 1990 they clearly outscore modern finals and semis. Here is the data, the psychology, and what managers optimize for.";
const pubDate = "Jul 18, 2026";
const category = "Sports";
const dateObj = new Date("2026-07-18T12:00:00Z");
const img = "/images/world-cup-third-place";
