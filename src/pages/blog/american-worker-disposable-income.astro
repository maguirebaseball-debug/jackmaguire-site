  <script is:inline>
    (function () {
      var root = document.getElementById('nahdi-chart');
      var tip = document.getElementById('nahdi-tip');
      if (!root || !tip) return;
      root.addEventListener('mousemove', function (e) {
        var row = e.target.closest ? e.target.closest('.viz-row') : null;
        if (!row || !row.dataset.usd) { tip.hidden = true; return; }
        tip.textContent = row.dataset.usd + ' per worker, ' + row.dataset.pct + '% of the US figure';
        tip.hidden = false;
        tip.style.left = Math.min(e.clientX + 12, window.innerWidth - 250) + 'px';
        tip.style.top = (e.clientY + 14) + 'px';
      });
      root.addEventListener('mouseleave', function () { tip.hidden = true; });
    })();
  </script>

</PlainStandaloneBlog>
