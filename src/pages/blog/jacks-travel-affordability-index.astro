---
import BaseHead from '../../components/BaseHead.astro';
import countries from '../../data/travel-affordability/countries.json';
import cities from '../../data/travel-affordability/cities.json';
import causalFeatures from '../../data/travel-affordability/causal-features.json';

const title = "Jack's Travel Affordability Index";
const description = 'An interactive 2026 ranking of tourist affordability across 195 countries and 69 cities, with price drivers, confidence grades, and searchable destination data.';
const pubDate = 'Jul 15, 2026';
const category = 'Travel';

const regions = [...new Set(countries.map((country) => country.region))].sort();
const cityEconomies = [...new Set(cities.map((city) => city.economy))].sort();
const topCountries = countries.slice(0, 6);
const visitorFeatures = causalFeatures.filter((feature) => feature.outcome === 'Visitor USD prices');
const observedCount = countries.filter((country) => country.projection_confidence === 'A').length;
const payload = JSON.stringify({ countries, cities }).replace(/</g, '\\u003c');
const canonical = 'https://jackmaguire.org/blog/jacks-travel-affordability-index/';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content="2026-07-15" />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'Article',
			headline: title,
			description,
			datePublished: '2026-07-15',
			dateModified: '2026-07-15',
			author: { '@type': 'Person', name: 'Jack Maguire' },
			mainEntityOfPage: canonical,
		})} />
	</head>
	<body class="travel-index">
		<header class="ti-masthead">
			<a class="ti-home" href="/">Jack Maguire</a>
			<div class="ti-wordmark" aria-label="Jack's Travel Affordability Index">
				<span class="ti-kicker">The 2026 edition</span>
				<span>Travel Affordability</span>
			</div>
			<a class="ti-index-link" href="#rankings">Explore the index</a>
		</header>

		<main>
			<section class="ti-hero">
				<div class="ti-hero-copy">
					<p class="ti-rubric">Data interactive <span>•</span> July 2026</p>
					<h1>Jack's Travel<br />Affordability Index</h1>
					<p class="ti-dek">Where your travel dollar goes furthest, across every UN country and 69 major cities.</p>
					<p class="ti-intro">
						A place can be cheap for a visitor even when life is expensive for the people who live there.
						This index isolates the first question: how much does a tourist paying in U.S. dollars face on the ground?
					</p>
					<div class="ti-byline">
						<span>By Jack Maguire</span>
						<span>Updated July 15, 2026</span>
					</div>
				</div>

				<aside class="ti-hero-rank" aria-label="Cheapest visitor destinations">
					<div class="ti-hero-rank-head">
						<span>Visitor rank</span>
						<span>U.S. = 100</span>
					</div>
					{topCountries.map((country) => (
						<div class:list={['ti-rank-row', country.projection_confidence >= 'D' && 'is-caution']}>
							<span class="ti-rank-number">{String(country.visitor_rank_cheapest).padStart(2, '0')}</span>
							<span class="ti-rank-country">
								<strong>{country.country}</strong>
								<small>{country.projection_confidence === 'A' ? 'Observed' : `Grade ${country.projection_confidence} projection`}</small>
							</span>
							<span class="ti-rank-score">{country.visitor_price_us100.toFixed(1)}</span>
						</div>
					))}
					<p class="ti-chart-note">Lower is cheaper. Conflict, scarcity, visa access, and airfare are outside the score.</p>
				</aside>
			</section>

			<section class="ti-statline reveal" aria-label="Index coverage">
				<div><strong>195</strong><span>countries</span></div>
				<div><strong>69</strong><span>cities</span></div>
				<div><strong>{observedCount}</strong><span>observed anchors</span></div>
				<div><strong>9.1%</strong><span>visitor model test error</span></div>
			</section>

			<section class="ti-reading reveal" aria-labelledby="what-it-means">
				<div class="ti-section-label">The reading</div>
				<div class="ti-reading-body">
					<h2 id="what-it-means">Cheap is a currency story first.</h2>
					<div class="ti-reading-grid">
						<div>
							<p class="ti-dropcap">Egypt, India and Indonesia are the clearest inexpensive choices in the top tier because all three are directly observed. Syria ranks first in the model, but its grade D result reflects stale inputs, war, and exchange-rate distortion. A low index value is not a travel recommendation.</p>
							<p>Japan is a useful rich-country case. Yen weakness makes it relatively inexpensive for dollar earners even though it remains a high-income economy. Switzerland is the reverse: strong wages help residents, while visitors face the world's highest modeled price level.</p>
						</div>
						<aside class="ti-pullquote">
							<span>54.5%</span>
							<p>of identified movement in tourist-facing prices came from currency appreciation.</p>
						</aside>
					</div>
				</div>
			</section>

			<section class="ti-factors reveal" aria-labelledby="factor-title">
				<div class="ti-section-label">What moves the index</div>
				<div class="ti-factor-content">
					<div class="ti-factor-heading">
						<h2 id="factor-title">The tourist price equation</h2>
						<p>Measured importance among the causal channels in the model. This explains change in visitor-facing prices, not the full level of every country's score.</p>
					</div>
					<div class="ti-factor-grid">
						{visitorFeatures.map((factor, index) => (
							<article class="ti-factor-card">
								<div class="ti-factor-number">0{index + 1}</div>
								<h3>{factor.causal_feature}</h3>
								<div class="ti-factor-bar" aria-label={`${factor.importance_share_pct.toFixed(1)} percent importance`}>
									<span style={`width:${factor.importance_share_pct}%`}></span>
								</div>
								<strong>{factor.importance_share_pct.toFixed(1)}%</strong>
								<p>{factor.interpretation}</p>
								<small>Elasticity {factor.elasticity.toFixed(2)} · 95% interval {factor.ci_low.toFixed(2)} to {factor.ci_high.toFixed(2)}</small>
							</article>
						))}
					</div>
					<div class="ti-formula">
						<span>Working rule</span>
						<p>A 10% currency appreciation is associated with roughly a 7.4% rise in dollar prices, before local price responses.</p>
					</div>
				</div>
			</section>

			<section class="ti-explorer reveal" id="rankings" aria-labelledby="rankings-title">
				<div class="ti-explorer-heading">
					<div>
						<p class="ti-section-label">The full country index</p>
						<h2 id="rankings-title">Find your next destination</h2>
					</div>
					<p>Index 100 equals the U.S. visitor price level. A score of 50 suggests a comparable basket costs about half as much. Airfare is excluded.</p>
				</div>

				<div class="ti-controls" aria-label="Country filters">
					<label class="ti-search">
						<span>Search</span>
						<input id="country-search" type="search" placeholder="Country name" autocomplete="off" />
					</label>
					<label>
						<span>Region</span>
						<select id="country-region">
							<option value="">All regions</option>
							{regions.map((region) => <option value={region}>{region}</option>)}
						</select>
					</label>
					<label>
						<span>Evidence</span>
						<select id="country-evidence">
							<option value="">All evidence</option>
							<option value="observed">Observed only</option>
							<option value="projected">Projected</option>
							<option value="proxy">Peer proxy</option>
						</select>
					</label>
					<label>
						<span>Confidence</span>
						<select id="country-confidence">
							<option value="">All grades</option>
							<option value="A">A · observed</option>
							<option value="B">B · strong model</option>
							<option value="C">C · use caution</option>
							<option value="D">D · weak</option>
							<option value="E">E · proxy</option>
						</select>
					</label>
					<label>
						<span>Price band</span>
						<select id="country-band">
							<option value="">Any price</option>
							<option value="under40">Under 40</option>
							<option value="40to60">40 to 60</option>
							<option value="60to80">60 to 80</option>
							<option value="80to100">80 to 100</option>
							<option value="over100">Over 100</option>
						</select>
					</label>
					<label>
						<span>Sort</span>
						<select id="country-sort">
							<option value="rank">Cheapest first</option>
							<option value="expensive">Most expensive first</option>
							<option value="confidence">Strongest evidence</option>
							<option value="alpha">A to Z</option>
						</select>
					</label>
				</div>

				<div class="ti-resultbar">
					<p id="country-count" aria-live="polite">195 destinations</p>
					<p><span class="ti-grade ti-grade-a">A</span> observed <span class="ti-grade ti-grade-d">D</span> high caution</p>
				</div>

				<div class="ti-data-layout">
					<div class="ti-table-panel">
						<div class="ti-table-scroll">
							<table class="ti-data-table">
								<thead>
									<tr>
										<th class="ti-col-rank" scope="col">Rank</th>
										<th class="ti-col-name" scope="col">Country</th>
										<th class="ti-col-price" scope="col">Price index</th>
										<th class="ti-col-range" scope="col">Range</th>
										<th class="ti-col-grade" scope="col">Grade</th>
										<th class="ti-col-compare" scope="col"><span class="sr-only">Compare</span></th>
									</tr>
								</thead>
								<tbody id="country-rows"></tbody>
							</table>
						</div>
						<div class="ti-pagination" id="country-pagination" aria-label="Country results pages"></div>
					</div>
					<aside class="ti-detail" id="country-detail" aria-live="polite"></aside>
				</div>

				<section class="ti-compare" aria-labelledby="compare-title">
					<div class="ti-compare-head">
						<div>
							<p class="ti-section-label">Side by side</p>
							<h3 id="compare-title">Compare up to three countries</h3>
						</div>
						<button id="compare-clear" type="button">Clear</button>
					</div>
					<div class="ti-compare-grid" id="compare-grid"></div>
				</section>
			</section>

			<section class="ti-city-section reveal" id="cities" aria-labelledby="cities-title">
				<div class="ti-section-label">The city reality</div>
				<div class="ti-city-heading">
					<h2 id="cities-title">69 cities, where trips actually happen</h2>
					<p>National averages hide the gap between Cairo and Zurich, or New York and the rest of the United States. The city index combines a broad urban basket with country-level Big Mac evidence.</p>
				</div>

				<div class="ti-controls ti-city-controls" aria-label="City filters">
					<label class="ti-search">
						<span>Search</span>
						<input id="city-search" type="search" placeholder="City or country" autocomplete="off" />
					</label>
					<label>
						<span>Country</span>
						<select id="city-economy">
							<option value="">All countries</option>
							{cityEconomies.map((economy) => <option value={economy}>{economy}</option>)}
						</select>
					</label>
					<label>
						<span>Sort</span>
						<select id="city-sort">
							<option value="rank">Cheapest first</option>
							<option value="expensive">Most expensive first</option>
							<option value="rent">Lowest rent first</option>
							<option value="alpha">A to Z</option>
						</select>
					</label>
				</div>

				<div class="ti-resultbar"><p id="city-count" aria-live="polite">69 cities</p></div>
				<div class="ti-data-layout ti-city-layout">
					<div class="ti-table-panel">
						<div class="ti-table-scroll">
							<table class="ti-data-table">
								<thead>
									<tr>
										<th class="ti-col-rank" scope="col">Rank</th>
										<th class="ti-col-name" scope="col">City</th>
										<th class="ti-col-city-country" scope="col">Country</th>
										<th class="ti-col-price" scope="col">Price index</th>
										<th class="ti-col-grade" scope="col">Grade</th>
									</tr>
								</thead>
								<tbody id="city-rows"></tbody>
							</table>
						</div>
						<div class="ti-pagination" id="city-pagination" aria-label="City results pages"></div>
					</div>
					<aside class="ti-detail" id="city-detail" aria-live="polite"></aside>
				</div>
			</section>

			<section class="ti-method reveal" id="method" aria-labelledby="method-title">
				<div class="ti-section-label">How to read it</div>
				<div class="ti-method-body">
					<h2 id="method-title">A compass, not a quote from a hotel desk</h2>
					<div class="ti-method-grid">
						<article>
							<span>01</span>
							<h3>What is measured</h3>
							<p>A U.S. dollar-facing consumer price index, anchored to the United States at 100. It combines Deutsche Bank and Numbeo city baskets, standardized Big Mac prices, and World Bank national indicators.</p>
						</article>
						<article>
							<span>02</span>
							<h3>What is estimated</h3>
							<p>Forty-six countries have direct 2026 anchors. The rest are causal projections or peer proxies. Grade A means observed. Grades B through E carry progressively more uncertainty.</p>
						</article>
						<article>
							<span>03</span>
							<h3>What is excluded</h3>
							<p>International airfare, visas, safety, scarcity, seasonal hotel spikes, and the value of the experience. City rent is a directional accommodation signal, not a nightly hotel estimate.</p>
						</article>
					</div>

					<div class="ti-warning">
						<strong>Cheap can be misleading.</strong>
						<p>Conflict economies and countries with parallel exchange rates can appear artificially inexpensive in dollars while travelers face shortages, restricted access, or prices unavailable at the modeled rate. Treat grade C, D, and E results as broad bands.</p>
					</div>

					<details>
						<summary>Technical notes and model limits</summary>
						<div class="ti-details-copy">
							<p>The visitor model has a 9.1% leave-one-country-out mean absolute percentage error and a log R² of 0.912. Country rank intervals show the modeled 80% range. Neighboring positions are rarely meaningfully different.</p>
							<p>Moderate inflation has a confidence interval that crosses zero. Housing supply, taxes, tourism, migration, energy policy, conflict, and informal prices are not fully identified. Big Mac sources also use different collection channels, including in-store, delivery, and secondary data.</p>
							<p>Resident affordability is shown only as context in country detail panels. It uses modeled local cost-to-wage ratios and is less precise than the tourist index.</p>
						</div>
					</details>

					<div class="ti-sources">
						<h3>Sources</h3>
						<p>
							<a href="https://www.dbresearch.com/PROD/RPS_EN-PROD/Mapping_the_World_s_Prices_2026/RPS_EN_DOC_VIEW.calias?rwnode=PROD0000000000435631&amp;ProdCollection=PROD0000000000543811">Deutsche Bank, Mapping the World's Prices 2026</a> ·
							<a href="https://github.com/TheEconomist/big-mac-data">The Economist Big Mac data</a> ·
							<a href="https://data.worldbank.org/indicator/PA.NUS.PRVT.PP">World Bank household price levels</a> ·
							<a href="https://data.worldbank.org/indicator/FP.CPI.TOTL.ZG">World Bank inflation</a> ·
							<a href="https://www.un.org/en/about-us/member-states">United Nations country universe</a>
						</p>
					</div>
				</div>
			</section>
		</main>

		<footer class="ti-footer">
			<a href="/blog/">More writing</a>
			<span>© 2026 Jack Maguire</span>
			<a href="#top" id="back-top">Back to top ↑</a>
		</footer>

		<script id="affordability-data" type="application/json" set:html={payload}></script>
		<script is:inline>
			(() => {
				const source = document.getElementById('affordability-data');
				if (!source) return;
				const data = JSON.parse(source.textContent || '{}');
				const countries = data.countries || [];
				const cities = data.cities || [];
				const pageSize = 20;
				let countryPage = 1;
				let cityPage = 1;
				let selectedCountry = 'EGY';
				let selectedCity = 'Cairo';
				let comparison = ['EGY', 'IND', 'IDN'];

				const $ = (id) => document.getElementById(id);
				const safe = (value) => String(value ?? '')
					.replaceAll('&', '&amp;')
					.replaceAll('<', '&lt;')
					.replaceAll('>', '&gt;')
					.replaceAll('"', '&quot;')
					.replaceAll("'", '&#039;');
				const number = (value, digits = 1) => value == null || Number.isNaN(Number(value)) ? 'n/a' : Number(value).toFixed(digits);
				const signed = (value) => value == null || Number.isNaN(Number(value)) ? 'n/a' : `${Number(value) > 0 ? '+' : ''}${Number(value).toFixed(1)}%`;
				const gradeClass = (grade) => `ti-grade ti-grade-${String(grade).toLowerCase()}`;
				const evidenceLabel = (row) => row.projection_confidence === 'A' ? 'Observed 2026 anchor' : row.score_type;
				const confidenceText = { A: 'Observed', B: 'Strong projection', C: 'Use caution', D: 'Weak projection', E: 'Peer proxy' };
				const countryByIso = new Map(countries.map((row) => [row.iso3, row]));

				function priceBandMatch(value, band) {
					if (!band) return true;
					if (band === 'under40') return value < 40;
					if (band === '40to60') return value >= 40 && value < 60;
					if (band === '60to80') return value >= 60 && value < 80;
					if (band === '80to100') return value >= 80 && value < 100;
					return value >= 100;
				}

				function renderPagination(element, current, totalPages, onPage) {
					if (!element) return;
					if (totalPages <= 1) {
						element.innerHTML = '';
						return;
					}
					const pages = [...new Set([1, current - 1, current, current + 1, totalPages].filter((page) => page >= 1 && page <= totalPages))];
					const controls = [];
					controls.push(`<button type="button" data-page="${current - 1}" ${current === 1 ? 'disabled' : ''}>Previous</button>`);
					let prior = 0;
					pages.forEach((page) => {
						if (prior && page - prior > 1) controls.push('<span>…</span>');
						controls.push(`<button type="button" data-page="${page}" class="${page === current ? 'is-current' : ''}" aria-current="${page === current ? 'page' : 'false'}">${page}</button>`);
						prior = page;
					});
					controls.push(`<button type="button" data-page="${current + 1}" ${current === totalPages ? 'disabled' : ''}>Next</button>`);
					element.innerHTML = controls.join('');
					element.querySelectorAll('button[data-page]').forEach((button) => button.addEventListener('click', () => onPage(Number(button.dataset.page))));
				}

				function countryDetail(row) {
					const warning = row.parallel_fx_flag || ['C', 'D', 'E'].includes(row.projection_confidence);
					return `
						<div class="ti-detail-topline"><span>Country profile</span><span class="${gradeClass(row.projection_confidence)}">${safe(row.projection_confidence)}</span></div>
						<h3>${safe(row.country)}</h3>
						<p class="ti-detail-region">${safe(row.region)} · ${safe(row.income_group)}</p>
						<div class="ti-detail-score">
							<div><strong>#${safe(row.visitor_rank_cheapest)}</strong><span>of 195</span></div>
							<div><strong>${number(row.visitor_price_us100)}</strong><span>price index</span></div>
						</div>
						<p class="ti-basket-copy">A comparable U.S. basket priced at $100 is modeled at <strong>$${number(row.visitor_price_us100)}</strong> here.</p>
						${warning ? `<div class="ti-inline-warning"><strong>${safe(confidenceText[row.projection_confidence])}.</strong> ${row.parallel_fx_flag ? 'Official and market exchange rates may diverge.' : 'Use the rank range, not the exact position.'}</div>` : ''}
						<dl class="ti-detail-list">
							<div><dt>80% rank range</dt><dd>${safe(row.visitor_rank_p10)} to ${safe(row.visitor_rank_p90)}</dd></div>
							<div><dt>Evidence</dt><dd>${safe(evidenceLabel(row))}</dd></div>
							<div><dt>Price source</dt><dd>${safe(row.pli_source)}</dd></div>
							<div><dt>Base year</dt><dd>${safe(row.base_pli_year ?? 'n/a')}</dd></div>
							<div><dt>Recent inflation</dt><dd>${signed(row.last_inflation_pct)}</dd></div>
							<div><dt>FX appreciation</dt><dd>${signed(row.last_fx_appreciation_pct)}</dd></div>
							<div><dt>Imputed inputs</dt><dd>${safe(row.input_imputation_count)}</dd></div>
							<div><dt>Resident context</dt><dd>#${safe(row.resident_rank_most_affordable)} · ${number(row.resident_affordability_us100)}</dd></div>
						</dl>
						<div class="ti-contributions">
							<p>Latest modeled contributions</p>
							<span>FX ${number(row.visitor_fx_contribution_pp)} pp</span>
							<span>Moderate inflation ${number(row.visitor_moderate_inflation_contribution_pp)} pp</span>
							<span>High inflation ${number(row.visitor_high_inflation_contribution_pp)} pp</span>
						</div>`;
				}

				function getFilteredCountries() {
					const query = $('country-search').value.trim().toLowerCase();
					const region = $('country-region').value;
					const evidence = $('country-evidence').value;
					const confidence = $('country-confidence').value;
					const band = $('country-band').value;
					const sort = $('country-sort').value;
					const rows = countries.filter((row) => {
						const basisMatches = !evidence || (evidence === 'observed' && row.projection_confidence === 'A') || (evidence === 'projected' && row.score_type.includes('projection')) || (evidence === 'proxy' && row.score_type.includes('proxy'));
						return (!query || row.country.toLowerCase().includes(query)) && (!region || row.region === region) && basisMatches && (!confidence || row.projection_confidence === confidence) && priceBandMatch(row.visitor_price_us100, band);
					});
					rows.sort((a, b) => {
						if (sort === 'expensive') return b.visitor_price_us100 - a.visitor_price_us100;
						if (sort === 'confidence') return a.projection_confidence.localeCompare(b.projection_confidence) || a.visitor_rank_cheapest - b.visitor_rank_cheapest;
						if (sort === 'alpha') return a.country.localeCompare(b.country);
						return a.visitor_rank_cheapest - b.visitor_rank_cheapest;
					});
					return rows;
				}

				function renderCountries() {
					const rows = getFilteredCountries();
					const pages = Math.max(1, Math.ceil(rows.length / pageSize));
					countryPage = Math.min(countryPage, pages);
					const visible = rows.slice((countryPage - 1) * pageSize, countryPage * pageSize);
					$('country-count').textContent = `${rows.length} destination${rows.length === 1 ? '' : 's'}`;
					$('country-rows').innerHTML = visible.length ? visible.map((row) => `
						<tr data-iso="${safe(row.iso3)}" class="${selectedCountry === row.iso3 ? 'is-selected' : ''} ${['D', 'E'].includes(row.projection_confidence) ? 'is-caution' : ''}" tabindex="0" aria-label="View ${safe(row.country)} details">
							<td class="ti-rank-cell ti-col-rank">${safe(row.visitor_rank_cheapest)}</td>
							<td class="ti-col-name"><strong>${safe(row.country)}</strong><small>${safe(row.region)}</small></td>
							<td class="ti-col-price"><span class="ti-index-value">${number(row.visitor_price_us100)}</span><span class="ti-mini-bar"><i style="width:${Math.min(100, row.visitor_price_us100 / 1.3)}%"></i></span></td>
							<td class="ti-col-range">${safe(row.visitor_rank_p10)} to ${safe(row.visitor_rank_p90)}</td>
							<td class="ti-col-grade"><span class="${gradeClass(row.projection_confidence)}">${safe(row.projection_confidence)}</span></td>
							<td class="ti-col-compare"><label class="ti-check" title="Add to comparison"><input type="checkbox" data-compare="${safe(row.iso3)}" ${comparison.includes(row.iso3) ? 'checked' : ''} /><span>+</span></label></td>
						</tr>`).join('') : '<tr><td colspan="6" class="ti-empty">No countries match those filters.</td></tr>';

					$('country-rows').querySelectorAll('tr[data-iso]').forEach((rowElement) => {
						const activate = () => {
							selectedCountry = rowElement.dataset.iso;
							const row = countryByIso.get(selectedCountry);
							$('country-detail').innerHTML = countryDetail(row);
							$('country-rows').querySelectorAll('tr').forEach((element) => element.classList.toggle('is-selected', element.dataset.iso === selectedCountry));
						};
						rowElement.addEventListener('click', (event) => { if (!event.target.closest('.ti-check')) activate(); });
						rowElement.addEventListener('keydown', (event) => { if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); activate(); } });
					});

					$('country-rows').querySelectorAll('input[data-compare]').forEach((input) => input.addEventListener('change', () => {
						const iso = input.dataset.compare;
						if (input.checked && comparison.length >= 3) {
							input.checked = false;
							return;
						}
						comparison = input.checked ? [...comparison, iso] : comparison.filter((value) => value !== iso);
						renderComparison();
					}));

					renderPagination($('country-pagination'), countryPage, pages, (page) => { countryPage = page; renderCountries(); $('rankings').scrollIntoView({ behavior: 'smooth', block: 'start' }); });
				}

				function renderComparison() {
					const target = $('compare-grid');
					const selected = comparison.map((iso) => countryByIso.get(iso)).filter(Boolean);
					if (!selected.length) {
						target.innerHTML = '<p class="ti-empty-compare">Use the + controls in the table to add destinations.</p>';
						return;
					}
					target.innerHTML = selected.map((row) => `
						<article>
							<button type="button" data-remove="${safe(row.iso3)}" aria-label="Remove ${safe(row.country)}">×</button>
							<p class="ti-compare-rank">#${safe(row.visitor_rank_cheapest)} of 195</p>
							<h4>${safe(row.country)}</h4>
							<div class="ti-compare-price"><strong>${number(row.visitor_price_us100)}</strong><span>U.S. = 100</span></div>
							<div class="ti-compare-bar"><span style="width:${Math.min(100, row.visitor_price_us100 / 1.3)}%"></span><i style="left:${Math.min(100, 100 / 1.3)}%"></i></div>
							<p>${row.visitor_price_us100 < 100 ? `${number(100 - row.visitor_price_us100, 0)}% below the U.S. benchmark` : `${number(row.visitor_price_us100 - 100, 0)}% above the U.S. benchmark`}</p>
							<span class="${gradeClass(row.projection_confidence)}">Grade ${safe(row.projection_confidence)}</span>
						</article>`).join('');
					target.querySelectorAll('button[data-remove]').forEach((button) => button.addEventListener('click', () => {
						comparison = comparison.filter((iso) => iso !== button.dataset.remove);
						renderComparison();
						renderCountries();
					}));
				}

				function cityDetail(row) {
					return `
						<div class="ti-detail-topline"><span>City profile</span><span class="${gradeClass(row.confidence)}">${safe(row.confidence)}</span></div>
						<h3>${safe(row.city)}</h3>
						<p class="ti-detail-region">${safe(row.economy)}</p>
						<div class="ti-detail-score">
							<div><strong>#${safe(row.robust_city_rank_cheapest)}</strong><span>of 69</span></div>
							<div><strong>${number(row.robust_city_price_us100)}</strong><span>price index</span></div>
						</div>
						<p class="ti-basket-copy">A comparable U.S. urban basket priced at $100 is estimated at <strong>$${number(row.robust_city_price_us100)}</strong> here.</p>
						<dl class="ti-detail-list">
							<div><dt>One-bedroom rent</dt><dd>$${number(row.rent1, 0)} / month</dd></div>
							<div><dt>Grocery index</dt><dd>${number(row.groceries)}</dd></div>
							<div><dt>Utilities index</dt><dd>${number(row.utilities)}</dd></div>
							<div><dt>Country Big Mac check</dt><dd>${number(row.bigmac_consensus_us100)}</dd></div>
							<div><dt>DB basket rank</dt><dd>#${safe(row.db_city_rank_cheapest)}</dd></div>
							<div><dt>Evidence adjustment</dt><dd>${Number(row.rank_change_vs_db) > 0 ? '+' : ''}${safe(row.rank_change_vs_db)} places cheaper</dd></div>
						</dl>
						<div class="ti-inline-note">Rent is a directional accommodation factor. It is not a hotel-night estimate.</div>`;
				}

				function getFilteredCities() {
					const query = $('city-search').value.trim().toLowerCase();
					const economy = $('city-economy').value;
					const sort = $('city-sort').value;
					const rows = cities.filter((row) => (!query || `${row.city} ${row.economy}`.toLowerCase().includes(query)) && (!economy || row.economy === economy));
					rows.sort((a, b) => {
						if (sort === 'expensive') return b.robust_city_price_us100 - a.robust_city_price_us100;
						if (sort === 'rent') return a.rent1 - b.rent1;
						if (sort === 'alpha') return a.city.localeCompare(b.city);
						return a.robust_city_rank_cheapest - b.robust_city_rank_cheapest;
					});
					return rows;
				}

				function renderCities() {
					const rows = getFilteredCities();
					const pages = Math.max(1, Math.ceil(rows.length / pageSize));
					cityPage = Math.min(cityPage, pages);
					const visible = rows.slice((cityPage - 1) * pageSize, cityPage * pageSize);
					$('city-count').textContent = `${rows.length} cit${rows.length === 1 ? 'y' : 'ies'}`;
					$('city-rows').innerHTML = visible.length ? visible.map((row) => `
						<tr data-city="${safe(row.city)}" class="${selectedCity === row.city ? 'is-selected' : ''}" tabindex="0" aria-label="View ${safe(row.city)} details">
							<td class="ti-rank-cell ti-col-rank">${safe(row.robust_city_rank_cheapest)}</td>
							<td class="ti-col-name"><strong>${safe(row.city)}</strong><small class="ti-mobile-only">${safe(row.economy)}</small></td>
							<td class="ti-col-city-country">${safe(row.economy)}</td>
							<td class="ti-col-price"><span class="ti-index-value">${number(row.robust_city_price_us100)}</span><span class="ti-mini-bar"><i style="width:${Math.min(100, row.robust_city_price_us100 / 1.3)}%"></i></span></td>
							<td class="ti-col-grade"><span class="${gradeClass(row.confidence)}">${safe(row.confidence)}</span></td>
						</tr>`).join('') : '<tr><td colspan="5" class="ti-empty">No cities match those filters.</td></tr>';
					$('city-rows').querySelectorAll('tr[data-city]').forEach((rowElement) => {
						const activate = () => {
							selectedCity = rowElement.dataset.city;
							const row = cities.find((item) => item.city === selectedCity);
							$('city-detail').innerHTML = cityDetail(row);
							$('city-rows').querySelectorAll('tr').forEach((element) => element.classList.toggle('is-selected', element.dataset.city === selectedCity));
						};
						rowElement.addEventListener('click', activate);
						rowElement.addEventListener('keydown', (event) => { if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); activate(); } });
					});
					renderPagination($('city-pagination'), cityPage, pages, (page) => { cityPage = page; renderCities(); $('cities').scrollIntoView({ behavior: 'smooth', block: 'start' }); });
				}

				['country-search', 'country-region', 'country-evidence', 'country-confidence', 'country-band', 'country-sort'].forEach((id) => {
					$(id).addEventListener(id.includes('search') ? 'input' : 'change', () => { countryPage = 1; renderCountries(); });
				});
				['city-search', 'city-economy', 'city-sort'].forEach((id) => {
					$(id).addEventListener(id.includes('search') ? 'input' : 'change', () => { cityPage = 1; renderCities(); });
				});
				$('compare-clear').addEventListener('click', () => { comparison = []; renderComparison(); renderCountries(); });
				$('back-top').addEventListener('click', (event) => { event.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); });

				$('country-detail').innerHTML = countryDetail(countryByIso.get(selectedCountry));
				$('city-detail').innerHTML = cityDetail(cities.find((row) => row.city === selectedCity));
				renderCountries();
				renderComparison();
				renderCities();

				if ('IntersectionObserver' in window) {
					const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					}), { threshold: 0.08 });
					document.querySelectorAll('.reveal').forEach((element) => observer.observe(element));
				} else {
					document.querySelectorAll('.reveal').forEach((element) => element.classList.add('is-visible'));
				}
			})();
		</script>
	</body>
</html>

