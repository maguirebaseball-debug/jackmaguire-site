const title = "25 Ingredient Pairings That Should Exist But Don't";
const description = "I ran 294,000 recipes and the FooDB flavor compound database through a statistical analysis to find ingredient pairs with strong chemical compatibility and near-zero co-occurrence. These are the gaps between what chemistry predicts and what cooks actually do.";
const pubDate = "May 27, 2026";

