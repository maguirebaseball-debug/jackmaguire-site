---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const lastUpdated = 'July 2026';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Now: ${SITE_TITLE}`} description="Jack Maguire is a performance marketing consultant based in East Village, NYC. Current work, reading, and travel notes updated regularly." />
	</head>
	<body>
		<Header />
		<main>
			<section class="now-lede">
				<p class="kicker">Current coordinates</p>
				<h1>Now</h1>
				<p>East Village work, reading, and travel notes as of {lastUpdated}.</p>
			</section>

			<div class="prose">
				<h2>Location</h2>
				<p>East Village, New York City.</p>

				<h2>Work</h2>
				<p>I am looking for a senior paid social or growth role where I can build the testing, measurement, and creative systems behind profitable acquisition. I am especially interested in businesses where channel performance connects to real unit economics, not just platform metrics.</p>

				<h2>Reading</h2>
                                <p>Revisiting existentialist philosophy and theology, alongside narrative history and behavioral economics.</p>

                                <h2>Thinking about</h2>
				<p><strong>AI in practical work.</strong> I am interested in using AI to make creative testing, analysis, and reporting faster without losing the judgment that makes the work useful.</p>

				<h2>Travel</h2>
				<p>Back in the East Village after a spring trip through Central Europe. No next trip is booked yet.</p>
			</div>

			<p class="note"><em>This is a <a href="https://nownpage.org" target="_blank">/now page</a>. It reflects what I'm actually doing, not what I've done.</em></p>
		</main>
		<Footer />
	</body>
</html>

<style>
	.updated {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin-top: -0.5em;
		margin-bottom: 2em;
	}
	.now-lede {
		margin-bottom: 2rem;
		padding: 1.25rem 0 1.5rem;
		border-bottom: 1px solid rgba(85, 107, 47, 0.22);
	}
	.kicker {
		margin: 0 0 0.45rem;
		font-family: var(--font-ui), sans-serif;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent-dark);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.now-lede p:last-child {
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	.prose h2 {
		font-size: 1.1em;
		margin-top: 1.5em;
		margin-bottom: 0.3em;
	}
	.note {
		margin-top: 3em;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
</style>
