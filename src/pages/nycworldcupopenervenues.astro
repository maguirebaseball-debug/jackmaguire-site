---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import venues from '../data/worldcup_venues.json';

const title = "NYC Watch Parties: FIFA World Cup 2026";
const description = "Verified venues and fan zones for the 2026 World Cup in New York City.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <style>
    :root {
      --fifa-green: #556B2F; /* Olive Green as per site guidelines */
      --fifa-dark-green: #3A4B1F;
      --text-dark: #111;
      --bg-white: #ffffff;
      --bg-gray: #f9f9f9;
      --border-gray: #ececec;
    }

    body {
      background-color: var(--bg-white);
      color: var(--text-dark);
      margin: 0;
      padding: 0;
    }

    .fifa-header {
      background: var(--fifa-green);
      color: white;
      padding: 3rem 2rem;
      text-align: center;
      border-bottom: 8px solid var(--fifa-dark-green);
    }

    .fifa-header h1 {
      font-size: 2.5rem;
      margin: 0;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .fifa-header p {
      font-size: 1.2rem;
      margin-top: 1rem;
      opacity: 0.9;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    .controls {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .controls input, .controls select {
      padding: 0.75rem 1rem;
      font-size: 1rem;
      border: 1px solid var(--border-gray);
      border-radius: 4px;
      flex: 1;
      min-width: 250px;
      font-family: inherit;
    }

    .controls input:focus, .controls select:focus {
      outline: none;
      border-color: var(--fifa-green);
    }

    .table-responsive {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th, td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-gray);
    }

    th {
      background-color: var(--bg-gray);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.85rem;
      color: var(--fifa-dark-green);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }

    th:hover {
      background-color: #eee;
    }

    tr:hover {
      background-color: #fafafa;
    }

    .venue-name {
      font-weight: 700;
      color: var(--fifa-dark-green);
    }

    .description-cell {
      min-width: 300px;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <Header />

  <div class="fifa-header">
    <h1>World Cup '26 Venues</h1>
    <p>Find the perfect neighborhood spot for the opening matches</p>
  </div>

  <div class="container">
    <div class="controls">
      <input type="text" id="searchInput" placeholder="Search venues, vibes, or descriptions...">
      <select id="neighborhoodFilter">
        <option value="">All Neighborhoods</option>
      </select>
    </div>

    <div class="table-responsive">
      <table id="venueTable">
        <thead>
          <tr>
            <th data-sort="venue_name">Venue Name ⇕</th>
            <th data-sort="neighborhood">Neighborhood ⇕</th>
            <th data-sort="featured_match">Featured Match ⇕</th>
            <th data-sort="event_vibe">Vibe ⇕</th>
            <th data-sort="specials">Specials ⇕</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- Rows rendered by JS -->
        </tbody>
      </table>
    </div>
  </div>

  <Footer />

  <script id="venue-data" type="application/json" set:html={JSON.stringify(venues)}></script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const dataScript = document.getElementById("venue-data");
      if (!dataScript) return;
      
      const venues = JSON.parse(dataScript.textContent);
      const tableBody = document.getElementById("tableBody");
      const searchInput = document.getElementById("searchInput");
      const neighborhoodFilter = document.getElementById("neighborhoodFilter");
      const headers = document.querySelectorAll("th[data-sort]");

      let currentSort = { column: null, asc: true };

      // Populate neighborhood dropdown
      const neighborhoods = [...new Set(venues.map(v => v.neighborhood).filter(Boolean))].sort();
      neighborhoods.forEach(hood => {
        const option = document.createElement("option");
        option.value = hood;
        option.textContent = hood;
        neighborhoodFilter.appendChild(option);
      });

      function renderTable(data) {
        tableBody.innerHTML = "";
        data.forEach(venue => {
          const tr = document.createElement("tr");
          tr.innerHTML = `
            <td class="venue-name">${venue.venue_name || ''}</td>
            <td>${venue.neighborhood || ''}</td>
            <td>${venue.featured_match || ''}</td>
            <td>${venue.event_vibe || ''}</td>
            <td>${venue.specials || ''}</td>
            <td class="description-cell">${venue.description || ''}</td>
          `;
          tableBody.appendChild(tr);
        });
      }

      function filterAndSort() {
        const query = searchInput.value.toLowerCase();
        const hood = neighborhoodFilter.value;

        let filtered = venues.filter(v => {
          const matchesSearch = Object.values(v).some(val => 
            String(val).toLowerCase().includes(query)
          );
          const matchesHood = hood === "" || v.neighborhood === hood;
          return matchesSearch && matchesHood;
        });

        if (currentSort.column) {
          filtered.sort((a, b) => {
            const valA = String(a[currentSort.column] || '').toLowerCase();
            const valB = String(b[currentSort.column] || '').toLowerCase();
            if (valA < valB) return currentSort.asc ? -1 : 1;
            if (valA > valB) return currentSort.asc ? 1 : -1;
            return 0;
          });
        }

        renderTable(filtered);
      }

      searchInput.addEventListener("input", filterAndSort);
      neighborhoodFilter.addEventListener("change", filterAndSort);

      headers.forEach(th => {
        th.addEventListener("click", () => {
          const col = th.getAttribute("data-sort");
          if (currentSort.column === col) {
            currentSort.asc = !currentSort.asc;
          } else {
            currentSort.column = col;
            currentSort.asc = true;
          }
          filterAndSort();
        });
      });

      // Initial render
      filterAndSort();
    });
  </script>
</body>
</html>
