		color: var(--ledger-ink-soft);
	}
	.hero-cta {
		display: inline-block;
		font-family: 'JetBrains Mono', ui-monospace, Menlo, monospace;
		font-weight: 700;
		font-size: 0.88em;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--ledger-ink);
