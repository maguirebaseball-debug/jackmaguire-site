---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Resume System — For Vince";
const description = "An interactive walkthrough of how Jack Maguire generates tailored, ATS-optimized resumes using a structured AI-assisted workflow.";
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <style>
    :root {
      --green: #556B2F;
      --green-dark: #3A4B1C;
      --green-light: #eef2e6;
      --paper: #fbfaf6;
      --paper-warm: #f5efe3;
      --ink: #22293A;
      --muted: #60739F;
      --border: rgba(85,107,47,0.18);
      --shadow: 0 2px 12px rgba(85,107,47,0.10);
    }

    * { box-sizing: border-box; }

    .rs-wrap {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1.25rem 4rem;
      font-family: Verdana, Tahoma, Geneva, sans-serif;
      color: var(--ink);
    }

    /* ── Hero ── */
    .rs-hero {
      text-align: center;
      padding: 3rem 0 2.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2.5rem;
    }
    .rs-hero-label {
      display: inline-block;
      background: var(--green-light);
      color: var(--green-dark);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border-radius: 2rem;
      margin-bottom: 1rem;
    }
    .rs-hero h1 {
      font-size: clamp(1.6rem, 4vw, 2.3rem);
      font-weight: 700;
      line-height: 1.2;
      margin: 0 0 0.75rem;
      color: var(--ink);
    }
    .rs-hero p {
      font-size: 0.97rem;
      color: #4a5568;
      max-width: 580px;
      margin: 0 auto;
      line-height: 1.65;
    }

    /* ── Stats row ── */
    .rs-stats {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2.75rem;
    }
    .rs-stat {
      background: var(--paper-warm);
      border: 1px solid var(--border);
      border-radius: 0.6rem;
      padding: 0.85rem 1.25rem;
      text-align: center;
      min-width: 120px;
    }
    .rs-stat-n {
      display: block;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--green);
      line-height: 1;
    }
    .rs-stat-l {
      font-size: 0.72rem;
      color: #607050;
      margin-top: 0.25rem;
      display: block;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ── Section title ── */
    .rs-section-title {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 1.1rem;
    }

    /* ── Pipeline flow ── */
    .rs-pipeline {
      position: relative;
      margin-bottom: 3rem;
    }
    .rs-pipeline-track {
      position: absolute;
      left: 22px;
      top: 28px;
      bottom: 28px;
      width: 2px;
      background: linear-gradient(to bottom, var(--green), var(--green-light));
      border-radius: 2px;
    }
    .rs-step {
      display: flex;
      gap: 1.1rem;
      margin-bottom: 1rem;
      align-items: flex-start;
    }
    .rs-step-badge {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--green);
      color: #fff;
      font-size: 0.95rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 0 4px var(--paper), 0 0 0 6px var(--green-light);
      position: relative;
      z-index: 1;
    }
    .rs-step-badge.gate {
      background: #c0392b;
      box-shadow: 0 0 0 4px var(--paper), 0 0 0 6px #fddedd;
    }
    .rs-step-card {
      flex: 1;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 0.65rem;
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: border-color 0.15s;
    }
    .rs-step-card:hover {
      border-color: var(--green);
    }
    .rs-step-header {
      padding: 1rem 1.1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      user-select: none;
    }
    .rs-step-header:hover { background: var(--green-light); }
    .rs-step-title {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--ink);
      line-height: 1.3;
    }
    .rs-step-subtitle {
      font-size: 0.78rem;
      color: #607050;
      margin-top: 0.15rem;
    }
    .rs-chevron {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      color: var(--green);
      transition: transform 0.2s;
    }
    .rs-step-card.open .rs-chevron { transform: rotate(180deg); }
    .rs-step-body {
      display: none;
      padding: 0 1.1rem 1.1rem;
      border-top: 1px solid var(--border);
      font-size: 0.875rem;
      line-height: 1.65;
      color: #3a4030;
    }
    .rs-step-card.open .rs-step-body { display: block; }
    .rs-step-body p { margin: 0.65rem 0 0; }
    .rs-step-body ul {
      margin: 0.5rem 0 0;
      padding-left: 1.2rem;
    }
    .rs-step-body li { margin-bottom: 0.3rem; }
    .rs-step-body strong { color: var(--ink); }

    /* doc-chips */
    .rs-doc-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.85rem;
    }
    .rs-doc-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.35rem 0.75rem;
      background: var(--green-light);
      border: 1px solid rgba(85,107,47,0.25);
      border-radius: 0.4rem;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--green-dark);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
      text-decoration: none;
    }
    .rs-doc-chip:hover {
      background: #dde8c4;
      border-color: var(--green);
    }
    .rs-doc-chip svg { flex-shrink: 0; }

    /* gate badge */
    .rs-gate-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #fddedd;
      border: 1px solid #e07070;
      border-radius: 0.4rem;
      padding: 0.3rem 0.7rem;
      font-size: 0.76rem;
      font-weight: 700;
      color: #c0392b;
      margin-top: 0.75rem;
    }

    /* ── Docs section ── */
    .rs-docs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.85rem;
      margin-bottom: 3rem;
    }
    .rs-doc-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 0.65rem;
      padding: 1rem;
      cursor: pointer;
      transition: border-color 0.15s, box-shadow 0.15s;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .rs-doc-card:hover {
      border-color: var(--green);
      box-shadow: var(--shadow);
    }
    .rs-doc-icon {
      font-size: 1.4rem;
      line-height: 1;
    }
    .rs-doc-name {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.3;
    }
    .rs-doc-desc {
      font-size: 0.74rem;
      color: #607050;
      line-height: 1.4;
    }
    .rs-doc-open-hint {
      font-size: 0.7rem;
      color: var(--green);
      font-weight: 600;
      margin-top: auto;
      padding-top: 0.25rem;
    }

    /* ── Modal ── */
    .rs-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(20,25,20,0.6);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .rs-modal-overlay.active {
      display: flex;
    }
    .rs-modal {
      background: var(--paper);
      border-radius: 0.75rem;
      width: 100%;
      max-width: 780px;
      max-height: 88vh;
      display: flex;
      flex-direction: column;
      box-shadow: 0 12px 60px rgba(0,0,0,0.25);
    }
    .rs-modal-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .rs-modal-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--ink);
    }
    .rs-modal-close {
      background: none;
      border: none;
      cursor: pointer;
      color: #607050;
      padding: 0.25rem;
      border-radius: 0.3rem;
      display: flex;
      align-items: center;
      transition: background 0.1s;
    }
    .rs-modal-close:hover { background: var(--green-light); color: var(--green-dark); }
    .rs-modal-body {
      overflow-y: auto;
      padding: 1.25rem;
      flex: 1;
    }
    .rs-modal-body pre {
      white-space: pre-wrap;
      word-break: break-word;
      font-family: 'Courier New', Courier, monospace;
      font-size: 0.78rem;
      line-height: 1.6;
      background: #f0ede6;
      border: 1px solid var(--border);
      border-radius: 0.4rem;
      padding: 1rem;
      margin: 0;
      color: #2d3020;
    }

    /* ── Rules list ── */
    .rs-rules {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 0.65rem;
      padding: 1.25rem 1.4rem;
      margin-bottom: 3rem;
    }
    .rs-rules ul {
      margin: 0;
      padding-left: 1.2rem;
      font-size: 0.875rem;
      line-height: 1.7;
      color: #3a4030;
    }
    .rs-rules li { margin-bottom: 0.35rem; }

    @media (max-width: 600px) {
      .rs-pipeline-track { left: 19px; }
      .rs-step-badge { width: 38px; height: 38px; font-size: 0.85rem; }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="rs-wrap">

      <!-- Hero -->
      <div class="rs-hero">
        <span class="rs-hero-label">Resume System Documentation</span>
        <h1>How Jack's Resume Pipeline Works</h1>
        <p>Every resume is built fresh from the same source materials, tailored to a specific job, generated as a Word document, and visually verified before it ever touches an application form.</p>
      </div>

      <!-- Stats -->
      <div class="rs-stats">
        <div class="rs-stat">
          <span class="rs-stat-n">40+</span>
          <span class="rs-stat-l">Resumes generated</span>
        </div>
        <div class="rs-stat">
          <span class="rs-stat-n">3</span>
          <span class="rs-stat-l">Source documents</span>
        </div>
        <div class="rs-stat">
          <span class="rs-stat-n">7</span>
          <span class="rs-stat-l">Steps in the pipeline</span>
        </div>
        <div class="rs-stat">
          <span class="rs-stat-n">0</span>
          <span class="rs-stat-l">Fabricated skills</span>
        </div>
      </div>

      <!-- Source Documents -->
      <div class="rs-section-title">Source Documents (click to read)</div>
      <div class="rs-docs-grid">
        <div class="rs-doc-card" data-modal="modal-base">
          <div class="rs-doc-icon">📄</div>
          <div class="rs-doc-name">Base Resume</div>
          <div class="rs-doc-desc">Full career history. The raw content pool — never sent anywhere as-is.</div>
          <div class="rs-doc-open-hint">Click to read →</div>
        </div>
        <div class="rs-doc-card" data-modal="modal-static">
          <div class="rs-doc-icon">📐</div>
          <div class="rs-doc-name">Optimization Rules</div>
          <div class="rs-doc-desc">ATS philosophy, what to cut, how to avoid fabrication, 7-second-read principle.</div>
          <div class="rs-doc-open-hint">Click to read →</div>
        </div>
        <div class="rs-doc-card" data-modal="modal-skills">
          <div class="rs-doc-icon">🗂️</div>
          <div class="rs-doc-name">Skills Inventory</div>
          <div class="rs-doc-desc">Confirmed skills only. Anything not here stays off every resume.</div>
          <div class="rs-doc-open-hint">Click to read →</div>
        </div>
        <div class="rs-doc-card" data-modal="modal-wiki">
          <div class="rs-doc-icon">🗒️</div>
          <div class="rs-doc-name">Content Wiki</div>
          <div class="rs-doc-desc">Living log of job notes, reusable answers, and workflow decisions.</div>
          <div class="rs-doc-open-hint">Click to read →</div>
        </div>
        <div class="rs-doc-card" data-modal="modal-example-md">
          <div class="rs-doc-icon">✍️</div>
          <div class="rs-doc-name">Example Output (Gusto)</div>
          <div class="rs-doc-desc">The tailored markdown for the Gusto Senior Paid Social Lead role.</div>
          <div class="rs-doc-open-hint">Click to read →</div>
        </div>
        <div class="rs-doc-card" data-modal="modal-example-py">
          <div class="rs-doc-icon">🐍</div>
          <div class="rs-doc-name">DOCX Script (Gusto)</div>
          <div class="rs-doc-desc">The Python script that builds the Word document for that role.</div>
          <div class="rs-doc-open-hint">Click to read →</div>
        </div>
      </div>

      <!-- Pipeline -->
      <div class="rs-section-title">The 7-Step Pipeline</div>
      <div class="rs-pipeline">
        <div class="rs-pipeline-track"></div>

        <!-- Step 1 -->
        <div class="rs-step">
          <div class="rs-step-badge">1</div>
          <div class="rs-step-card" id="step1">
            <div class="rs-step-header" data-step="step1">
              <div>
                <div class="rs-step-title">Load source materials</div>
                <div class="rs-step-subtitle">Base Resume + Optimization Rules + Skills Inventory + Content Wiki</div>
              </div>
              <svg class="rs-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </div>
            <div class="rs-step-body">
              <p>Every application starts from the same three source files. A prior job-specific resume is <strong>never</strong> used as a starting point for a new application — existing tailored resumes are archival history only.</p>
              <ul>
                <li><strong>Base Resume</strong> — 12 years of career history. The raw content pool.</li>
                <li><strong>Optimization Rules</strong> — ATS and hiring-manager philosophy. The job description is the only filter.</li>
                <li><strong>Skills Inventory</strong> — Confirmed skills only. If it's not here, it doesn't go on a resume, period.</li>
                <li><strong>Content Wiki</strong> — Accumulated job notes, reusable application answers, and platform quirks.</li>
              </ul>
              <div class="rs-doc-chips">
                <a class="rs-doc-chip" data-modal="modal-base">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
                  View Base Resume
                </a>
                <a class="rs-doc-chip" data-modal="modal-skills">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  View Skills Inventory
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="rs-step">
          <div class="rs-step-badge">2</div>
          <div class="rs-step-card" id="step2">
            <div class="rs-step-header" data-step="step2">
              <div>
                <div class="rs-step-title">Extract the job description</div>
                <div class="rs-step-subtitle">Keywords, responsibilities, seniority signals, required tools</div>
              </div>
              <svg class="rs-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </div>
            <div class="rs-step-body">
              <p>Before writing a single word, the job description is broken into a checklist of every requirement, responsibility, skill, tool, and qualification it mentions. That checklist is the blueprint.</p>
              <ul>
                <li>Pull exact phrases and keywords, not paraphrases.</li>
                <li>Note the seniority level: IC contributor, manager, director, etc.</li>
                <li>Flag any required skills that are <strong>not</strong> confirmed in the Skills Inventory. Those get flagged as gaps rather than added to the resume.</li>
                <li>Note whether the role is in-house/brand-side or agency — changes which experience to lead with.</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="rs-step">
          <div class="rs-step-badge">3</div>
          <div class="rs-step-card" id="step3">
            <div class="rs-step-header" data-step="step3">
              <div>
                <div class="rs-step-title">Write the tailored markdown resume</div>
                <div class="rs-step-subtitle">Fresh file, job-specific copy, ATS keywords, no fabrication</div>
              </div>
              <svg class="rs-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </div>
            <div class="rs-step-body">
              <p>A new <code>.md</code> file is created, named for the company and role. The resume is assembled from the base content with strict rules on what makes the cut:</p>
              <ul>
                <li>Only bullets that map directly to the job posting blueprint are kept.</li>
                <li>The summary is rewritten entirely from scratch for each role.</li>
                <li>Most recent role: ~6 bullets. Second role: ~3 bullets. Older roles: 1-2 bullets or a single title/date line.</li>
                <li>Exact job-description keywords are used where truthful. No flowery language, no AI-sounding filler words.</li>
                <li>No skills, tools, or platforms that are not in the Skills Inventory, even if the posting asks for them.</li>
                <li>Location formatted as <code>New York, New York</code>. No em dashes anywhere.</li>
              </ul>
              <div class="rs-doc-chips">
                <a class="rs-doc-chip" data-modal="modal-example-md">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
                  See Gusto example output
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="rs-step">
          <div class="rs-step-badge">4</div>
          <div class="rs-step-card" id="step4">
            <div class="rs-step-header" data-step="step4">
              <div>
                <div class="rs-step-title">Generate the DOCX via Python</div>
                <div class="rs-step-subtitle">python-docx script, ATS-safe layout, single-column, no decorative elements</div>
              </div>
              <svg class="rs-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </div>
            <div class="rs-step-body">
              <p>Each resume has a paired Python script that builds a Word document using the <code>python-docx</code> library. The content is hardcoded in the script, and running it outputs the final <code>.docx</code>. The formatting spec is fixed:</p>
              <ul>
                <li><strong>Font:</strong> Arial, 10.5pt body, 22pt name, 10.5pt bold section headers</li>
                <li><strong>Margins:</strong> 0.6–0.65 inches (tighter than default to fit content without shrinking text)</li>
                <li><strong>Layout:</strong> Single-column only. No tables, text boxes, sidebars, images, or decorative lines.</li>
                <li><strong>Bullets:</strong> Standard round bullets via Word's <code>List Bullet</code> style</li>
                <li><strong>Section heads:</strong> All-caps, bold — SUMMARY, SKILLS, EXPERIENCE, EDUCATION</li>
                <li><strong>Line spacing:</strong> 1.0 throughout with tight paragraph spacing (0-3pt before/after)</li>
              </ul>
              <div class="rs-doc-chips">
                <a class="rs-doc-chip" data-modal="modal-example-py">
