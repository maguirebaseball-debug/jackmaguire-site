---
import BaseHead from '../components/BaseHead.astro';
import analysis from '../data/tyler-retro-analysis.json';
import guestForecast from '../data/tyler-guest-forecast.json';

const title = 'What Makes a Conversations with Tyler Episode Work';
const description = 'A seven-year retrospective of audience reach, audience love, Tyler Cowen’s favorite conversations, and a 2026 forecast of who should come next.';
const canonical = 'https://jackmaguire.org/tylercowen-retro/';

const yearlyLeaders = [
  { year: '2019', top: 'Jordan Peterson', loved: 'Knausgård', tyler: 'Knausgård', note: 'The rare literary episode that Tyler called the CWT highlight of the year.' },
  { year: '2020', top: 'Matt Yglesias', loved: 'John Brennan', tyler: 'John Brennan', note: 'The UFO exchange made Brennan Tyler’s personal highlight.' },
  { year: '2021', top: 'Amia Srinivasan', loved: 'Amia Srinivasan', tyler: 'Amia Srinivasan', note: 'Polarizing, highly retained, and one of Tyler’s favorites.' },
  { year: '2022', top: 'Thomas Piketty', loved: 'Mary Gaitskill', tyler: 'Vaughn Smith / Roy Foster', note: 'Debate pulled downloads. Genuineness created the more durable signal.' },
  { year: '2023', top: 'Paul Graham', loved: 'Lazarus Lake', tyler: 'Lazarus Lake / Katherine Rundell', note: 'Lazarus Lake became the clearest audience-love episode in the sample.' },
  { year: '2024', top: 'Peter Thiel', loved: 'Stephen Kotkin', tyler: 'Stephen Kotkin', note: 'A history conversation entered the pantheon immediately.' },
  { year: '2025', top: 'Sam Altman', loved: 'David Commins', tyler: 'Any Austin / Donald Lopez', note: 'Commins is the year’s most useful outlier.' },
];

const measuredDimensions = analysis.dimensions.filter((dimension) => dimension.state === 'coded' && !dimension.sparse);
const topEffects = (outcome: 'acquisition' | 'affection' | 'tyler') => measuredDimensions
  .filter((dimension) => !dimension.effects![outcome].notApplicable)
  .map((dimension) => ({
    label: dimension.label,
    value: dimension.effects![outcome].differencePp,
    interval: dimension.effects![outcome].interval80,
  }))
  .sort((left, right) => Math.abs(right.value) - Math.abs(left.value))
  .slice(0, 7);
const viewEffects = topEffects('acquisition');
const loveEffects = topEffects('affection');
const tylerEffects = topEffects('tyler');
const outcomeByKey = Object.fromEntries(analysis.outcomes.map((outcome) => [outcome.key, outcome]));
const displayPp = (value: number) => `${value >= 0 ? '+' : ''}${value}pp`;
const displayInterval = (interval: number[] | null) => interval ? `[${interval[0]}, ${interval[1]}]` : 'sparse';

const outliers = [
  { name: 'David Commins', year: '2025', x: 39, y: 86, quote: 'Tyler expected a Saudi Arabia episode to be near the bottom. It finished seventh.' },
  { name: 'Lazarus Lake', year: '2023', x: 26, y: 93, quote: 'Unusual life, warmth, competition, and a premise that travelled by recommendation.' },
  { name: 'Amia Srinivasan', year: '2021', x: 91, y: 82, quote: 'Conflict did not create abandonment. It created retention.' },
  { name: 'Stephen Kotkin', year: '2024', x: 43, y: 90, quote: 'The all-timer pattern: serious prep, difficult material, and obvious host pleasure.' },
  { name: 'Sam Altman', year: '2025', x: 97, y: 59, quote: 'The clearest acquisition win, with a different mechanism from attachment.' },
  { name: 'Masaaki Suzuki', year: '2024', x: 18, y: 71, quote: 'A specialist Bach episode that exposes how subject knowledge and accent can shape starts.' },
];

const audienceGuests = guestForecast.audience_top_25;
const tylerGuests = guestForecast.tyler_top_25;
const overlapGuests = guestForecast.overlap;
const audienceNames = new Set(audienceGuests.map((guest) => guest.guest));
const tylerNames = new Set(tylerGuests.map((guest) => guest.guest));
const audienceOnly = audienceGuests.filter((guest) => !tylerNames.has(guest.guest));
const tylerOnly = tylerGuests.filter((guest) => !audienceNames.has(guest.guest));
const guestsByName = new Map([...audienceGuests, ...tylerGuests].map((guest) => [guest.guest, guest]));
const firstOutreach = ['Michael Levin', 'John Jumper', 'Max Martin', 'Sarah Paine', 'Lisa Su', 'Kevin Esvelt'].map((name) => guestsByName.get(name)!);
const audienceWeights = [
  { label: 'Reach', value: 24 }, { label: 'Expertise depth', value: 22 }, { label: 'Single-subject coherence', value: 18 },
  { label: 'Current relevance', value: 16 }, { label: 'Candor', value: 12 }, { label: 'Novelty', value: 8 },
];
const tylerWeights = [
  { label: 'Expertise depth', value: 29 }, { label: 'Idiosyncrasy', value: 22 }, { label: 'Preparation payoff', value: 18 },
  { label: 'Intellectual range', value: 13 }, { label: 'Current relevance', value: 10 }, { label: 'Anticipated rapport', value: 8 },
];

---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogImage="/tylercowen-retro-og.png" />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content="2026-07-17" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      datePublished: '2026-07-17',
      author: { '@type': 'Person', name: 'Jack Maguire' },
      mainEntityOfPage: canonical,
    })} />
  </head>
  <body class="retro-body">
    <main class="retro-page" id="top">
      <nav class="retro-nav">
        <a href="/">JACK MAGUIRE</a>
        <span>FIELD NOTE 07.17.26</span>
        <a href="#method">METHOD</a>
      </nav>

      <section class="hero">
        <p class="eyebrow">CONVERSATIONS WITH TYLER / 2019-2025</p>
        <h1>Celebrity opens<br />the door.<br /><em>Specificity</em> earns<br />the room.</h1>
        <div class="hero-bottom">
          <p>A seven-year read of which conversations attracted the largest audience, which became loved, and which Tyler himself found most alive.</p>
          <dl>
            <div><dt>07</dt><dd>retrospectives</dd></div>
            <div><dt>{analysis.panel.rows}</dt><dd>retrospective mentions</dd></div>
            <div><dt>{analysis.dimensions.length}</dt><dd>pre-registered dimensions</dd></div>
          </dl>
        </div>
      </section>

      <section class="thesis">
        <p class="section-label">THE MAIN FINDING</p>
        <div>
          <h2>There are three different ways for an episode to work.</h2>
          <p class="lede">The evidence supports a narrower claim than the first version made. In this selected retrospective panel, fame is strongly enriched among download leaders. History, obscurity, and specialist expertise are enriched among the love signals. Those are descriptive contrasts, not causal effects.</p>
        </div>
      </section>

      <section class="three-ways" aria-label="Three distinct episode outcomes">
        <article class="way acquisition">
          <span>01</span>
          <h3>Audience<br />acquisition</h3>
          <p>{outcomeByKey.acquisition.events} of {analysis.panel.rows} mentions ({outcomeByKey.acquisition.rate}%) appear in a retrospective top-download list.</p>
          <strong>Sam Altman<br />Paul Graham<br />Peter Thiel</strong>
        </article>
        <article class="way affection">
          <span>02</span>
          <h3>Audience<br />affection</h3>
          <p>{outcomeByKey.affection.events} of {analysis.panel.rows} mentions ({outcomeByKey.affection.rate}%) carry a direct listener-favorite or retention signal.</p>
          <strong>Lazarus Lake<br />Stephen Kotkin<br />Vishy Anand</strong>
        </article>
        <article class="way tyler">
          <span>03</span>
          <h3>Tyler’s<br />enjoyment</h3>
          <p>{outcomeByKey.tyler.events} of {analysis.panel.rows} mentions ({outcomeByKey.tyler.rate}%) receive the strongest Tyler-praise code. This is a host outcome, not an audience proxy.</p>
          <strong>Knausgård<br />Donald Lopez<br />Any Austin</strong>
        </article>
      </section>

      <section class="year-table">
        <div class="section-head"><p class="section-label">THE SEVEN-YEAR LEDGER</p><p>Top audio downloads and two different forms of love.</p></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Year</th><th>Most listened</th><th>Audience-love signal</th><th>Tyler’s pick</th><th>What matters</th></tr></thead>
            <tbody>{yearlyLeaders.map((row) => <tr><td>{row.year}</td><td>{row.top}</td><td>{row.loved}</td><td>{row.tyler}</td><td>{row.note}</td></tr>)}</tbody>
          </table>
        </div>
      </section>

      <section class="effects" id="effects">
        <div class="effects-intro"><p class="section-label">WHAT THE PANEL ACTUALLY SAYS</p><h2>Descriptive enrichment, in percentage points.</h2><p>Every bar is the observed outcome rate when a feature is present minus its rate when absent. The bracket is an 80% bootstrap interval from 5,000 deterministic resamples. It is not a regression coefficient, a p-value, or a causal estimate.</p></div>
        <div class="effect-grid">
          <article class="effect-card"><header><span class="dot acquisition-dot"></span><p>Acquisition</p><small>Top-download-list enrichment</small></header><div class="bar-list">{viewEffects.map((effect) => <div class:list={['effect-row', effect.value < 0 && 'negative']}><span>{effect.label}</span><div class="track"><i style={`width:${Math.min(Math.abs(effect.value), 100)}%`}></i></div><b>{displayPp(effect.value)}<small>{displayInterval(effect.interval)}</small></b></div>)}</div></article>
          <article class="effect-card"><header><span class="dot affection-dot"></span><p>Audience affection</p><small>Listener-favorite enrichment</small></header><div class="bar-list">{loveEffects.map((effect) => <div class:list={['effect-row', effect.value < 0 && 'negative']}><span>{effect.label}</span><div class="track"><i style={`width:${Math.min(Math.abs(effect.value), 100)}%`}></i></div><b>{displayPp(effect.value)}<small>{displayInterval(effect.interval)}</small></b></div>)}</div></article>
          <article class="effect-card"><header><span class="dot tyler-dot"></span><p>Strong Tyler pick</p><small>Highest retrospective praise code</small></header><div class="bar-list">{tylerEffects.map((effect) => <div class:list={['effect-row', effect.value < 0 && 'negative']}><span>{effect.label}</span><div class="track"><i style={`width:${Math.min(Math.abs(effect.value), 100)}%`}></i></div><b>{displayPp(effect.value)}<small>{displayInterval(effect.interval)}</small></b></div>)}</div></article>
        </div>
      </section>

      <section class="scatter-section">
        <div class="scatter-copy"><p class="section-label">THE OUTLIERS ARE THE PRODUCT CLUES</p><h2>High reach and high love rarely arrive by the same route.</h2><p>David Commins is the cleanest surprise. An obscure Saudi Arabia episode finished seventh in a celebrity-heavy 2025 top ten. Lazarus Lake got there through warmth and recommendation. Amia Srinivasan got there through conflict that listeners stayed to hear.</p><p>The axes below are relative within this retrospective-derived sample, not universal podcast scores.</p></div>
        <figure class="scatter" aria-label="Episode acquisition and affection scatter chart">
          <div class="axis y-axis">AUDIENCE LOVE</div><div class="axis x-axis">AUDIENCE ACQUISITION</div>
          <div class="scatter-grid"></div>
          {outliers.map((episode, index) => <button class:list={['point', `point-${index}`]} style={`left:${episode.x}%;bottom:${episode.y}%`} data-name={episode.name} data-year={episode.year} data-quote={episode.quote} aria-label={`${episode.name}, ${episode.year}: ${episode.quote}`}></button>)}
          <div class="tooltip" id="tooltip"><strong>Hover a point</strong><span>Each dot is an episode with an unusual pattern.</span></div>
        </figure>
      </section>

      <section class="outlier-table">
        <p class="section-label">READ THE WEIRD ONES CLOSELY</p>
        <div class="outlier-grid">{outliers.map((episode, index) => <article class:list={['outlier-card', `outlier-${index}`]}><span>{episode.year}</span><h3>{episode.name}</h3><p>{episode.quote}</p></article>)}</div>
      </section>

      <section class="taxonomy">
        <div class="taxonomy-head"><p class="section-label">THE 62-DIMENSION CODEBOOK</p><h2>Every dimension, its operational definition, and its data status.</h2><p>Thirty-five features were coded from the annual retrospectives. Twenty-seven transcript and audio measures are pre-registered here but explicitly unobserved. The table never turns an unmeasured quantity into a zero.</p></div>
        <div class="codebook-note"><p><b>Reading a cell:</b> Δ is feature-present rate minus feature-absent rate, in percentage points. Brackets are 80% bootstrap intervals. “Sparse” means fewer than four observations in a comparison group. “Not observed” means the available source corpus cannot identify the feature.</p></div>
        <div class="codebook-wrap">
          <table class="codebook-table">
            <thead><tr><th>Family</th><th>Dimension and definition</th><th>Observed n</th><th>Acquisition Δ</th><th>Affection Δ</th><th>Tyler Δ</th><th>Status</th></tr></thead>
            <tbody>{analysis.dimensions.map((dimension) => <tr class:list={[dimension.state === 'not_observed' && 'unobserved']}>
              <td>{dimension.group}</td>
              <td><b>{dimension.label}</b><span>{dimension.definition}</span></td>
              {dimension.state === 'coded' ? <>
                <td>{dimension.support!.present}/{analysis.panel.rows}</td>
                <td>{displayPp(dimension.effects!.acquisition.differencePp)}<small>{displayInterval(dimension.effects!.acquisition.interval80)}</small></td>
                <td>{displayPp(dimension.effects!.affection.differencePp)}<small>{displayInterval(dimension.effects!.affection.interval80)}</small></td>
                {dimension.effects!.tyler.notApplicable ? <td>n/a<small>overlaps outcome</small></td> : <td>{displayPp(dimension.effects!.tyler.differencePp)}<small>{displayInterval(dimension.effects!.tyler.interval80)}</small></td>}
                <td>{dimension.sparse ? 'Sparse' : 'Coded'}</td>
              </> : <>
                <td>n/a</td><td>n/a</td><td>n/a</td><td>n/a</td><td>Not observed</td>
              </>}
            </tr>)}</tbody>
          </table>
        </div>
      </section>

      <section class="recommendations">
        <p class="section-label">A PROGRAMMING RULE, NOT A FORMULA</p>
        <h2>Use recognizable guests to acquire an audience. Use strange specialists to give it a reason to stay.</h2>
        <div class="recommendation-grid"><div><b>01</b><h3>Keep a portfolio</h3><p>Use a 70/30 mix of recognisable anchors and discovery bets. Fame is a legitimate distribution channel.</p></div><div><b>02</b><h3>Package the question</h3><p>Never market a specialist as obscure. Market why Saudi Arabia mattered, what Buddhism is actually like, or what a conductor hears.</p></div><div><b>03</b><h3>Measure the chain</h3><p>Track starts, ten-minute retention, completion, referral source, and unsolicited recommendation separately.</p></div></div>
      </section>

      <section class="guest-forecast" id="next-guests">
        <div class="forecast-head">
          <p class="section-label">THE 2026 GUEST SLATE</p>
          <div>
            <h2>Who should come next?</h2>
            <p>The first outreach should go to Michael Levin, John Jumper, Max Martin, Sarah Paine, Lisa Su, and Kevin Esvelt. They combine a clear premise with unusual expertise, strong preparation payoff, and enough 2026 relevance to travel.</p>
          </div>
        </div>

        <div class="forecast-stats" aria-label="Prospective guest research summary">
          <div><b>793</b><span>primary-source items</span></div>
          <div><b>25</b><span>audience-love picks</span></div>
          <div><b>25</b><span>Tyler-enjoyment picks</span></div>
          <div><b>{overlapGuests.length}</b><span>names in both sets</span></div>
        </div>

        <div class="outreach-grid">
          {firstOutreach.map((guest, index) => <article>
            <span>{String(index + 1).padStart(2, '0')} / FIRST OUTREACH</span>
            <h3>{guest.guest}</h3>
            <p>{guest.domain}</p>
            <dl><div><dt>Audience</dt><dd>{guest.audience_score}</dd></div><div><dt>Tyler</dt><dd>{guest.tyler_score}</dd></div></dl>
          </article>)}
        </div>

        <div class="overlap-block">
          <div class="overlap-copy">
            <p class="section-label">THE FORECAST MOSTLY AGREES</p>
            <h3>{overlapGuests.length} guests clear both thresholds.</h3>
            <p>The overlap is the finding. Audience affection and Tyler’s enjoyment both reward depth, a narrow but generative subject, original material, and the visible payoff from preparation.</p>
          </div>
          <div class="set-diagram" aria-label={`${audienceOnly.length} audience-only guests, ${overlapGuests.length} guests in both sets, and ${tylerOnly.length} Tyler-only guests`}>
            <div class="set-wing audience-wing"><small>AUDIENCE ONLY / {audienceOnly.length}</small>{audienceOnly.map((guest) => <b>{guest.guest}</b>)}</div>
            <div class="set-center"><small>AUDIENCE LOVE + TYLER ENJOYMENT / {overlapGuests.length}</small><div>{overlapGuests.map((guest) => <span>{guest.guest}</span>)}</div></div>
            <div class="set-wing tyler-wing"><small>TYLER ONLY / {tylerOnly.length}</small>{tylerOnly.map((guest) => <b>{guest.guest}</b>)}</div>
          </div>
        </div>

        <div class="rankings-head">
          <p class="section-label">TWO RANKINGS, TWO JOBS</p>
          <h3>One slate is built to be loved. The other is built around Tyler’s curiosity.</h3>
        </div>
        <div class="guest-rankings">
          <div class="guest-table-wrap">
            <table class="guest-table">
              <caption>25 guests most likely to be loved by the audience</caption>
              <thead><tr><th>Rank</th><th>Guest</th><th>Score</th><th>Why it should travel</th></tr></thead>
              <tbody>{audienceGuests.map((guest, index) => <tr><td>{String(index + 1).padStart(2, '0')}</td><td><b>{guest.guest}</b><small>{guest.domain}</small></td><td>{guest.audience_score}</td><td>{guest.audience_case}</td></tr>)}</tbody>
            </table>
          </div>
          <div class="guest-table-wrap">
            <table class="guest-table tyler-table">
              <caption>25 guests Tyler is most likely to enjoy</caption>
              <thead><tr><th>Rank</th><th>Guest</th><th>Score</th><th>Why it suits Tyler</th></tr></thead>
              <tbody>{tylerGuests.map((guest, index) => <tr><td>{String(index + 1).padStart(2, '0')}</td><td><b>{guest.guest}</b><small>{guest.domain}</small></td><td>{guest.tyler_score}</td><td>{guest.tyler_case}</td></tr>)}</tbody>
            </table>
          </div>
        </div>

        <div class="forecast-model">
          <div class="model-copy"><p class="section-label">HOW THE FORECAST IS BUILT</p><h3>Transparent weights, deliberately separate outcomes.</h3><p>These 0 to 100 scores are structured editorial forecasts. The weights inherit the retrospective’s directional findings, while each candidate receives a 1 to 5 judgment on the underlying dimensions. They rank outreach. They do not estimate causal effects.</p></div>
          <div class="weight-card"><h4>Audience love</h4>{audienceWeights.map((weight) => <div class="weight-row"><span>{weight.label}</span><i><b style={`width:${weight.value / 29 * 100}%`}></b></i><strong>{weight.value}%</strong></div>)}</div>
          <div class="weight-card tyler-weights"><h4>Tyler enjoyment</h4>{tylerWeights.map((weight) => <div class="weight-row"><span>{weight.label}</span><i><b style={`width:${weight.value / 29 * 100}%`}></b></i><strong>{weight.value}%</strong></div>)}</div>
        </div>

        <div class="forecast-caveat"><b>Screening rule.</b> Every shortlisted person had no prior CWT archive match and no material exact-name result in Marginal Revolution’s internal search at the time of the audit. That is a documented search result, not proof that Tyler has never encountered the person under a variant spelling, inside a link list, or offline.</div>
      </section>

      <section class="method" id="method">
        <p class="section-label">METHOD AND SOURCES</p>
        <div><h2>The number is useful only when you can reconstruct it.</h2><p><b>Unit and corpus.</b> The panel has {analysis.panel.rows} retrospective episode-year mentions covering {analysis.panel.distinctGuests} distinct guests from the seven official 2019 to 2025 CWT retrospectives. It is a selected sample of episodes the show chose to discuss. It is not the full episode universe, so neither its rates nor its contrasts generalize mechanically to the show.</p><p><b>Outcomes.</b> Acquisition means an episode was named in a retrospective top-download list. Audience affection means the retrospective supplied a listener-favorite, unusually strong retention, or equivalent direct listener-response signal. Strong Tyler pick means the hand-coded Tyler-enjoyment score equals 3, reserved for the strongest personal-praise language. These are three binary outcomes, reported separately because a download leader and a beloved conversation are not the same object.</p><p><b>Estimator.</b> For each coded feature d and outcome Y, the reported statistic is Δ<sub>d</sub> = mean(Y | d = 1) − mean(Y | d = 0). It is an unadjusted rate difference in percentage points. The interval is an 80% percentile bootstrap with 5,000 seeded resamples (seed 20260717). Intervals are withheld when either comparison group has fewer than four rows. The code and exact input files below reproduce every displayed number. Host enthusiasm is withheld from the Strong Tyler Pick comparison because the two codes overlap.</p><p><b>Prospective audit.</b> The guest slate adds 793 primary-source items: 500 recent Marginal Revolution entries from its public sitemap and 293 CWT archive entries. Candidate names were screened against the CWT catalog and Marginal Revolution’s internal exact-name search. Current relevance was checked separately. The resulting shortlist was coded on twelve editorial dimensions before either ranking was produced.</p><p><b>What it does not identify.</b> Features and outcomes are both hand-coded from the same retrospective documents. Selection into the panel is outcome-related. The historical table describes co-occurrence in a curated retrospective sample. The prospective scores are structured forecasts, not causal estimates. A defensible next stage would use the full episode universe, downloads at fixed ages, starts, retention, completion, promotion exposure, guest fame measured before release, release timing, and transcript or diarized-audio measures. Then it could estimate preregistered models with year and format controls.</p><p class="sources"><b>Primary sources:</b> <a href="https://conversationswithtyler.com/episodes/tyler-looks-back-on-2019-bonus/">2019</a> · <a href="https://conversationswithtyler.com/episodes/conversations-with-tyler-2020-retrospective/">2020</a> · <a href="https://conversationswithtyler.com/episodes/conversations-with-tyler-2021-retrospective/">2021</a> · <a href="https://conversationswithtyler.com/episodes/conversations-with-tyler-2022-retrospective/">2022</a> · <a href="https://conversationswithtyler.com/episodes/conversations-with-tyler-2023-retrospective/">2023</a> · <a href="https://conversationswithtyler.com/episodes/conversations-with-tyler-2024-retrospective/">2024</a> · <a href="https://conversationswithtyler.com/episodes/conversations-with-tyler-2025-retrospective/">2025</a> · <a href="https://marginalrevolution.com/">Marginal Revolution</a> · <a href="https://conversationswithtyler.com/episodes/">CWT archive</a></p><p class="sources"><b>Reproducibility:</b> <a href="/data/tyler-retro-panel.csv">coded panel CSV</a> · <a href="/data/tyler-retro-analysis.json">analysis output JSON</a> · <a href="/data/tyler-guest-forecast.csv">guest forecast CSV</a> · <a href="/data/tyler-guest-source-ledger.csv">793-item source ledger</a> · <a href="/data/tyler-guest-exclusion-screen.csv">candidate exclusion screen</a> · <a href="https://github.com/maguirebaseball-debug/jackmaguire-site/blob/main/scripts/analyze-tyler-retro.mjs">historical analysis script</a></p></div>
      </section>
      <footer><a href="/">JACK MAGUIRE</a><span>BUILT FROM THE OFFICIAL RETROSPECTIVE ARCHIVE</span><a href="#top">BACK TO TOP ↑</a></footer>
    </main>
    <script>
      const tooltip = document.querySelector('#tooltip');
      document.querySelectorAll('.point').forEach((point) => {
        point.addEventListener('mouseenter', () => {
          tooltip.innerHTML = `<strong>${point.dataset.name} <i>${point.dataset.year}</i></strong><span>${point.dataset.quote}</span>`;
        });
        point.addEventListener('focus', () => {
          tooltip.innerHTML = `<strong>${point.dataset.name} <i>${point.dataset.year}</i></strong><span>${point.dataset.quote}</span>`;
        });
      });
    </script>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body.retro-body) { margin: 0; background: #101b27; color: #e7e0d2; font-family: Arial, Helvetica, sans-serif; }
  :global(.retro-body main) { max-width: none; padding: 0; }
  :global(.retro-body a) { color: inherit; }
  .retro-page { overflow: hidden; }
  .retro-nav { height: 54px; padding: 0 4.5vw; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(230, 223, 207, .2); font: 10px/1 ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: .12em; color: #d9cfbf; }
