---
const title = "Counter";
const description = "A personal count-up timer.";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <style>
    :root {
      --accent: #556B2F;
      --accent-dark: #3A4B1C;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      background: #faf9f6;
      color: #222;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
    }

    .container {
      text-align: center;
      max-width: 600px;
      width: 100%;
    }

    .label {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #888;
      margin-bottom: 2rem;
    }

    .timer {
      display: flex;
      gap: 2rem;
      justify-content: center;
      flex-wrap: wrap;
      margin: 2rem 0;
    }

    .unit {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 70px;
    }

    .number {
      font-size: 3.5rem;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }

    .unit-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #aaa;
      margin-top: 0.4rem;
    }

    .since {
      font-size: 0.85rem;
      color: #bbb;
      margin-top: 2.5rem;
    }

    .location {
      font-size: 0.85rem;
      color: #bbb;
      margin-top: 0.4rem;
    }

    .history-section {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid #eee;
      width: 100%;
    }

    .history-title {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #ccc;
      margin-bottom: 1rem;
      text-align: center;
    }

    .history-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8rem;
      color: #aaa;
    }

    .history-table th {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #ccc;
      padding-bottom: 0.5rem;
      font-weight: normal;
      text-align: center;
    }

    .history-table td {
      padding: 0.35rem 0;
      text-align: center;
    }

    .history-table tr:not(:last-child) td {
      border-bottom: 1px solid #f0f0f0;
    }

    .history-stats {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 1.2rem;
      font-size: 0.7rem;
      color: #bbb;
    }

    .history-stats span {
      white-space: nowrap;
    }

    .admin-link {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      font-size: 0.7rem;
      color: #ccc;
      text-decoration: none;
      font-family: Georgia, serif;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }

    .admin-link:hover {
      color: #999;
    }
  </style>
</head>
<body>
  <div class="container">
    <p class="label">Time since last drink</p>

    <div class="timer">
      <div class="unit">
        <span class="number" id="weeks">-</span>
        <span class="unit-label">weeks</span>
      </div>
      <div class="unit">
        <span class="number" id="days">-</span>
        <span class="unit-label">days</span>
      </div>
      <div class="unit">
        <span class="number" id="hours">-</span>
        <span class="unit-label">hours</span>
      </div>
      <div class="unit">
        <span class="number" id="minutes">-</span>
        <span class="unit-label">minutes</span>
      </div>
      <div class="unit">
        <span class="number" id="seconds">-</span>
        <span class="unit-label">seconds</span>
      </div>
    </div>

    <p class="since" id="since-text"></p>
    <p class="location" id="location-text"></p>

    <div class="history-section" id="history-section" style="display:none;">
      <p class="history-title">Previous runs &nbsp;<a href="/sobriety/log" style="font-size:0.6rem;color:#ccc;text-decoration:none;letter-spacing:0.1em;text-transform:uppercase;">full log</a></p>
      <table class="history-table">
        <thead>
          <tr>
            <th>Started</th>
            <th>Duration</th>
          </tr>
        </thead>
        <tbody id="history-body"></tbody>
      </table>
      <div class="history-stats" id="history-stats"></div>
    </div>
  </div>

  <a href="/sobriety-admin" class="admin-link">admin login</a>

  <script is:inline>
    const UPSTASH_URL = 'https://still-jennet-137992.upstash.io';
    const UPSTASH_TOKEN = 'gQAAAAAAAhsIAAIgcDIwNDlmNDdiZjQ0YWI0ZTRiOTgyN2VhZGIzODYxZDg1Ng';
    const KEY = 'sobriety_start';
    const LOCATION_KEY = 'sobriety_location';
    const HISTORY_KEY = 'sobriety_history';
    let startTime = null;

    function pad(n) {
      return String(n).padStart(2, '0');
    }

    function tick() {
      if (startTime === null) return;
      const now = Date.now();
      let diff = Math.floor((now - startTime) / 1000);

      const weeks = Math.floor(diff / (7 * 24 * 3600));
      diff -= weeks * 7 * 24 * 3600;
      const days = Math.floor(diff / (24 * 3600));
      diff -= days * 24 * 3600;
      const hours = Math.floor(diff / 3600);
      diff -= hours * 3600;
      const minutes = Math.floor(diff / 60);
      const seconds = diff % 60;

      document.getElementById('weeks').textContent = weeks;
      document.getElementById('days').textContent = days;
      document.getElementById('hours').textContent = pad(hours);
      document.getElementById('minutes').textContent = pad(minutes);
      document.getElementById('seconds').textContent = pad(seconds);

      const startDate = new Date(startTime);
      const opts = { month: 'long', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' };
      document.getElementById('since-text').textContent =
        'Since ' + startDate.toLocaleString('en-US', opts);
    }

    function formatDuration(ms) {
      let s = Math.floor(ms / 1000);
      const weeks = Math.floor(s / (7 * 24 * 3600));
      s -= weeks * 7 * 24 * 3600;
      const days = Math.floor(s / (24 * 3600));
      s -= days * 24 * 3600;
      const hours = Math.floor(s / 3600);
      const parts = [];
      if (weeks > 0) parts.push(weeks + (weeks === 1 ? ' week' : ' weeks'));
      if (days > 0) parts.push(days + (days === 1 ? ' day' : ' days'));
      if (hours > 0 && weeks === 0) parts.push(hours + (hours === 1 ? ' hour' : ' hours'));
      return parts.length > 0 ? parts.join(', ') : 'less than an hour';
    }

    async function loadHistory() {
      try {
        const res = await fetch(UPSTASH_URL + '/get/' + HISTORY_KEY, {
          headers: { Authorization: 'Bearer ' + UPSTASH_TOKEN }
        });
        const data = await res.json();
        if (!data.result) return;
        const history = JSON.parse(data.result);
        if (!history || history.length === 0) return;

        document.getElementById('history-section').style.display = 'block';

        const tbody = document.getElementById('history-body');
        const reversed = [...history].reverse().slice(0, 7);
        reversed.forEach(entry => {
          const tr = document.createElement('tr');
          const dateStr = new Date(entry.start).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          tr.innerHTML = '<td>' + dateStr + '</td><td>' + formatDuration(entry.duration) + '</td>';
          tbody.appendChild(tr);
        });

        const durations = history.map(e => e.duration);
        const n = durations.length;
        const minD = Math.min(...durations);
        const maxD = Math.max(...durations);
        const avgD = durations.reduce((a, b) => a + b, 0) / n;
        const sorted = [...durations].sort((a, b) => a - b);
        const medD = n % 2 === 0 ? (sorted[n/2-1] + sorted[n/2]) / 2 : sorted[Math.floor(n/2)];

        const statsEl = document.getElementById('history-stats');
        let statsHtml = '<span>shortest: ' + formatDuration(minD) + '</span>'
          + '<span>longest: ' + formatDuration(maxD) + '</span>'
          + '<span>avg: ' + formatDuration(avgD) + '</span>';
        if (n >= 3) statsHtml += '<span>median: ' + formatDuration(medD) + '</span>';
        statsEl.innerHTML = statsHtml;
      } catch (e) {}
    }

    async function init() {
      try {
        const [timeRes, locRes] = await Promise.all([
          fetch(UPSTASH_URL + '/get/' + KEY, { headers: { Authorization: 'Bearer ' + UPSTASH_TOKEN } }),
          fetch(UPSTASH_URL + '/get/' + LOCATION_KEY, { headers: { Authorization: 'Bearer ' + UPSTASH_TOKEN } })
        ]);
        const timeData = await timeRes.json();
        const locData = await locRes.json();
        if (timeData.result) {
          startTime = parseInt(timeData.result, 10);
        } else {
          const now = Date.now();
          startTime = now;
          await fetch(UPSTASH_URL + '/set/' + KEY + '/' + now, {
            headers: { Authorization: 'Bearer ' + UPSTASH_TOKEN }
          });
        }
        if (locData.result) {
          document.getElementById('location-text').textContent = 'location: ' + locData.result;
        }
      } catch (e) {
        startTime = Date.now();
      }
      tick();
      setInterval(tick, 1000);
      loadHistory();
    }

    init();
  </script>
</body>
</html>
