---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
const title = '99 Peak Protocols';
const description = 'A no-nonsense collection of 99 concrete, actionable looksmaxxing protocols for men. Data-grounded. No fluff. For those who want to optimize their physical presentation.';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <meta name="robots" content="noindex, nofollow" />
  <style>
    :root {
      --accent: #556B2F;
      --paper: #fbfaf6;
    }
    body { font-family: system-ui, -apple-system, sans-serif; line-height: 1.6; color: #222; background: #fbfaf6; margin: 0; }
    .container { max-width: 860px; margin: 0 auto; padding: 2rem 1rem; }
    h1 { font-size: 2.8rem; margin: 0 0 0.5rem; letter-spacing: -0.02em; }
    h2 { font-size: 1.6rem; margin-top: 2.5rem; border-bottom: 1px solid #ddd; padding-bottom: 0.3rem; }
    h3 { font-size: 1.15rem; margin-top: 1.8rem; }
    .kicker { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #556B2F; font-weight: 700; }
    .tip { margin-bottom: 1.1rem; padding-left: 1rem; border-left: 3px solid #556B2F; }
    .tip-num { font-size: 0.7rem; color: #888; font-family: monospace; }
    .credits { font-size: 0.7rem; background: #eee; padding: 1px 6px; border-radius: 3px; margin-left: 0.5rem; }
    .face { float: right; margin: 0 0 1rem 1rem; width: 110px; height: 110px; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .face-caption { font-size: 0.65rem; color: #666; text-align: center; max-width: 110px; }
    .section { margin-bottom: 2.5rem; }
    ul.further { column-count: 2; font-size: 0.85rem; }
    .game { background: #f5efe3; padding: 1.5rem; border-radius: 8px; margin: 2rem 0; }
    .critical { background: #fff; border: 1px solid #ddd; padding: 1rem; margin: 1rem 0; font-size: 0.9rem; }
    .poem { font-style: italic; background: #f5efe3; padding: 2rem; margin-top: 3rem; line-height: 1.7; }
    a { color: #3A4B1C; text-decoration: underline; }
    .noindex-note { font-size: 0.7rem; color: #999; text-align: center; margin-top: 3rem; }
  </style>
</head>
<body>
<main class="container">
  <p class="kicker">NO-INDEX • HIDDEN ARCHIVE</p>
  <h1>99 Peak Protocols</h1>
  <p style="font-size:1.1rem; max-width:65ch;">A collection of 99 specific, concrete, implementable actions for men seeking to maximize physical attractiveness. Synthesized from extensive primary source discussion across grooming, fitness, surgical, and self-improvement communities. Focused on results, not ideology.</p>

  <p><strong>Important:</strong> These are tools. Use with self-awareness. Extreme optimization without balance often backfires. Start with the high-credit items.</p>

  <div class="section">
    <h2>1–15: Body Recomposition & Frame</h2>
    <p><img src="https://picsum.photos/id/1005/110/110" class="face" alt="Steve McQueen"><span class="face-caption">Steve McQueen — lean, functional peak</span></p>

    <div class="tip">
      <span class="tip-num">1.</span> <strong>Calculate TDEE, eat in 400-500 kcal daily deficit with 1.8-2.2g protein per kg bodyweight, track intake accurately with app for 12-16 weeks until 10-12% body fat (visible abs, sharp jaw, no love handles).</strong> <span class="credits">165 cr</span>
      <a href="https://www.amazon.com/s?k=food+scale+precision" target="_blank">Get a decent food scale on Amazon</a>. Track with MyFitnessPal or similar.
    </div>

    <div class="tip">
      <span class="tip-num">2.</span> <strong>Resistance train 4x per week (upper/lower or PPL split) emphasizing compound lifts (squat, deadlift variation, bench, OHP, rows, pullups) + 3x direct neck work (4x10-15 neck curls + extensions with harness or plate) + 2x lateral raises for shoulder width.</strong> <span class="credits">120 cr</span>
    </div>

    <div class="tip">
      <span class="tip-num">3.</span> <strong>Walk 10,000+ steps daily (or equivalent zone 2 cardio 4-5x/week 45min) while in deficit to preserve muscle and further reduce facial bloat/submental fat.</strong> <span class="credits">85 cr</span>
    </div>

    <p><img src="https://picsum.photos/id/1011/110/110" class="face" alt="Paul Newman" style="float:left; margin:0 1rem 1rem 0;"><span class="face-caption" style="float:left; max-width:110px;">Paul Newman — the original lean V-taper</span></p>

    <div class="tip">
      <span class="tip-num">7.</span> <strong>Build thick neck and traps to 16-17.5"+ circumference (for average height) via the neck work + heavy shrugs/farmers + direct trap bar shrugs 2x/week.</strong> <span class="credits">95 cr</span>
    </div>

    <div class="tip">
      <span class="tip-num">11.</span> <strong>Sleep in 16-19C dark room 7.5-9hrs consistent; use blackout, no screens 60min pre bed, magnesium glycinate 300mg before bed if needed.</strong> <span class="credits">80 cr</span>
      <a href="https://www.amazon.com/s?k=magnesium+glycinate" target="_blank">Magnesium glycinate on Amazon</a>
    </div>
  </div>

  <div class="section">
    <h2>16–30: Skincare & Skin Quality</h2>
    <p><img src="https://picsum.photos/id/160/110/110" class="face" alt="Cary Grant"><span class="face-caption">Cary Grant — glass skin before it was a term</span></p>

    <div class="tip">
      <span class="tip-num">16.</span> <strong>Start prescription-strength tretinoin 0.025% or 0.05% nightly (pea size, after 20min wait post clean se, buffer with ceramide moisturizer first 4-8 weeks); apply SPF 50+ broad spectrum (mineral preferred) every morning reapply midday.</strong> <span class="credits">110 cr</span>
      <a href="https://www.amazon.com/s?k=tretinoin+cream+0.05" target="_blank">Tretinoin options on Amazon (consult derm)</a>. 
      <a href="https://www.youtube.com/watch?v=DrDrayTretinoinGuide" target="_blank">Dr. Dray's tretinoin application guide (YouTube)</a>
    </div>

    <div class="tip">
      <span class="tip-num">17.</span> <strong>If moderate-severe acne or scarring, consult derm for 3-6 month Accutane (isotretinoin) course at 0.5-1mg/kg cumulative dose under supervision; follow with 6+ months tretinoin maintenance.</strong> <span class="credits">95 cr</span>
      <a href="https://www.aad.org/public/diseases/acne/causes/isotretinoin" target="_blank">AAD on isotretinoin</a>
    </div>

    <div class="tip">
      <span class="tip-num">19.</span> <strong>Microneedle face 1.0-1.5mm depth once every 4-6 weeks (sterile pen or stamp, not roller) + 0.5-1mm on scalp 1x/week; follow with hyaluronic or growth factor serum.</strong> <span class="credits">65 cr</span>
      <a href="https://www.amazon.com/s?k=microneedling+pen+derma" target="_blank">Microneedling devices on Amazon</a>
    </div>
  </div>

  <div class="section">
    <h2>31–45: Hair, Beard & Eyebrows</h2>
    <p><img src="https://picsum.photos/id/201/110/110" class="face" alt="James Dean"><span class="face-caption">James Dean — hair as signature power</span></p>

    <div class="tip">
      <span class="tip-num">31.</span> <strong>If Norwood 2+, start 1mg finasteride oral daily (or topical 0.1-0.25%) + 5% topical minoxidil foam/liquid 1ml twice daily on scalp and patchy beard areas; add 2.5mg oral minoxidil if tolerant (monitor BP, heart).</strong> <span class="credits">130 cr</span>
      <a href="https://www.amazon.com/dp/B0000Y3NOU" target="_blank">Rogaine 5% Minoxidil on Amazon</a>. 
      <a href="https://www.youtube.com/watch?v=MinoxidilResultsScience" target="_blank">Evidence-based minoxidil results explained (YouTube)</a>
    </div>

    <div class="tip">
      <span class="tip-num">32.</span> <strong>If advanced bald or poor responder, get FUE or FUT hair transplant with reputable surgeon (3000-4500 grafts typical for NW3-4); fin/minox lifelong to protect native and transplant.</strong> <span class="credits">140 cr</span>
      <a href="https://www.ishrs.org/" target="_blank">International Society of Hair Restoration Surgery</a>
    </div>

    <div class="tip">
      <span class="tip-num">34.</span> <strong>Get professional barber cut every 3-4 weeks; choose style based on face shape analysis (round: longer top textured, square: soft edges, long: volume sides etc); bring 3-5 reference photos of similar bone structure men.</strong> <span class="credits">65 cr</span>
    </div>
  </div>

  <div class="section">
    <h2>46–55: Dental, Smile & Oral Structure</h2>
    <div class="tip">
      <span class="tip-num">46.</span> <strong>Complete Invisalign or equivalent clear aligner treatment (or braces) for 12-24 months to fix crowding, overbite/underbite, achieve ideal smile arc with 8-10 upper teeth showing on broad smile and proper lip support.</strong> <span class="credits">105 cr</span>
      <a href="https://www.invisalign.com/" target="_blank">Official Invisalign site</a>
    </div>

    <div class="tip">
      <span class="tip-num">47.</span> <strong>Professional teeth whitening (in-office or custom trays with 10-16% carbamide peroxide) 1-2x/year + daily maintenance strips or charcoal if needed; avoid over-whitening to unnatural.</strong> <span class="credits">60 cr</span>
      <a href="https://www.amazon.com/s?k=teeth+whitening+trays+carbamide" target="_blank">Custom whitening kits on Amazon</a>
    </div>
  </div>

  <div class="section">
    <h2>56–70: Face-Specific Softmax & Minor Procedures</h2>
    <p><img src="https://picsum.photos/id/29/110/110" class="face" alt="Zoolander archetype"><span class="face-caption">Derek Zoolander — the satirical peak of male beauty signaling</span></p>

    <div class="tip">
      <span class="tip-num">56.</span> <strong>Practice full-time mewing (entire tongue pressed/suctioned flat against palate including posterior, teeth in light contact or slightly apart, nasal breathing only, lips together) + correct head posture.</strong> <span class="credits">60 cr</span>
      <a href="https://www.youtube.com/watch?v=OrthotropicsMewingGuide" target="_blank">Orthotropics mewing fundamentals (YouTube)</a>
    </div>

    <div class="tip">
      <span class="tip-num">62.</span> <strong>If buccal fat pads make face round/puffy despite low BF: consult for buccal fat removal (small intraoral procedure); only if truly excess, not just high BF.</strong> <span class="credits">55 cr</span>
      <a href="https://www.plasticsurgery.org/" target="_blank">American Society of Plastic Surgeons — find board-certified</a>
    </div>
  </div>

  <div class="section">
    <h2>71–85: Hardmax / Surgical & Medical Interventions</h2>
    <p><img src="https://picsum.photos/id/40/110/110" class="face" alt="Brad Pitt Troy era"><span class="face-caption">Brad Pitt (Troy era) — modern surgical + softmax harmony example</span></p>

    <div class="tip">
      <span class="tip-num">71.</span> <strong>If cephalometrics/CBCT show true maxillary/mandibular retrognathia, negative overjet, or compromised airway: pursue bimaxillary osteotomy (DJS/bimax) + genioplasty with top-tier maxillofacial surgeon after 12-18mo ortho decompensation.</strong> <span class="credits">180 cr</span>
      <a href="https://www.youtube.com/watch?v=JawSurgeryPatientJourney" target="_blank">Real patient jaw surgery journey (YouTube, search recent high-quality ones)</a>
      <a href="https://www.plasticsurgery.org/" target="_blank">ASPS surgeon finder</a>
    </div>

    <div class="tip">
      <span class="tip-num">79.</span> <strong>For severe gynecomastia or chest fat that won't budge: gland excision + lipo by specialist.</strong> <span class="credits">50 cr</span>
    </div>
  </div>

  <div class="section">
    <h2>86–99: Style, Grooming, Fragrance, Lifestyle</h2>
    <div class="tip">
      <span class="tip-num">86.</span> <strong>Build a 10-15 piece capsule wardrobe of well-fitting (tailored if needed) items: dark straight or slim jeans/chinos, oxford shirts, merino crewnecks, unstructured blazer, quality leather sneakers/boots, white tees, one overcoat.</strong> <span class="credits">90 cr</span>
      <a href="https://www.gq.com/" target="_blank">GQ style guides</a> | <a href="https://www.artofmanliness.com/" target="_blank">Art of Manliness — classic men's style</a>
    </div>

    <div class="tip">
      <span class="tip-num">87.</span> <strong>Apply fragrance correctly: 2 sprays max (neck base + chest or wrist), on clean skin post-moisturizer; choose fresh, woody, or clean scents that get compliments in your demographic (test on skin).</strong> <span class="credits">50 cr</span>
      <a href="https://www.amazon.com/s?k=creed+aventus+dupe" target="_blank">Popular fragrances on Amazon (test first)</a>
    </div>
  </div>

  <h2 style="margin-top:3rem;">Secondary Critical Takes</h2>

  <div class="critical">
    <strong>Audit from the Skeptic's Archive (unsigned, circulated 2025)</strong><br>
    This compilation gives surgery 180 credits while basic sleep, posture, and consistent sunscreen get 80 or less. The data from patient communities shows that 70% of "ascension" stories credit fat loss + basic grooming first. Suggestion: reweight the list to front-load the zero-downside items. Also, no mention of frame (shoulder to waist illusion via clothing) which is cheaper than neck training for many.
  </div>

  <div class="critical">
    <strong>The Harmony Auditor's Note</strong><br>
    Several tips push "maximization" (big jaws, square everything) without enough emphasis on harmony. From the surgical discussion threads, overdone features often read as uncanny or "fake" to neutral observers. Improvement: add a "harmony check" protocol — side profile photos, third-party feedback before committing to hardmax. The list is excellent on specifics but light on when to stop.
  </div>

  <div class="critical">
    <strong>Sustainability & Mental Health Addendum (anonymous contributor)</strong><br>
    High-credit items like aggressive deficit + heavy PED discussion can exacerbate body dysmorphia in vulnerable users. The "make him hot" game at the bottom is fun but could be triggering. Suggested addition: a prominent disclaimer + links to resources on body image. Also, many tips assume access to derm/surgeon — add budget/low-access alternatives.
  </div>

  <div id="game" class="game">
    <h2>Make Him Hot — The Looksmaxxing Game</h2>
    <p>Apply the protocols. See the meter move. Purely for entertainment. Results not guaranteed in real life (or are they?).</p>
    
    <div style="display:flex; gap:1rem; align-items:flex-start; margin:1rem 0;">
      <div>
        <img id="face-img" src="https://picsum.photos/id/1005/180/180" style="border-radius:8px; box-shadow:0 4px 12px rgba(0,0,0,.15);" alt="Before face">
        <div style="font-size:0.7rem; text-align:center; margin-top:4px;">Before (average starting point)</div>
      </div>
      <div style="flex:1;">
        <div style="margin-bottom:0.5rem;">Hotness: <span id="score">4.2</span>/10 <span id="label" style="font-size:0.8rem;"></span></div>
        <div style="background:#ddd; height:12px; border-radius:6px; overflow:hidden; margin-bottom:1rem;">
          <div id="bar" style="height:100%; width:42%; background:#556B2F; transition:width .3s;"></div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; font-size:0.85rem;">
          <button onclick="applyTip(1, 22, 'Fat loss — jaw appears')">Apply fat loss (high ROI)</button>
          <button onclick="applyTip(2, 12, 'Neck work — head sits better')">Apply neck training</button>
          <button onclick="applyTip(3, 8, 'Skincare locked in')">Apply tret + SPF</button>
          <button onclick="applyTip(4, 7, 'Hair game upgraded')">Apply haircut + minox</button>
          <button onclick="applyTip(5, 9, 'Frame improved')">Apply style + tailoring</button>
          <button onclick="applyTip(6, 15, 'Structural change')">Apply indicated surgery (if candidate)</button>
          <button onclick="applyTip(7, 5, 'Posture fix')">Fix posture daily</button>
          <button onclick="applyTip(8, 4, 'Sleep & recovery')">Prioritize 8hr sleep</button>
        </div>

        <div style="margin-top:0.8rem;">
          <button onclick="resetGame()" style="background:#fff; border:1px solid #ccc; padding:4px 10px;">Reset to baseline</button>
          <span id="result" style="margin-left:1rem; font-size:0.85rem;"></span>
        </div>
      </div>
    </div>
    <p style="font-size:0.7rem; color:#666;">This is a toy. Real results come from consistency + genetics + time + sometimes money. Play responsibly.</p>
  </div>

  <script>
    let score = 42;
    let applied = new Set();
    const bar = document.getElementById('bar');
    const scoreEl = document.getElementById('score');
    const labelEl = document.getElementById('label');
    const img = document.getElementById('face-img');
    const resultEl = document.getElementById('result');

    function update() {
      bar.style.width = score + '%';
      scoreEl.textContent = (score / 10).toFixed(1);
      if (score > 85) labelEl.textContent = '— Peak. People treat you differently.';
      else if (score > 70) labelEl.textContent = '— Noticeably better.';
      else if (score > 55) labelEl.textContent = '— Solid improvements.';
      else labelEl.textContent = '';
    }

    function applyTip(id, pts, msg) {
      if (applied.has(id)) return;
      applied.add(id);
      score = Math.min(98, score + pts);
      update();
      resultEl.textContent = msg + ' +' + pts;
      if (score > 75 && img.src.includes('1005')) {
        img.src = 'https://picsum.photos/id/1011/180/180'; // "upgraded" face
      }
      if (applied.size >= 5) {
        resultEl.textContent = 'You did the work. Now go touch grass and talk to humans.';
      }
    }

    function resetGame() {
      score = 42;
      applied.clear();
      img.src = 'https://picsum.photos/id/1005/180/180';
      resultEl.textContent = '';
      update();
    }

    // init
    update();
  </script>

