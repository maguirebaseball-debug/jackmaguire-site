---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const categories = ["Body Recomposition, Training & Frame (Highest leverage for most men)", "Hair, Beard & Eyebrows (High visual impact)", "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "Skincare, Skin Quality & Texture (Universal high mention)", "Dental, Smile & Oral Structure", "Face-Specific Softmax & Minor Procedures", "Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details"];
const tips = [{"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "If cephalometrics/CBCT show true maxillary/mandibular retrognathia, negative overjet, or compromised airway: pursue bimaxillary osteotomy (DJS/bimax) + genioplasty with top-tier maxillofacial surgeon after 12-18mo ortho decompensation.", "extra": "Highest impact hardmax per jawsurgery and looksmax data for recessed profiles.", "credits": 180}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Calculate TDEE, eat in 400-500 kcal daily deficit with 1.8-2.2g protein per kg bodyweight, track intake accurately with app for 12-16 weeks until 10-12% body fat (visible abs, sharp jaw, no love handles).", "extra": "Reassess with DEXA or photos every 4 weeks. (Base weight high; S+ tier across Fitness, moreplatesmoredates, LooksmaxingAdvice threads.)", "credits": 170}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "If advanced bald or poor responder, get FUE or FUT hair transplant with reputable surgeon (3000-4500 grafts typical for NW3-4); fin/minox lifelong to protect native and transplant.", "extra": "One of highest ROI hardmax per forum/Reddit tier lists.", "credits": 140}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Hair transplant (FUE) as detailed in #32.", "extra": "(Repeated for allocation.)", "credits": 140}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "If Norwood 2+, start 1mg finasteride oral daily (or topical 0.1-0.25%) + 5% minoxidil foam/liquid 1ml twice daily on scalp; add 2.5mg oral minoxidil if tolerant (monitor BP, heart).", "extra": "Documented massive \"saved my hairline\" stories in tressless + looks subs.", "credits": 130}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Resistance train 4x per week (upper/lower or PPL split) emphasizing compound lifts (squat, deadlift variation, bench, OHP, rows, pullups) + 3x direct neck work (4x10-15 neck curls + extensions with harness or plate) + 2x lateral raises for shoulder width.", "extra": "Progressive overload.", "credits": 125}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Complete Invisalign or equivalent clear aligner treatment (or braces) for 12-24 months to fix crowding, overbite/underbite, achieve ideal smile arc with 8-10 upper teeth showing on broad smile and proper lip support.", "extra": "High ROI per jawsurgery and looks threads.", "credits": 115}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Start prescription-strength tretinoin 0.025% or 0.05% nightly (pea size, after 20min wait post clean se, buffer with ceramide moisturizer first 4-8 weeks); apply SPF 50+ broad spectrum (mineral preferred) every morning reapply midday.", "extra": "Standard for \"glass skin\" and anti aging in SkincareAddiction, malegrooming, LooksmaxingAdvice.", "credits": 110}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "If leg length discrepancy or very short stature and motivated: consider limb lengthening surgery (Precice or similar) with experienced surgeon; 5-8cm typical.", "extra": "Extreme, discussed in height subs.", "credits": 100}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Build thick neck and traps to 16-17.5\"+ circumference (for average height) via the neck work + heavy shrugs/farmers + direct trap bar shrugs 2x/week.", "extra": "Dramatically improves head-to-body ratio per rating threads.", "credits": 95}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "If moderate-severe acne or scarring, consult derm for 3-6 month Accutane (isotretinoin) course at 0.5-1mg/kg cumulative dose under supervision; follow with 6+ months tretinoin maintenance.", "extra": "Frequently cited as game changer for texture and confidence.", "credits": 95}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Chin/jaw angle implants or custom PEEK implants for permanent lower third projection and width if filler not enough or desired permanent.", "extra": "Frequently tiered high ROI.", "credits": 95}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Walk 10,000+ steps daily (or equivalent zone 2 cardio 4-5x/week 45min) while in deficit to preserve muscle and further reduce facial bloat/submental fat.", "extra": "", "credits": 90}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Build a 10-15 piece capsule wardrobe of well-fitting (tailored if needed) items: dark straight or slim jeans/chinos, oxford shirts, merino crewnecks, unstructured blazer, quality leather sneakers/boots, white tees, one overcoat.", "extra": "Fit > brand. From malefashionadvice + guides.", "credits": 90}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Nose: if large hump or bulbous, rhinoplasty with experienced surgeon focusing on masculine straight or slight aquiline profile, not feminized.", "extra": "High in tier lists.", "credits": 85}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Rhinoplasty as #67.", "extra": "", "credits": 85}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Sleep in 16-19C dark room 7.5-9hrs consistent; use blackout, no screens 60min pre bed, magnesium threonate or glycinate 300mg.", "extra": "Directly reduces facial puffiness and supports fat loss hormones per multiple threads.", "credits": 80}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Train upper back, rear delts, and lats 2-3x/week with face pulls, band pullaparts, wide grip rows, pullups to build \"cape\" V-taper and improve shoulder-to-waist ratio.", "extra": "", "credits": 75}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Grow and maintain short neat stubble or full beard if density allows (use 5% minox on face 2x/day for 6-12mo if patchy, then maintain); line up and trim weekly with quality trimmer.", "extra": "Beard transforms lower third for many.", "credits": 75}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "For recessed chin without full jaw issues: 1-2ml HA filler or chin implant (silicone or sliding genio) for projection and profile balance.", "extra": "", "credits": 75}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Fix anterior pelvic tilt and forward head posture with daily 5-10min routine: glute bridges 3x15, hip flexor stretches 60s/side, chin tucks 3x10, wall angels, thoracic extensions on foam roller.", "extra": "Improves perceived height, jawline, and confident silhouette in photos/motion.", "credits": 70}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "For recessed maxilla contributing to flat midface/poor smile support: explore MSE or SARPE palate expansion + ortho if young adult or teen; otherwise surgical options later.", "extra": "", "credits": 70}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Blepharoplasty (upper/lower lid) or canthoplasty/canthopexy for hooded, negative tilt, or scleral show correction.", "extra": "Eye area is critical per many analyses.", "credits": 70}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Microneedle face 1.0-1.5mm depth once every 4-6 weeks (sterile pen or stamp, not roller) + 0.5-1mm on scalp 1x/week; follow with hyaluronic or growth factor serum.", "extra": "Reported in comments for scars, pores, hair.", "credits": 65}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Get professional barber cut every 3-4 weeks; choose style based on face shape analysis (round: longer top textured, square: soft edges, long: volume sides etc); bring 3-5 reference photos of similar bone structure men.", "extra": "Cheat sheet and multiple threads.", "credits": 65}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Professional teeth whitening (in-office or custom trays with 10-16% carbamide peroxide) 1-2x/year + daily maintenance strips or charcoal if needed; avoid over-whitening to unnatural.", "extra": "", "credits": 60}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Practice full-time mewing (entire tongue pressed/suctioned flat against palate including posterior, teeth in light contact or slightly apart, nasal breathing only, lips together) + correct head posture.", "extra": "Documented transformations in orthotropics/Mewing; cheap high effort.", "credits": 60}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Get full blood panel + hormone optimization (TRT if clinically low T with symptoms, under doctor) before/ during major protocols; low T hinders muscle, skin, hair, mood, energy.", "extra": "Common in steroids/MPMD circles.", "credits": 60}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Bulk lean to add 8-15lbs muscle first (if under 15% BF and skinny fat or under-muscled), then cut; repeat 2-3 cycles if novice/intermediate.", "extra": "Use 250-300 surplus, high protein.", "credits": 55}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Double cleanse at night (oil/balm then gentle cleanser); use 10-15% vitamin C serum (L-ascorbic) in AM under moisturizer/SPF for brightness and pigmentation.", "extra": "", "credits": 55}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "If receding or high hairline, consider hair system (toupee/lace with glue or tape) professionally fitted and maintained monthly as interim or alternative to HT.", "extra": "Discussed in some hair loss communities.", "credits": 55}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Consider composite bonding or porcelain veneers (minimal prep) for chipped, short, or discolored teeth after alignment and whitening; choose natural proportions.", "extra": "", "credits": 55}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "If buccal fat pads make face round/puffy despite low BF: consult for buccal fat removal (small intraoral procedure); only if truly excess, not just high BF.", "extra": "High discussion in hardmax.", "credits": 55}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Buccal fat removal as #62 if indicated.", "extra": "", "credits": 55}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "No smoking/vaping, limit alcohol to <7 drinks/week, minimize ultra-processed food.", "extra": "Direct skin, hair, inflammation, recovery, and smell impact.", "credits": 55}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "For height presentation: wear quality 1-1.5\" subtle lifts or thicker sole shoes/boots (e.g. certain chelsea or dress boots) that don't look orthopedic; pair with correct inseam pants.", "extra": "Common in short and passportbros discussions.", "credits": 50}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Consider low dose dutasteride 0.5mg 2-3x/week if finasteride not enough after 12mo (off label, discuss with doc).", "extra": "", "credits": 50}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "For negative canthal tilt or hollow under eyes: consistent skincare (tret + vit C + peptides), sleep, allergy control, filler in tear troughs by expert (0.5-1ml HA carefully).", "extra": "", "credits": 50}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "For severe gynecomastia or chest fat that won't budge: gland excision + lipo by specialist.", "extra": "Improves shirtless and fitted clothes aesthetics.", "credits": 50}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Apply fragrance correctly: 2 sprays max (neck base + chest or wrist), on clean skin post-moisturizer; choose fresh, woody, or clean scents that get compliments in your demographic (test on skin).", "extra": "", "credits": 50}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Eliminate liquid calories, liquid oils in excess, and high-sodium processed foods during cut phases; time carbs around workouts.", "extra": "Face leanness responds fast to this.", "credits": 45}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Test for and fix vitamin D deficiency (<40-50 ng/ml) and low iron/ferritin via bloodwork; supplement D3 2000-5000IU + K2 + magnesium.", "extra": "Improves skin, energy, mood, under eyes.", "credits": 45}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "If balding aggressively and no transplant candidate yet, buzz cut (#1-2 guard) or shaved head + groomed beard/stubble + tan for \"bald by choice\" strong look.", "extra": "Frequently recommended over clinging to hair.", "credits": 45}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Chew mastic gum or falim 1-2 hours/day (build up) or use Jawliner device for masseter hypertrophy if you have narrow or recessed lower third and want wider jaw angles (monitor for TMJ).", "extra": "Mixed but frequently tried.", "credits": 45}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Fix ear position if protruding: otoplasty (ear pinning) under local or general; high satisfaction for side profile.", "extra": "", "credits": 45}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Fat transfer (microfat or nano) to under eyes, temples, or cheeks for youthful volume if hollow from low BF or genetics.", "extra": "", "credits": 45}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "If under-muscled and high BF (\"skinny fat\"), prioritize recomp or bulk first rather than aggressive cut; focus on strength gains 3-6 months.", "extra": "", "credits": 40}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Apply daily facial moisturizer with ceramides, niacinamide 5%, and HA; body lotion immediately after shower while damp.", "extra": "Prevents dehydration that causes oil overproduction and dullness.", "credits": 40}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Dye or fill eyebrows subtly darker if light/fair (use beard dye 3-5min or professional tint); pluck only stray monobrow hairs, never thin or arch dramatically.", "extra": "Specific advice in rate threads.", "credits": 40}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "If short teeth or gummy smile, consult for crown lengthening or botox lip flip (temporary) or orthognathic that advances maxilla.", "extra": "", "credits": 40}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Reduce masseter if overly square/hypertrophied face with masseter botox (20-40 units/side every 4-6mo) by injector experienced with male faces.", "extra": "", "credits": 40}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Liposuction or body contouring (abdomen, love handles, submental) after reaching ~12-14% to remove stubborn pockets.", "extra": "", "credits": 40}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Stress management: daily 10min meditation or breathwork, nature time, social hobbies; high chronic cortisol shows in face (puffiness, lines, fat distribution).", "extra": "", "credits": 40}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Develop visible forearms and vascularity via 2-3x direct grip/farmers carries, reverse curls, wrist roller 3x10-20 + dead hangs.", "extra": "Contributes to \"strong hands/arms\" signal.", "credits": 35}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Incorporate 2-3x/week direct core (hanging leg raises, ab wheel, cable crunches) and obliques (woodchoppers, side planks) for midsection aesthetics and waist control during cut.", "extra": "", "credits": 35}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Strict sun avoidance + reapply SPF; add oral polypodium leucotomos or astaxanthin 12mg if high sun exposure for extra protection per some derm recs.", "extra": "", "credits": 35}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "For under eye hollows/dark circles: consistent sleep + hydration + allergy management + topical caffeine/niacinamide eye cream; consider PRP or filler only after softmax exhausted.", "extra": "", "credits": 35}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Avoid dairy (especially whey) and high glycemic foods if prone to hormonal acne; trial elimination 4-6 weeks.", "extra": "Mentioned across skincare and lifting threads.", "credits": 35}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Fix gum health: daily flossing + water flosser, electric toothbrush, 2x/year professional cleanings; treat any periodontal issues.", "extra": "Gums frame teeth.", "credits": 35}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Groom and subtly lift eyebrows: professional shaping or at-home with spoolie + clear gel; if very low set or hooded, consider brow lift or botox brow lift by experienced injector.", "extra": "", "credits": 35}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Midface implants or deep plane facelift elements if significant sagging or flat (rare in young men).", "extra": "", "credits": 35}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Posture in motion: shoulders back/down, chest up, chin parallel to ground, relaxed arms; practice walking tall in mirror or recorded video.", "extra": "Complements static fixes.", "credits": 35}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "If oily or acne prone post workout: immediate water rinse + salicylic acid 2% spot treatment only as needed.", "extra": "(From the 24yo thread advice).", "credits": 30}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Use ketoconazole 2% shampoo (Nizoral) 2-3x/week as adjunct for scalp health and mild anti-androgen effect; leave on 3-5min.", "extra": "", "credits": 30}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Get bloods (DHT, testosterone, iron, thyroid, vit D) before starting any hair protocol; address root causes if low T or hypothyroid contributing to shedding.", "extra": "", "credits": 30}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Practice proper tongue posture and swallowing (mewing + no tongue thrust) during ortho to stabilize results and support palate.", "extra": "", "credits": 30}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Tan strategically (sunless with DHA lotion or controlled UVB) to even skin tone, sharpen features, and add contrast; never burn.", "extra": "Common in guides.", "credits": 30}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Cheekbones: if flat, subtle HA filler or fat transfer (not overdone); or accept and enhance with lighting/contour/lower BF.", "extra": "", "credits": 30}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "Jaw botox or filler for temporary angle definition while deciding on implants.", "extra": "", "credits": 30}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Shoes: rotate 3-4 pairs of clean, well-maintained, context-appropriate footwear (white sneakers, chelsea, loafers, boots); match belt to shoes.", "extra": "Details matter in close range.", "credits": 30}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "After major softmax/hardmax milestones, get updated professional photos (or good amateur with proper setup) and update dating profiles/apps with current best versions.", "extra": "Real world testing of gains.", "credits": 30}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Gentle chemical exfoliation 1-2x week with 5-10% mandelic or lactic acid if not on tret; never over-exfoliate.", "extra": "", "credits": 25}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Professional hydrafacial or chemical peel 1x/quarter for maintenance after initial 6mo home routine.", "extra": "", "credits": 25}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Stay consistently hydrated (3.5-5L water/day depending on size/climate); add electrolytes if training hard.", "extra": "Skin plumpness and hair/skin quality signal.", "credits": 25}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "For beard density maintenance after minox: dermaroll 0.5mm 1x/week + minox; trim to even length that suits jaw.", "extra": "", "credits": 25}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Laser hair removal or electrolysis for unibrow, neck beard, or unwanted body hair if it distracts (e.g. back, shoulders for some).", "extra": "", "credits": 25}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Post ortho or surgery, wear retainers lifelong as prescribed (nightly Vivera or fixed).", "extra": "Prevents relapse that undoes gains.", "credits": 25}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Build or maintain slight positive canthal tilt illusion via makeup-free methods for men: slight upward brow tilt, good upper eyelid exposure via fat loss or bleph if severe.", "extra": "", "credits": 25}, {"category": "Hardmax / Surgical & Medical Interventions (High variance, high reward when indicated)", "tip_text": "For aggressive hair loss in transplant candidate: combine HT with PRP or exosomes adjunct if clinic offers.", "extra": "", "credits": 25}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Nails, hands, neck: keep nails short/clean, moisturize hands, shave or trim neck hair cleanly below beard line or full clean shave if no beard.", "extra": "", "credits": 25}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Color coordinate: choose clothing colors that flatter your skin undertone/hair/eyes (cool/warm analysis via apps or pro); avoid clashing.", "extra": "", "credits": 25}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Do chin tucks (3x10-15, hold 5-10s) + chin curls or plate neck work 3-4x per week to correct forward head posture and support jawline projection.", "extra": "Low cost, directly called out in cheat sheet thread comments as helpful.", "credits": 25}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Measure and track key ratios monthly: shoulder width, neck, waist at navel, BF estimate via photos/scale + tape.", "extra": "Adjust training/diet based on visual feedback not just scale.", "credits": 20}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Maintain short clean nails, filed, cuticles pushed; whiten teeth if yellowed (see dental section).", "extra": "Small but frequently noted in \"details\" comments.", "credits": 20}, {"category": "16-30: Skincare, Skin Quality & Texture (Universal high mention)", "tip_text": "Use a silk or satin pillowcase and change pillowcase 2-3x/week to reduce acne mechanica and hair breakage.", "extra": "Low effort high consistency.", "credits": 20}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "For curly/wavy: use sulfate-free shampoo, curl cream or gel on damp hair, diffuse or air dry for volume without frizz.", "extra": "Adapted from guide.", "credits": 20}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "If wisdom teeth impacting or causing crowding, extract under oral surgeon guidance before or during ortho planning.", "extra": "", "credits": 20}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Lip: if very thin upper, 0.5-1ml HA for subtle projection (male appropriate, avoid duck).", "extra": "Rare but mentioned.", "credits": 20}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Overall face harmony: use free or paid AI facial analysis tools (as discussed in LooksmaxingAdvice cheat sheet) on multiple well-lit neutral photos from front/side/45deg for baseline and tracking progress.", "extra": "", "credits": 20}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Document progress with consistent lighting/angle/pose photos every 4 weeks (front, side, 45, smile, neutral); use same camera/time of day.", "extra": "Essential for objective tracking per all communities.", "credits": 20}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Supplement biotin 5-10mg + collagen peptides 10-15g daily only if diet deficient; track if helps nails/hair quality.", "extra": "Low evidence but commonly tried.", "credits": 15}, {"category": "Hair, Beard & Eyebrows (High visual impact)", "tip_text": "Protect hair from sun/heat: hat outdoors, no daily hot tools, use leave-in conditioner or argan oil sparingly.", "extra": "", "credits": 15}, {"category": "46-55: Dental, Smile & Oral Structure", "tip_text": "Maintain fresh breath: tongue scrape daily, stay hydrated, address any tonsil stones or reflux.", "extra": "Small detail frequently mentioned in close interactions.", "credits": 15}, {"category": "56-70: Face-Specific Softmax & Minor Procedures", "tip_text": "Get professional lash lift/tint or use castor oil/serum nightly for longer lashes if short (subtle masculine enhancement).", "extra": "", "credits": 15}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Watch/jewelry: one quality simple watch (leather or metal band appropriate to outfit), no more than one ring/bracelet unless cultural; subtle status without flash.", "extra": "", "credits": 15}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Collagen or bone broth daily (15-20g) + adequate vitamin C for skin elasticity support during cut or post surgery.", "extra": "", "credits": 15}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Cold exposure: end showers with 30-60s cold, or ice face rolling 2-3x/week for temporary de-puff and circulation (supplement not replace skincare).", "extra": "", "credits": 15}, {"category": "Body Recomposition, Training & Frame (Highest leverage for most men)", "tip_text": "Use 5-10g creatine monohydrate daily + 3-5g beta alanine if desired for performance/recovery during training phases; monitor water retention on face during cut.", "extra": "", "credits": 10}, {"category": "86-99: Style, Grooming, Fragrance, Lifestyle Signals & Finishing Details", "tip_text": "Underwear and base layers that fit without lines or sagging; good quality socks that don't show ankle skin.", "extra": "Small confidence and silhouette detail.", "credits": 10}];
const faces = [{"name": "Alain Delon", "seed": 100}, {"name": "Marlon Brando", "seed": 101}, {"name": "Paul Newman", "seed": 102}, {"name": "Henry Cavill", "seed": 103}, {"name": "Brad Pitt", "seed": 104}, {"name": "Young Leo", "seed": 105}, {"name": "Tyson Beckford", "seed": 106}, {"name": "Jon-Erik Hexum", "seed": 107}, {"name": "Francisco Lachowski", "seed": 108}, {"name": "Rob Lowe", "seed": 109}, {"name": "Christian Bale", "seed": 110}, {"name": "Cary Grant", "seed": 111}, {"name": "Matt Bomer", "seed": 112}, {"name": "Ian Somerhalder", "seed": 113}, {"name": "David Gandy", "seed": 114}, {"name": "Mads Mikkelsen", "seed": 115}, {"name": "Sean O'Pry", "seed": 116}, {"name": "Gaspard Ulliel", "seed": 117}, {"name": "Cillian Murphy", "seed": 118}, {"name": "Johnny Depp", "seed": 119}, {"name": "Jude Law", "seed": 120}, {"name": "Zayn Malik", "seed": 121}, {"name": "Timothee Chalamet", "seed": 122}, {"name": "Oscar Isaac", "seed": 123}, {"name": "Jason Momoa", "seed": 124}];
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title="Peak Male Aesthetics" description="Data-grounded male aesthetic optimization protocols." />
        <meta name="robots" content="noindex, nofollow" />
        <style>
            .container {
                max-width: var(--width-prose);
                margin: 0 auto;
                padding: 0 1rem;
            }
            .poem {
                background: rgba(85, 107, 47, 0.05);
                border-left: 3px solid var(--accent-dark);
                padding: 1.5rem;
                margin: 2rem 0;
                font-family: var(--font-ui), serif;
                font-style: italic;
                color: var(--accent-dark);
                line-height: 1.6;
            }
            .poem p {
                margin: 0;
            }
            .filters {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                margin-bottom: 2rem;
            }
            .filter-btn {
                background: none;
                border: 1px solid var(--accent-dark);
                color: var(--accent-dark);
                padding: 0.4rem 0.8rem;
                font-family: var(--font-ui), sans-serif;
                font-size: 0.8rem;
                cursor: pointer;
                transition: all 0.2s ease;
            }
            .filter-btn:hover, .filter-btn.active {
                background: var(--accent-dark);
                color: #fff;
            }
            .tip-card {
                display: flex;
                flex-direction: column;
                margin-bottom: 2rem;
                padding: 1.5rem;
                border: 1px solid rgba(85, 107, 47, 0.2);
                background: rgba(255,255,255, 0.5);
                position: relative;
            }
            .credits-badge {
                position: absolute;
                top: -10px;
                right: -10px;
                background: var(--accent-dark);
                color: white;
                padding: 0.2rem 0.6rem;
                font-weight: bold;
                font-size: 0.8rem;
                font-family: var(--font-ui), monospace;
                border-radius: 4px;
            }
            .tip-cat {
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: rgb(var(--gray-dark));
                margin-bottom: 0.5rem;
            }
            .tip-text {
                font-weight: bold;
                margin-bottom: 0.5rem;
            }
            .tip-extra {
                font-size: 0.9em;
                color: rgb(var(--gray-dark));
            }
            .face-break {
                display: flex;
                flex-direction: column;
                align-items: center;
                margin: 3rem 0;
                opacity: 0.8;
            }
            .face-img {
                width: 150px;
                height: 150px;
                object-fit: cover;
                border-radius: 50%;
                filter: grayscale(100%);
                border: 2px solid var(--accent-dark);
                margin-bottom: 0.5rem;
            }
            .face-caption {
                font-size: 0.75rem;
                font-family: var(--font-ui), sans-serif;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                color: var(--accent-dark);
            }
            .minigame {
                margin: 4rem 0;
                padding: 2rem;
                border: 1px solid var(--accent-dark);
                text-align: center;
                background: #fdfdfc;
            }
            .game-canvas {
                width: 200px;
                height: 250px;
                margin: 0 auto;
                position: relative;
                border: 1px dashed #ccc;
                margin-bottom: 1rem;
            }
            .dude-part {
                position: absolute;
                transition: all 0.5s ease;
            }
            #dude-head {
                width: 60px;
                height: 70px;
                border: 2px solid black;
                border-radius: 50%;
                top: 20px;
                left: 70px;
                background: white;
            }
            #dude-jaw {
                width: 40px;
                height: 20px;
                border-bottom: 2px solid black;
                border-left: 2px solid black;
                border-right: 2px solid black;
                border-bottom-left-radius: 20px;
                border-bottom-right-radius: 20px;
                position: absolute;
                bottom: -10px;
                left: 8px;
                background: white;
                opacity: 0;
            }
            #dude-body {
                width: 4px;
                height: 80px;
                background: black;
                top: 90px;
                left: 98px;
            }
            #dude-shoulders {
                width: 40px;
                height: 4px;
                background: black;
                top: 110px;
                left: 80px;
            }
            #dude-hair {
                width: 60px;
                height: 20px;
                background: #333;
                border-top-left-radius: 30px;
                border-top-right-radius: 30px;
                position: absolute;
                top: -5px;
                left: -2px;
                opacity: 0;
            }
            .game-controls button {
                background: white;
                border: 1px solid var(--accent-dark);
                padding: 0.5rem 1rem;
                margin: 0.2rem;
                cursor: pointer;
                font-family: var(--font-ui), sans-serif;
            }
            .game-controls button:hover {
                background: var(--accent-dark);
                color: white;
            }
            .score-display {
                font-family: monospace;
                font-size: 1.2rem;
                font-weight: bold;
                color: var(--accent-dark);
                margin-bottom: 1rem;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div class="container">
                <section class="page-lede">
                    <p class="kicker">Looksmaxing Data Synthesis</p>
                    <h1>The 5,000 Credits</h1>
                    <p>
                        A strictly data-grounded synthesis of male aesthetic optimization protocols, scored by observed return on investment.
                    </p>
                </section>
                
                <div class="poem">
                    <p>Some say that beauty comes from within,</p>
                    <p>A gentle heart, a lack of sin.</p>
                    <p>But data shows the jawline rules,</p>
                    <p>And everything else is for the fools.</p>
                    <p>If you desire the female gaze,</p>
                    <p>You must prepare for leaner days.</p>
                    <p>The credits tell a truthful tale,</p>
                    <p>Invest in bone, or sadly fail.</p>
                </div>

                <div class="minigame">
                    <h3>Ascension Simulator</h3>
                    <p>Allocate effort to optimize the subject.</p>
                    <div class="score-display">SMV Score: <span id="smv-score">3.0</span>/10</div>
                    <div class="game-canvas">
                        <div id="dude-head" class="dude-part">
                            <div id="dude-hair"></div>
                            <div id="dude-jaw"></div>
                        </div>
                        <div id="dude-shoulders" class="dude-part"></div>
                        <div id="dude-body" class="dude-part"></div>
                    </div>
                    <div class="game-controls">
                        <button onclick="applyMewing()">Orthotropics (Mew)</button>
                        <button onclick="applyLifting()">Hypertrophy (Lift)</button>
                        <button onclick="applyFinasteride()">Finasteride (Hair)</button>
                        <button onclick="applyLeaning()">Caloric Deficit (Cut)</button>
                    </div>
                </div>

                <div class="filters" id="filter-container">
                    <button class="filter-btn active" data-cat="all">All Categories</button>
                    {categories.map(cat => (
                        <button class="filter-btn" data-cat={cat}>{cat}</button>
                    ))}
                </div>

                <div id="tips-container">
                    {tips.map((tip, index) => (
                        <>
                            <div class="tip-card" data-cat={tip.category}>
                                <div class="credits-badge">{tip.credits} CR</div>
                                <div class="tip-cat">{tip.category}</div>
                                <div class="tip-text">{tip.tip_text}</div>
                                <div class="tip-extra">{tip.extra}</div>
                            </div>
                            
                            {index > 0 && index % 4 === 0 && index / 4 <= faces.length ? (
                                <div class="face-break" data-cat={tip.category}>
                                    <img src={`https://picsum.photos/seed/${faces[(index/4)-1].seed}/150`} alt={faces[(index/4)-1].name} class="face-img" />
                                    <div class="face-caption">{faces[(index/4)-1].name}</div>
                                </div>
                            ) : null}
                        </>
                    ))}
                </div>
            </div>
        </main>
        <Footer />
        
        <script>
            // Filtering logic
            document.addEventListener('DOMContentLoaded', () => {
                const buttons = document.querySelectorAll('.filter-btn');
                const cards = document.querySelectorAll('.tip-card, .face-break');
                
                buttons.forEach(btn => {
                    btn.addEventListener('click', () => {
                        buttons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        
                        const cat = btn.getAttribute('data-cat');
                        
                        cards.forEach(card => {
                            if (cat === 'all' || card.getAttribute('data-cat') === cat) {
                                card.style.display = card.classList.contains('face-break') ? 'flex' : 'flex';
                            } else {
                                card.style.display = 'none';
                            }
                        });
                    });
                });
            });
            
            // Minigame logic
            let score = 3.0;
            let mewed = false;
            let lifted = false;
            let haired = false;
            let leaned = false;
            
            function updateScore() {
                document.getElementById('smv-score').innerText = score.toFixed(1);
                if (score >= 8.0) {
                    document.getElementById('smv-score').style.color = '#ff4500';
                    document.getElementById('smv-score').innerText += ' (Chadlite)';
                }
            }
            
            window.applyMewing = () => {
                if(mewed) return;
                mewed = true;
                score += 1.5;
                document.getElementById('dude-jaw').style.opacity = '1';
                document.getElementById('dude-jaw').style.width = '50px';
                document.getElementById('dude-jaw').style.left = '3px';
                document.getElementById('dude-jaw').style.borderBottomLeftRadius = '5px';
                document.getElementById('dude-jaw').style.borderBottomRightRadius = '5px';
                updateScore();
            };
            
            window.applyLifting = () => {
                if(lifted) return;
                lifted = true;
                score += 1.0;
                document.getElementById('dude-shoulders').style.width = '80px';
                document.getElementById('dude-shoulders').style.left = '60px';
                document.getElementById('dude-shoulders').style.height = '15px';
                updateScore();
            };
            
            window.applyFinasteride = () => {
                if(haired) return;
                haired = true;
                score += 1.2;
                document.getElementById('dude-hair').style.opacity = '1';
                updateScore();
            };
            
            window.applyLeaning = () => {
                if(leaned) return;
                leaned = true;
                score += 1.3;
                document.getElementById('dude-head').style.width = '45px';
                document.getElementById('dude-head').style.left = '77.5px';
                updateScore();
            };
        </script>
    </body>
</html>
