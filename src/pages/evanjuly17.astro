---
const stops = [
  { rank: '01', name: 'The Magician', area: 'Lower East Side', moment: 'The opener', score: '9.3', price: '$', social: 'High', crowd: 'Late 20s / early 30s', note: 'A red-neon room with enough motion to make talking to strangers feel normal. Start here before the night becomes a project.', why: 'The best all-around answer: busy, unpretentious, cheap enough to stay loose, and never trying to turn the night into a nightclub audition.', photos: [{src:'https://media.timeout.com/images/105917118/1024/576/image.jpg',label:'INTERIOR'},{src:'https://media.timeout.com/images/105917119/1024/576/image.jpg',label:'IN THE ROOM'}], source:'https://www.timeout.com/newyork/bars/the-magician', maps: 'https://maps.google.com/?q=The+Magician+118+Rivington+Street+NYC', site: 'https://www.themagicianbar.com/' },
  { rank: '02', name: 'Bua', area: 'St. Marks / East Village', moment: 'The reliable middle', score: '9.0', price: '$$', social: 'High', crowd: '25–32 sweet spot', note: 'An open-front room with a happy, low-stakes current. Easy to enter, easy to linger, easy to leave with a larger group than you arrived with.', why: 'Bua has the night-to-night consistency. It is the right kind of busy: social rather than precious, and lively without the awful bottle-service undertow.', photos: [{src:'https://images.getbento.com/accounts/c44f61e7a149fc1687b176d796599dfb/media/images/5079168820063016bua.jpg?w=1200&fit=max&auto=compress,format&cs=origin',label:'INTERIOR'},{src:'https://images.getbento.com/accounts/c44f61e7a149fc1687b176d796599dfb/media/images/66850buainfo.jpeg?w=1200&fit=crop&auto=compress,format&cs=origin&crop=focalpoint&fp-x=0.47&fp-y=0.5',label:'IN THE ROOM'}], source:'https://www.buabar.com/', maps: 'https://maps.google.com/?q=Bua+122+St+Marks+Place+NYC', site: 'https://www.buabar.com/' },
  { rank: '03', name: 'The Lions', area: 'East Village', moment: 'The polished pivot', score: '8.7', price: '$$', social: 'Medium-high', crowd: '28–35', note: 'Burgers, cold beer, martinis, and a good-looking room that stops short of becoming a scene.', why: 'Pick this when the group wants a touch more polish and a crowd that has generally aged out of the first-job stampede.', photos: [{src:'https://res.cloudinary.com/the-infatuation/image/upload/c_fill,w_1200,ar_4:3,g_west,f_auto/images/NYC_TheLionsBarandGrill_WillHartmaniPhoneContent_EDIT_02_an9hox',label:'INTERIOR'}], source:'https://www.theinfatuation.com/new-york/reviews/the-lions-bar-and-grill', maps: 'https://maps.google.com/?q=The+Lions+132+First+Avenue+NYC', site: 'https://www.thelionsbar.com/' },
  { rank: '04', name: 'Ace Bar', area: 'Alphabet City', moment: 'The stranger-maker', score: '8.6', price: '$', social: 'Very high', crowd: 'Mixed, adult dive energy', note: 'Pool, darts, skee-ball, pinball. A bar with built-in reasons to say something besides “what are you drinking?”', why: 'The strongest place to convert a group night into a meeting-people night. Play something, lose something, talk to whoever is next.', photos: [{src:'https://res.cloudinary.com/the-infatuation/image/upload/c_fill,w_1200,ar_4:3,g_center,f_auto/NYC_AceBar_Interiors_AlexStaniloff-1_jqgumc',label:'INTERIOR'},{src:'https://res.cloudinary.com/the-infatuation/image/upload/c_fill,w_1200,ar_4:3,g_center,f_auto/NYC_AceBar_Interiors_AlexStaniloff-2_pwv64b',label:'IN THE ROOM'}], source:'https://www.theinfatuation.com/new-york/reviews/ace-bar', maps: 'https://maps.google.com/?q=Ace+Bar+531+East+5th+Street+NYC', site: 'https://www.acebar.com/' },
  { rank: '05', name: 'B-Side', area: 'Avenue C', moment: 'The soft landing', score: '8.3', price: '$', social: 'Medium', crowd: 'Neighborhood 20s / 30s', note: 'Relaxed and lived-in, with the mood of a neighborhood bar that did not receive a brand refresh.', why: 'For a group that wants the East Village without the pressure to make an entrance. Best as an early or late change of temperature.', photos: [{src:'https://static.wixstatic.com/media/dafa98_0d13962807b74c96a120499b8fed48ce~mv2.jpg',label:'INTERIOR'},{src:'https://static.wixstatic.com/media/dafa98_bcaa093095c744f393840fd528e229a1~mv2.jpg',label:'IN THE ROOM'}], source:'https://www.bsidenyc.bar/', maps: 'https://maps.google.com/?q=B-Side+131+Avenue+C+NYC', site: 'https://www.bsidenyc.bar/' },
  { rank: '06', name: '169 Bar', area: 'Chinatown / LES', moment: 'The cheap weird option', score: '8.2', price: '$', social: 'High', crowd: 'Can skew younger late', note: 'Funky, loud, a little strange, with cocktails that do not punish the wallet.', why: 'A wonderful choice before midnight. After that, the same energy can tilt recent-grad and feral. Use it with intention.', photos: [{src:'https://res.cloudinary.com/the-infatuation/image/upload/c_fill,w_1200,ar_4:3,g_center,f_auto/NYC_169Bar_NoahDevereaux_jciby8',label:'INTERIOR'},{src:'https://s.yimg.com/bj/3d00/3d00638bdb15604068e619f8687c4aae.jpg',label:'IN THE ROOM'}], source:'https://local.yahoo.com/info-11034018-169-bar-new-york/', maps: 'https://maps.google.com/?q=169+Bar+169+East+Broadway+NYC', site: 'https://169barnyc.com/' },
  { rank: '07', name: 'The Wayland', area: 'Alphabet City', moment: 'The music answer', score: '8.1', price: '$$', social: 'Medium', crowd: 'Creative 25–35', note: 'Cocktails, warmth, live music, and a room that feels more house party than hunt.', why: 'Choose it when cool means people with stories rather than the largest possible crowd. Less random mingling, better conversation.', photos: [{src:'https://res.cloudinary.com/the-infatuation/image/upload/c_fill,w_1200,ar_4:3,g_west,f_auto/NYC_The_Wayland_0123_horizontal_obbi4j',label:'INTERIOR'}], source:'https://www.theinfatuation.com/new-york/reviews/the-wayland', maps: 'https://maps.google.com/?q=The+Wayland+700+East+9th+Street+NYC', site: 'https://www.thewaylandnyc.com/' },
];

