  { name: 'Ray’s', area: 'Lower East Side', price: '$$', fit: 'Dance-adjacent', note: 'A crowded, loose room for when a bar should feel like an event.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/cms/reviews/rays/banners/1565386930.36', source: 'https://www.theinfatuation.com/new-york/reviews/rays' },
