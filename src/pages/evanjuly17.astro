  { name: 'Mister Paradise', area: 'East Village', price: '$$', fit: 'Polished but easy', note: 'More considered than a dive, still casual enough for an actual bar night.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/cms/reviews/mister-paradise/banners/1552400365.25', source: 'https://www.theinfatuation.com/new-york/reviews/mister-paradise' },
  { name: 'Fish Bar', area: 'East Village', price: '$', fit: 'Weird and cheap', note: 'Fish-tank theme, affordable drinks, no pretense. Use before it gets too packed.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/cms/reviews/fish-bar-2/banners/banner_image', source: 'https://www.theinfatuation.com/new-york/reviews/fish-bar-nyc' },
  { name: "McSorley’s Old Ale House", area: 'East Village', price: '$', fit: 'Historic curveball', note: 'A shared-table classic. Go for the ritual and the room, not a bespoke cocktail.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/images/NYC_McSorley_s_WillHartman_iPhoneContent_EDIT_01_cypqf7', source: 'https://www.theinfatuation.com/new-york/reviews/mcsorleys' },
  { name: 'Reservoir', area: 'Greenwich Village', price: '$$', fit: 'Sports-bar pivot', note: 'Loud, sprawling, and useful if the group wants uncomplicated beer-and-shots energy.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/images/reservoir-2095_bsiqdz', source: 'https://www.theinfatuation.com/new-york/reviews/reservoir' },
  { name: "Conall’s Public House", area: 'East Village', price: '$$', fit: 'Irish-pub warmth', note: 'A friendly, pubby option when a drinkable, normal room is the whole point.', image: 'https://conallspublichouse.com/wp-content/uploads/2026/05/image12.jpeg', source: 'https://conallspublichouse.com/' },
  { name: 'Parkside Lounge', area: 'Lower East Side', price: '$', fit: 'Rock-and-roll dive', note: 'For a late, messy, music-leaning turn. Character wins over comfort.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/images/PXL_20241024_224935422_ezdcu8', source: 'https://www.theinfatuation.com/new-york/reviews/parkside-lounge' },
  { name: 'Dream Baby', area: 'East Village', price: '$$', fit: 'Tiny cocktail den', note: 'A dark, intimate cocktail room for a smaller group or a strategic reset.', image: 'https://res.cloudinary.com/the-infatuation/image/upload/c_scale,w_1200,q_auto,f_auto/NYC_DreamBaby_Interiors_AlexStaniloff-1_hywbeg', source: 'https://www.theinfatuation.com/new-york/reviews/dream-baby' },
