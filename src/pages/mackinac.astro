  </main>

  <script>
    const slides = Array.from(document.querySelectorAll<HTMLElement>('.slide'));
    const btnNext = document.getElementById('btnNext') as HTMLButtonElement;
    const btnBack = document.getElementById('btnBack') as HTMLButtonElement;
    const progressFill = document.getElementById('progressFill') as HTMLElement;
    const stepLabel = document.getElementById('stepLabel') as HTMLElement;
    const stepCount = document.getElementById('stepCount') as HTMLElement;

    const TOTAL = slides.length;
    let current = 0;

    const nextLabels: Record<number, string> = {
      0: 'Begin Guide →',
    };
    const DEFAULT_NEXT = 'Next →';
    const LAST_LABEL = 'Done ✓';

    function goTo(index: number, direction: 'forward' | 'back') {
      const prev = slides[current];
      prev.classList.remove('active');
      prev.classList.add('exit');

      if (direction === 'back') {
        prev.style.transform = 'translateX(28px)';
        prev.style.opacity = '0';
      }

      setTimeout(() => {
        prev.classList.remove('exit');
        prev.style.transform = '';
        prev.style.opacity = '';
      }, 250);

      current = index;
      const next = slides[current];

      if (direction === 'back') {
        next.style.transform = 'translateX(-28px)';
        next.style.opacity = '0';
        next.offsetHeight; // force reflow
      }

      next.classList.add('active');

      if (direction === 'back') {
        requestAnimationFrame(() => {
          next.style.transition = 'opacity 0.22s ease, transform 0.22s ease';
          next.style.transform = '';
          next.style.opacity = '';
        });
      }

      // Update UI
      const pct = ((current + 1) / TOTAL) * 100;
      progressFill.style.width = `${pct}%`;
      stepLabel.textContent = next.dataset.label ?? '';
      stepCount.textContent = `${current + 1} / ${TOTAL}`;

      btnNext.textContent = current === TOTAL - 1
        ? LAST_LABEL
        : (nextLabels[current] ?? DEFAULT_NEXT);

      if (current > 0) btnBack.classList.add('visible');
      else btnBack.classList.remove('visible');
    }

    btnNext.addEventListener('click', () => {
      if (current < TOTAL - 1) goTo(current + 1, 'forward');
    });

    btnBack.addEventListener('click', () => {
      if (current > 0) goTo(current - 1, 'back');
    });

    // Keyboard nav
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') btnNext.click();
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') btnBack.click();
    });

    // Touch swipe
    let touchStartX = 0;
    document.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    document.addEventListener('touchend', (e) => {
      const dx = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 50) {
        if (dx > 0) btnNext.click();
        else btnBack.click();
      }
    }, { passive: true });
  </script>
