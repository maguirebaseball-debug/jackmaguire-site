    <!-- TAB BAR -->
    <div class="tab-bar" role="tablist">
      <button class="tab-btn active" data-panel="plan" role="tab">
        <span class="t-icon">📋</span>
        <span class="t-label">Plan</span>
      </button>
      <button class="tab-btn" data-panel="island" role="tab">
