---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Mackinac 2026 — Trip Guide"
    description="Four days at the top of Michigan. Free swimming holes, the car-free island, laborers' bars, and the history underneath all of it."
  />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    /* ═══ CNT DESIGN TOKENS ═════════════════════════════════════ */
    :root {
      --cream:     #FAF8F2;
      --ink:       #1C1916;
      --ink-soft:  #3D3A34;
      --muted:     #6E6A60;
      --faint:     #A09890;
      --rule:      #DDD9CE;
      --warm-wh:   #FFFDF8;

      --gold:      #C9A264;
      --gold-dk:   #8B6420;
      --gold-lt:   #F4E6C8;
      --gold-bg:   #FBF4E4;

      --dark:      #18160F;
      --dark-soft: #2A2720;
      --dark-text: #F0EBE0;
      --dark-muted:#B8B0A0;

      --serif: Georgia, 'Times New Roman', serif;
      --sans:  'Helvetica Neue', Helvetica, Arial, sans-serif;

      --tab-h:  56px;
      --radius: 6px;
    }

    html, body {
      background: var(--cream);
      margin: 0;
      font-family: var(--serif);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }

    /* ═══ APP SHELL ═════════════════════════════════════════════ */
    .app-masthead {
      background: var(--dark);
      padding: 1.5rem 1.25rem 1.25rem;
    }

    .am-eyebrow {
      font-family: var(--sans);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.6rem;
    }

    .am-title {
      font-family: var(--serif);
      font-size: clamp(1.6rem, 7vw, 2.2rem);
      font-style: italic;
      font-weight: 400;
      color: #fff;
      line-height: 1.08;
      margin: 0 0 0.7rem;
      letter-spacing: -0.02em;
    }

    .am-meta {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .am-pill {
      font-family: var(--sans);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.1);
      color: var(--dark-muted);
      padding: 0.3rem 0.65rem;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    /* ═══ STAT ROW ══════════════════════════════════════════════ */
    .stat-row {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      background: var(--dark-soft);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      -webkit-overflow-scrolling: touch;
    }

    .stat-row::-webkit-scrollbar { display: none; }

    .stat-cell {
      flex: 0 0 auto;
      min-width: 90px;
      padding: 0.9rem 1rem;
      text-align: center;
      border-right: 1px solid rgba(255,255,255,0.06);
    }

    .sc-n {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.35rem;
      color: var(--gold);
      line-height: 1;
    }

    .sc-l {
      font-family: var(--sans);
      font-size: 0.52rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--dark-muted);
      margin-top: 0.2rem;
      line-height: 1.3;
    }

    /* ═══ TAB BAR ═══════════════════════════════════════════════ */
    .tab-bar {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      background: var(--dark);
      border-bottom: 1px solid rgba(201,162,100,0.3);
      -webkit-overflow-scrolling: touch;
    }

    .tab-bar::-webkit-scrollbar { display: none; }

    .tab-btn {
      flex: 0 0 auto;
      padding: 0 1.1rem;
      height: var(--tab-h);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
      border: none;
      background: transparent;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: border-color 0.15s, color 0.15s;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    .tab-btn .t-icon {
      font-size: 1.1rem;
      line-height: 1;
    }

    .tab-btn .t-label {
      font-family: var(--sans);
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dark-muted);
      transition: color 0.15s;
    }

    .tab-btn.active {
      border-bottom-color: var(--gold);
    }

    .tab-btn.active .t-label { color: var(--gold); }
    .tab-btn.active .t-icon { filter: none; }
    .tab-btn:not(.active) .t-icon { opacity: 0.45; }

    /* ═══ PANELS ════════════════════════════════════════════════ */
    .panel {
      display: none;
      padding: 0 0 4rem;
    }

    .panel.active { display: block; }

    .panel-inner {
      max-width: 640px;
      margin: 0 auto;
      padding: 0 1.1rem;
    }

    /* ═══ SECTION HEADERS ═══════════════════════════════════════ */
    .sec-head {
      padding: 2rem 0 0.6rem;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 1.2rem;
    }

    .sec-eyebrow {
      font-family: var(--sans);
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.3rem;
    }

    .sec-title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-style: italic;
      font-weight: 400;
      color: var(--ink);
      margin: 0;
      line-height: 1.2;
    }

    /* ═══ CARDS ═════════════════════════════════════════════════ */
    .card {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      padding: 1.1rem 1.2rem;
      margin-bottom: 0.75rem;
    }

    .card-dark {
      background: var(--dark);
      border-color: transparent;
      border-left: 3px solid var(--gold);
    }

    .card-gold {
      background: var(--gold-bg);
      border: 1px solid var(--gold-lt);
      border-radius: var(--radius);
      padding: 1.1rem 1.2rem;
      margin-bottom: 0.75rem;
    }

    /* ═══ ACTIVITY CARD ═════════════════════════════════════════ */
    .act-card {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      margin-bottom: 0.75rem;
      overflow: hidden;
    }

    .act-card-body { padding: 1rem 1.1rem 0.9rem; }

    .act-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.7rem;
      margin-bottom: 0.5rem;
    }

    .act-name {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--ink);
      margin: 0;
      line-height: 1.25;
      flex: 1;
    }

    .badge {
      font-family: var(--sans);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.25rem 0.55rem;
      border-radius: 3px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .b-free     { background: #DFF2CE; color: #245A0E; }
    .b-cheap    { background: #FDF1CC; color: #7A5200; }
    .b-moderate { background: #FCE4D8; color: #8A2010; }
    .b-local    { background: var(--dark); color: var(--gold); border: 1px solid var(--gold); }

    .act-desc {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--muted);
      margin: 0 0 0.6rem;
    }

    .act-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.6rem 1.1rem;
      background: var(--cream);
      border-top: 1px solid var(--rule);
    }

    .act-meta {
      font-family: var(--sans);
      font-size: 0.62rem;
      color: var(--faint);
      letter-spacing: 0.02em;
    }

    .map-link {
      font-family: var(--sans);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gold-dk);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .map-link:hover { color: var(--gold); }

    /* ═══ LOCAL TIP CARD ════════════════════════════════════════ */
    .tip-card {
      background: var(--dark);
      border-left: 3px solid var(--gold);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 1.1rem 1.2rem;
      margin-bottom: 0.75rem;
    }

    .tip-ey {
      font-family: var(--sans);
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.5rem;
    }

    .tip-body {
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--dark-muted);
      margin: 0;
    }

    .tip-body strong,
    .tip-body em { color: var(--dark-text); font-style: italic; font-weight: 400; }

    /* ═══ PULL QUOTE ════════════════════════════════════════════ */
    .pq {
      border-top: 2px solid var(--gold);
      border-bottom: 1px solid var(--rule);
      padding: 1.2rem 0;
      margin: 1.5rem 0;
    }

    .pq p {
      font-family: var(--serif);
      font-size: clamp(1.1rem, 4.5vw, 1.45rem);
      font-style: italic;
      line-height: 1.35;
      color: var(--ink);
      margin: 0;
    }

    /* ═══ PROPERTY CARD ═════════════════════════════════════════ */
    .property-card {
      background: var(--dark);
      border-radius: var(--radius);
      overflow: hidden;
      margin-bottom: 1rem;
    }

    .pc-header {
      padding: 1.2rem 1.3rem;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .pc-ey {
      font-family: var(--sans);
      font-size: 0.55rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }

    .pc-name {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.15rem;
      color: #fff;
      margin: 0 0 0.3rem;
    }

    .pc-sub {
      font-family: var(--sans);
      font-size: 0.62rem;
      color: var(--dark-muted);
    }

    .pc-specs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    .pc-spec {
      padding: 0.85rem 1.2rem;
      border-right: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .pc-spec:nth-child(even) { border-right: none; }

    .pcs-l {
      font-family: var(--sans);
      font-size: 0.52rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gold);
      margin-bottom: 0.2rem;
      opacity: 0.7;
    }

    .pcs-v {
      font-size: 0.85rem;
      color: var(--dark-text);
      line-height: 1.4;
    }

    /* ═══ FERRY TABLE ════════════════════════════════════════════ */
    .ferry-card {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      overflow: hidden;
      margin-bottom: 0.75rem;
    }

    .fc-head {
      background: var(--gold-bg);
      padding: 0.7rem 1.1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--gold-lt);
    }

    .fc-name {
      font-family: var(--sans);
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--ink);
    }

    .fc-price {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1.1rem;
      color: var(--gold-dk);
    }

    .fc-body {
      padding: 0.8rem 1.1rem;
    }

    .fc-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.83rem;
      padding: 0.3rem 0;
      border-bottom: 1px solid var(--rule);
      color: var(--muted);
    }

    .fc-row:last-child { border-bottom: none; }

    .fc-row span:first-child {
      font-family: var(--sans);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--faint);
      display: flex;
      align-items: center;
    }

    /* ═══ DAY CARDS ═════════════════════════════════════════════ */
    .day-card {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      overflow: hidden;
      margin-bottom: 0.75rem;
    }

    .dc-head {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.9rem 1.1rem;
      background: var(--dark-soft);
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    .dc-tag {
      font-family: var(--sans);
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      background: rgba(201,162,100,0.15);
      border: 1px solid rgba(201,162,100,0.3);
      padding: 0.25rem 0.6rem;
      border-radius: 3px;
      white-space: nowrap;
    }

    .dc-title {
      font-family: var(--serif);
      font-style: italic;
      font-size: 0.95rem;
      color: var(--dark-text);
      flex: 1;
    }

    .dc-chevron {
      font-size: 0.8rem;
      color: var(--dark-muted);
      transition: transform 0.2s;
      flex-shrink: 0;
    }

    .day-card.open .dc-chevron { transform: rotate(180deg); }

    .dc-body {
      display: none;
      padding: 0.8rem 1.1rem;
    }

    .day-card.open .dc-body { display: block; }

    .srow {
      display: grid;
      grid-template-columns: 70px 1fr;
      gap: 0.2rem 0.8rem;
      margin-bottom: 0.75rem;
    }

    .srow:last-child { margin-bottom: 0; }

    .st {
      font-family: var(--sans);
      font-size: 0.58rem;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--faint);
      padding-top: 0.2rem;
      line-height: 1.3;
    }

    .sv {
      font-size: 0.88rem;
      line-height: 1.6;
      color: var(--muted);
    }

    .sv strong { color: var(--ink); font-style: italic; font-weight: 400; }

    /* ═══ FOOD CARDS ════════════════════════════════════════════ */
    .food-card {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      margin-bottom: 0.75rem;
      overflow: hidden;
    }

    .food-top {
      padding: 0.9rem 1.1rem 0.5rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.6rem;
    }

    .food-name {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--ink);
      margin: 0;
    }

    .food-price {
      font-family: var(--sans);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--gold-dk);
      white-space: nowrap;
    }

    .food-desc {
      font-size: 0.87rem;
      line-height: 1.65;
      color: var(--muted);
      padding: 0 1.1rem 1rem;
      margin: 0;
    }

    .food-tag {
      font-family: var(--sans);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.4rem 1.1rem;
      background: var(--cream);
      border-top: 1px solid var(--rule);
      color: var(--faint);
    }

    /* ═══ HISTORY ACCORDION ═════════════════════════════════════ */
    .hist-item {
      border-bottom: 1px solid var(--rule);
      overflow: hidden;
    }

    .hist-item:first-child { border-top: 1px solid var(--rule); }

    .hist-btn {
      width: 100%;
      padding: 1rem 0;
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      -webkit-tap-highlight-color: transparent;
    }

    .hist-cat {
      font-family: var(--sans);
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .hist-hed {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--ink);
      line-height: 1.3;
    }

    .hist-body {
      display: none;
      font-size: 0.88rem;
      line-height: 1.7;
      color: var(--muted);
      padding-bottom: 1.1rem;
    }

    .hist-body.open { display: block; }
    .hist-body em { color: var(--ink-soft); font-style: italic; }

    /* ═══ COST BLOCK ════════════════════════════════════════════ */
    .cost-block {
      background: var(--dark);
      border-radius: var(--radius);
      padding: 1.5rem 1.3rem;
      margin-top: 0.75rem;
    }

    .cb-hed {
      font-family: var(--sans);
      font-size: 0.55rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 1rem;
    }

    .crow {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      font-size: 0.87rem;
    }

    .crow:last-child {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.18);
      padding-top: 0.75rem;
      margin-top: 0.2rem;
      font-size: 0.95rem;
    }

    .crow .cl { color: rgba(255,255,255,0.6); flex: 1; }
    .crow .cv { color: var(--gold-lt); font-style: italic; font-family: var(--serif); white-space: nowrap; }
    .crow:last-child .cl { color: #fff; }
    .crow:last-child .cv { color: #fff; }

    /* ═══ SWIM CARD ═════════════════════════════════════════════ */
    .swim-card {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      margin-bottom: 0.75rem;
      overflow: hidden;
    }

    .swim-top {
      padding: 1rem 1.1rem 0.5rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.6rem;
    }

    .swim-name {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--ink);
      margin: 0;
    }

    .swim-desc {
      font-size: 0.87rem;
      line-height: 1.65;
      color: var(--muted);
      padding: 0 1.1rem 0.5rem;
      margin: 0;
    }

    .swim-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.55rem 1.1rem;
      background: var(--cream);
      border-top: 1px solid var(--rule);
    }

    .swim-dist {
      font-family: var(--sans);
      font-size: 0.6rem;
      color: var(--faint);
      letter-spacing: 0.03em;
    }

    /* ═══ HACK CARD ═════════════════════════════════════════════ */
    .hack-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    @media (min-width: 480px) {
      .hack-list { grid-template-columns: 1fr 1fr; }
    }

    .hack {
      background: var(--warm-wh);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
      padding: 0.95rem 1rem;
    }

    .hack-h {
      font-family: var(--sans);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin: 0 0 0.3rem;
    }

    .hack-b {
      font-size: 0.85rem;
      line-height: 1.58;
      color: var(--muted);
      margin: 0;
    }

    /* ═══ PROSE ═════════════════════════════════════════════════ */
    .p {
      font-size: 0.93rem;
      line-height: 1.72;
      color: var(--ink-soft);
      margin: 0 0 1rem;
    }

    .p-lead {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--ink-soft);
      margin: 0 0 1.1rem;
    }

    /* ═══ GRUNGY ENTRY ══════════════════════════════════════════ */
    .grungy-card {
      border-bottom: 1px solid var(--rule);
      padding: 1rem 0;
    }

    .grungy-card:first-child { border-top: 1px solid var(--rule); }

    .gr-name {
      font-family: var(--serif);
      font-style: italic;
      font-size: 1rem;
      color: var(--ink);
      margin: 0 0 0.35rem;
    }

    .gr-body {
      font-size: 0.87rem;
      line-height: 1.65;
      color: var(--muted);
      margin: 0;
    }

    .gr-body em { color: var(--ink-soft); font-style: italic; }

    /* ═══ FOOTER NOTE ═══════════════════════════════════════════ */
    .closing-card {
      background: var(--dark-soft);
      border-radius: var(--radius);
      padding: 1.4rem 1.3rem;
      margin: 1.5rem 0 0;
    }

    .closing-card p {
      font-family: var(--serif);
      font-style: italic;
      font-size: 0.95rem;
      line-height: 1.72;
      color: var(--dark-muted);
      margin: 0;
    }

    /* ═══ RESPONSIVE ════════════════════════════════════════════ */
    @media (min-width: 600px) {
      .am-title { font-size: 2.4rem; }
      .panel-inner { padding: 0 1.5rem; }
    }
  </style>
</head>
<body>
  <Header />
  <main>

    <!-- MASTHEAD -->
    <div class="app-masthead">
