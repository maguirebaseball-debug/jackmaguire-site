---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Mackinac 2026 — Trip Guide"
    description="Four days at the top of Michigan. Free swimming holes, the car-free island, laborers' bars, and the history underneath all of it."
  />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --cream:    #FAF8F2;
      --ink:      #1C1916;
      --muted:    #6E6A60;
      --faint:    #A09890;
      --rule:     #DDD9CE;
      --gold:     #C9A264;
      --gold-dk:  #8B6420;
      --gold-lt:  #F4E6C8;
      --gold-bg:  #FBF4E4;
      --dark:     #18160F;
      --dark-2:   #2A2720;
      --dark-txt: #F0EBE0;
      --dark-mut: #B8B0A0;
      --sans:     'Inter', system-ui, sans-serif;
      --mono:     'IBM Plex Mono', monospace;
      --r:        8px;
    }

    /* ── SHELL: body fills viewport, header + guide split it ─── */
    html { height: 100%; }

    body {
      margin: 0;
      font-family: var(--sans);
      background: var(--dark);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      height: 100dvh;
      overflow: hidden;
    }

    /* site header stays as-is; main takes the rest */
    main {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── GUIDE SHELL ────────────────────────────────────────────── */
    #guide {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: var(--dark);
      position: relative;
    }

    /* ── PROGRESS BAR ───────────────────────────────────────────── */
    .progress-track {
      height: 2px;
      background: rgba(255,255,255,0.08);
      flex-shrink: 0;
    }

    .progress-fill {
      height: 100%;
      background: var(--gold);
      transition: width 0.35s ease;
    }

    /* ── STEP HEADER ────────────────────────────────────────────── */
    .step-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.6rem 1.1rem 0.4rem;
      flex-shrink: 0;
    }

    .step-label {
      font-family: var(--sans);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .step-count {
      font-family: var(--mono);
      font-size: 0.6rem;
      color: var(--dark-mut);
    }

    /* ── SLIDES VIEWPORT ────────────────────────────────────────── */
    .slides-viewport {
      flex: 1;
      min-height: 0;
      position: relative;
      overflow: hidden;
    }

    .slide {
      position: absolute;
      inset: 0;
      padding: 0.6rem 1.1rem 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      opacity: 0;
      transform: translateX(28px);
      transition: opacity 0.22s ease, transform 0.22s ease;
      pointer-events: none;
      overflow: hidden;
    }

    .slide.active {
      opacity: 1;
      transform: translateX(0);
      pointer-events: all;
    }

    .slide.exit {
      opacity: 0;
      transform: translateX(-28px);
    }

    /* ── NAV BAR ────────────────────────────────────────────────── */
    .guide-nav {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.65rem 1.1rem 0.8rem;
      flex-shrink: 0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .btn-back {
      font-family: var(--sans);
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--dark-mut);
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 0.5rem 0.6rem;
      -webkit-tap-highlight-color: transparent;
      flex-shrink: 0;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s;
    }

    .btn-back.visible {
      opacity: 1;
      pointer-events: all;
    }

    .btn-next {
      flex: 1;
      font-family: var(--sans);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: var(--dark);
      background: var(--gold);
      border: none;
      border-radius: var(--r);
      padding: 0.9rem 1rem;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: background 0.12s, transform 0.08s;
      min-height: 48px;
    }

    .btn-next:active { transform: scale(0.98); background: var(--gold-dk); color: #fff; }

    /* ── SLIDE COMPONENTS ───────────────────────────────────────── */

    /* Slide title block */
    .s-eye {
      font-family: var(--sans);
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      flex-shrink: 0;
    }

    .s-title {
      font-family: var(--sans);
      font-size: clamp(1.4rem, 5.5vw, 1.9rem);
      font-weight: 800;
      color: #fff;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin: 0;
      flex-shrink: 0;
    }

    .s-sub {
      font-size: 0.83rem;
      color: var(--dark-mut);
      line-height: 1.5;
      flex-shrink: 0;
    }

    /* Tag pill row */
    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      flex-shrink: 0;
    }

    .pill {
      font-family: var(--sans);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.08);
      color: var(--dark-mut);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 0.28rem 0.65rem;
      border-radius: 20px;
    }

    /* Item list */
    .item-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      min-height: 0;
    }

    .item {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--r);
      padding: 0.7rem 0.85rem;
      display: flex;
      align-items: flex-start;
      gap: 0.65rem;
      flex-shrink: 0;
    }

    .item-icon {
      font-size: 1rem;
      line-height: 1;
      flex-shrink: 0;
      margin-top: 0.05rem;
    }

    .item-body { flex: 1; min-width: 0; }

    .item-name {
      font-size: 0.82rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: -0.01em;
      line-height: 1.25;
    }

    .item-desc {
      font-size: 0.75rem;
      color: var(--dark-mut);
      line-height: 1.45;
      margin-top: 0.1rem;
    }

    .item-badge {
      font-family: var(--mono);
      font-size: 0.6rem;
      font-weight: 500;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      flex-shrink: 0;
      align-self: flex-start;
      margin-top: 0.05rem;
    }

    .ib-free     { background: rgba(80,180,60,0.15); color: #7dd87d; }
    .ib-cheap    { background: rgba(201,162,100,0.15); color: var(--gold); }
    .ib-price    { background: rgba(255,255,255,0.08); color: var(--dark-mut); }

    /* Schedule rows */
    .sched-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0;
      min-height: 0;
    }

    .srow {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 0.3rem 0.75rem;
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      flex-shrink: 0;
    }

    .srow:last-child { border-bottom: none; }

    .stime {
      font-family: var(--mono);
      font-size: 0.58rem;
      color: var(--gold);
      padding-top: 0.18rem;
      line-height: 1.3;
      font-weight: 400;
    }

    .stext {
      font-size: 0.8rem;
      line-height: 1.55;
      color: var(--dark-mut);
    }

    .stext strong { color: #fff; font-weight: 600; font-style: normal; }

    /* Spec grid (cabin) */
    .spec-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.45rem;
      flex: 1;
      min-height: 0;
    }

    .spec-cell {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--r);
      padding: 0.65rem 0.75rem;
    }

    .spec-l {
      font-family: var(--sans);
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0.7;
      margin-bottom: 0.2rem;
    }

    .spec-v {
      font-size: 0.78rem;
      color: var(--dark-txt);
      line-height: 1.4;
    }

    /* Two-option cards */
    .option-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    .option-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.09);
      border-radius: var(--r);
      padding: 0.85rem 0.8rem;
    }

    .option-label {
      font-family: var(--sans);
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.35rem;
    }

    .option-title {
      font-size: 0.82rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.3rem;
      letter-spacing: -0.01em;
    }

    .option-body {
      font-size: 0.72rem;
      color: var(--dark-mut);
      line-height: 1.5;
    }

    /* Ferry cards */
    .ferry-row {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      flex-shrink: 0;
    }

    .ferry-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--r);
      padding: 0.7rem 0.85rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .ferry-left { flex: 1; }

    .ferry-name {
      font-size: 0.8rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: -0.01em;
    }

    .ferry-note {
      font-size: 0.68rem;
      color: var(--dark-mut);
      margin-top: 0.1rem;
    }

    .ferry-price {
      font-family: var(--mono);
      font-size: 0.9rem;
      color: var(--gold);
    }

    /* Cost rows */
    .cost-rows {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0;
      min-height: 0;
    }

    .crow {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      font-size: 0.8rem;
      flex-shrink: 0;
    }

    .crow:last-child {
      border-color: rgba(255,255,255,0.18);
      padding-top: 0.75rem;
      font-size: 0.88rem;
    }

    .crow .cl { color: var(--dark-mut); flex: 1; }
    .crow .cv { font-family: var(--mono); color: var(--gold); white-space: nowrap; }
    .crow:last-child .cl { color: #fff; font-weight: 600; }
    .crow:last-child .cv { color: #fff; }

    /* Tip bar */
    .tip-bar {
      background: rgba(201,162,100,0.1);
      border: 1px solid rgba(201,162,100,0.2);
      border-left: 3px solid var(--gold);
      border-radius: 0 var(--r) var(--r) 0;
      padding: 0.65rem 0.85rem;
      flex-shrink: 0;
    }

    .tip-eye {
      font-family: var(--sans);
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.25rem;
    }

    .tip-text {
      font-size: 0.77rem;
      color: var(--dark-mut);
      line-height: 1.5;
    }

    .tip-text strong { color: var(--dark-txt); font-weight: 600; }

    /* Checklist (done slide) */
    .check-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-height: 0;
    }

    .check-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 0.9rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--r);
      flex-shrink: 0;
    }

    .check-icon {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: rgba(80,180,60,0.15);
      border: 1px solid rgba(80,180,60,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      flex-shrink: 0;
      color: #7dd87d;
    }

    .check-text {
      font-size: 0.8rem;
      color: var(--dark-txt);
      font-weight: 500;
    }

    /* Welcome CTA */
    .welcome-cta {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 0.5rem;
      min-height: 0;
    }

    /* History items */
    .hist-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      min-height: 0;
    }

    .hist-entry {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--r);
      padding: 0.7rem 0.85rem;
      flex-shrink: 0;
    }

    .hist-cat {
      font-family: var(--sans);
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.2rem;
    }

    .hist-hed {
      font-size: 0.8rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: -0.01em;
      line-height: 1.3;
      margin-bottom: 0.2rem;
    }

    .hist-body {
      font-size: 0.73rem;
      color: var(--dark-mut);
      line-height: 1.5;
    }

    /* Divider */
    .divider {
      height: 1px;
      background: rgba(255,255,255,0.07);
      flex-shrink: 0;
    }

    /* Hide footer on this page */
    footer { display: none; }
  </style>
</head>
<body>
  <Header />
  <main>
  <div id="guide">

    <!-- PROGRESS -->
    <div class="progress-track">
      <div class="progress-fill" id="progressFill" style="width:6.25%"></div>
    </div>

    <!-- STEP HEADER -->
    <div class="step-header">
      <div class="step-label" id="stepLabel">Welcome</div>
      <div class="step-count" id="stepCount">1 / 16</div>
    </div>

    <!-- ═══ SLIDES ════════════════════════════════════════════════ -->
    <div class="slides-viewport">

      <!-- 0: WELCOME -->
      <div class="slide active" data-label="Welcome">
        <div class="s-eye">Upper Peninsula · Michigan · June 2026</div>
        <h1 class="s-title">Four Days at<br>the Top of Michigan</h1>
        <p class="s-sub">A field guide to Mackinac Island and St. Ignace — swimming holes, the car-free island, laborers' bars, and the history underneath all of it. Almost everything is free.</p>
        <div class="pill-row">
          <span class="pill">Jun 13–17</span>
          <span class="pill">St. Ignace, MI</span>
          <span class="pill">6 travelers</span>
          <span class="pill">Lake Michigan cabin</span>
        </div>
        <div class="welcome-cta">
          <div class="divider"></div>
          <div class="tip-bar">
            <div class="tip-eye">Before you start</div>
            <p class="tip-text">Each slide is one thing to know. Tap <strong>Next</strong> to move forward. No scrolling, ever.</p>
          </div>
        </div>
      </div>

      <!-- 1: THE CABIN -->
      <div class="slide" data-label="The Cabin">
        <div class="s-eye">Your Base</div>
        <h2 class="s-title">The Cabin</h2>
        <div class="spec-grid">
          <div class="spec-cell">
            <div class="spec-l">Sleeping</div>
            <div class="spec-v">King + Queen + Double · Sleeps 6</div>
          </div>
          <div class="spec-cell">
            <div class="spec-l">Waterfront</div>
            <div class="spec-v">Direct Lake Michigan beach access</div>
          </div>
          <div class="spec-cell">
            <div class="spec-l">Outdoor</div>
            <div class="spec-v">Firepit at water's edge · kayaks included</div>
          </div>
          <div class="spec-cell">
            <div class="spec-l">Kitchen</div>
            <div class="spec-v">Full kitchen + charcoal grill</div>
          </div>
          <div class="spec-cell">
            <div class="spec-l">View</div>
            <div class="spec-v">St. Helena lighthouse · passing freighters</div>
          </div>
          <div class="spec-cell">
            <div class="spec-l">Check-in / out</div>
            <div class="spec-v">After 4pm · Before 10:30am</div>
          </div>
        </div>
        <div class="tip-bar">
          <div class="tip-eye">Local knowledge</div>
          <p class="tip-text">Leave a window open at night. <strong>A 700-foot freighter passing in the dark at 2am is something.</strong></p>
        </div>
      </div>

      <!-- 2: ESSENTIALS -->
      <div class="slide" data-label="Essentials">
        <div class="s-eye">Before You Go</div>
        <h2 class="s-title">3 Things That<br>Actually Matter</h2>
        <div class="item-list">
          <div class="item">
            <div class="item-icon">🧥</div>
            <div class="item-body">
              <div class="item-name">Bring real layers</div>
              <div class="item-desc">Highs hit 65°F but wind off the Straits drops the feels-like to 50. You need a fleece or jacket every single day, not just at night.</div>
            </div>
          </div>
          <div class="item">
            <div class="item-icon">🧺</div>
            <div class="item-body">
              <div class="item-name">Pack a cooler before every island day</div>
              <div class="item-desc">A sandwich from the cabin costs $0. A sandwich on Mackinac Island costs $18. For 6 people over two island days, that's $200 in savings.</div>
            </div>
          </div>
          <div class="item">
            <div class="item-icon">🎫</div>
            <div class="item-body">
              <div class="item-name">Buy ferry tickets online tonight</div>
              <div class="item-desc">Arnold Line and Star Line both sell advance tickets. Weekend morning departures sell out or have long lines. Book tonight.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3: DAY 1 -->
      <div class="slide" data-label="Day 1 — Arrival">
        <div class="s-eye">Saturday · Jun 13</div>
        <h2 class="s-title">Day 1: Arrival</h2>
        <div class="sched-list">
          <div class="srow">
            <div class="stime">Afternoon</div>
            <div class="stext">Check in after 4pm. Walk the 60 feet to the water. That's your view for four days.</div>
          </div>
          <div class="srow">
            <div class="stime">Late PM</div>
            <div class="stext">Drive 3 miles north to <strong>Castle Rock</strong> ($1/person, 15-min climb, full Straits view). Then <strong>Father Marquette Memorial</strong> waterfront walk for the bridge at sunset.</div>
          </div>
          <div class="srow">
            <div class="stime">Evening</div>
            <div class="stext"><strong>Clyde's Drive-In</strong> for dinner (since 1949, ~$10/person). Light the firepit at the water's edge. Early night — big island day tomorrow.</div>
          </div>
        </div>
        <div class="tip-bar">
          <div class="tip-eye">Tonight</div>
          <p class="tip-text"><strong>Buy tomorrow's ferry tickets now</strong> before you forget. Arnold Line, online.</p>
        </div>
      </div>

      <!-- 4: DAY 2 ISLAND -->
      <div class="slide" data-label="Day 2 — Mackinac Island">
        <div class="s-eye">Sunday · Jun 14</div>
        <h2 class="s-title">Day 2: Mackinac Island</h2>
        <div class="sched-list">
          <div class="srow">
            <div class="stime">9am</div>
            <div class="stext">Pack the cooler. Walk to the <strong>Arnold Line dock</strong>. Take the 9–10am ferry. Bring your own bikes if you have them.</div>
          </div>
          <div class="srow">
            <div class="stime">Mid-AM</div>
            <div class="stext">Rent bikes at the dock. Ride the full <strong>M-185 perimeter</strong> (8 miles, flat, car-free). Picnic at <strong>British Landing</strong> halfway around.</div>
          </div>
          <div class="srow">
            <div class="stime">Afternoon</div>
            <div class="stext">Return bikes. Interior trails to <strong>Arch Rock → Sugar Loaf → Skull Cave</strong>. All free. 90% of tourists never find them.</div>
          </div>
          <div class="srow">
            <div class="stime">Late PM</div>
            <div class="stext"><strong>Fudge sampling</strong> on Market St (every shop gives free samples). Beer at <strong>Horn's Bar</strong> (est. 1859, workers' spot). Evening ferry back.</div>
          </div>
        </div>
      </div>

      <!-- 5: FERRY GUIDE -->
      <div class="slide" data-label="Ferry Guide">
        <div class="s-eye">Getting to the Island</div>
        <h2 class="s-title">The Ferry</h2>
        <div class="ferry-row">
          <div class="ferry-card">
            <div class="ferry-left">
              <div class="ferry-name">Arnold Line</div>
              <div class="ferry-note">Recommended · St. Ignace dock · walk from cabin · ~15 min crossing</div>
            </div>
            <div class="ferry-price">~$30</div>
          </div>
          <div class="ferry-card">
            <div class="ferry-left">
              <div class="ferry-name">Star Line</div>
              <div class="ferry-note">St. Ignace · hydro-jet · slightly faster</div>
            </div>
            <div class="ferry-price">~$30</div>
          </div>
          <div class="ferry-card">
            <div class="ferry-left">
